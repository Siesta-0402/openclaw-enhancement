@@ -0,0 +1,424 @@
+/**
+ * Context Assembly Optimization
+ * ==============================
+ *
+ * Smart context assembly with token budget control, priority-based
+ * ordering, and tool result truncation strategies.
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+import type { MemoryEntry, MemoryType, MemoryPriority } from "./memory/types.js";
+import { TYPE_ASSEMBLY_ORDER, PRIORITY_ORDER, estimateMemoryTokens } from "./memory/types.js";
+import {
+  allocateBudget,
+  getEffectiveContextWindow,
+  DEFAULT_TOKEN_LIMITS,
+} from "./compact/tokenBudget.js";
+
+/** Configuration for context assembly */
+export interface AssemblyConfig {
+  /** Total token budget for context */
+  tokenBudget?: number;
+  /** Model for context window calculations */
+  model?: string;
+  /** Include memory entries */
+  includeMemory?: boolean;
+  /** Include recent messages */
+  includeRecentMessages?: number;
+  /** Max tokens per tool result */
+  maxToolResultTokens: number;
+  /** Truncate long tool results */
+  truncateToolResults: boolean;
+  /** Priority threshold for memory inclusion */
+  memoryPriorityThreshold: MemoryPriority;
+}
+
+/** Default assembly configuration */
+export const DEFAULT_ASSEMBLY_CONFIG: AssemblyConfig = {
+  includeMemory: true,
+  includeRecentMessages: 20,
+  maxToolResultTokens: DEFAULT_TOKEN_LIMITS.MAX_TOOL_RESULT_TOKENS,
+  truncateToolResults: true,
+  memoryPriorityThreshold: "low",
+};
+
+/** Result of context assembly */
+export interface AssemblyResult {
+  /** Ordered messages for model context */
+  messages: AgentMessage[];
+  /** Memory entries included */
+  memoryEntries: MemoryEntry[];
+  /** Estimated total tokens */
+  estimatedTokens: number;
+  /** Token breakdown */
+  breakdown: {
+    systemPrompt: number;
+    memory: number;
+    recentMessages: number;
+    historicalMessages: number;
+  };
+  /** Whether budget was exceeded */
+  budgetExceeded: boolean;
+  /** What was truncated */
+  truncation: {
+    toolResultsTruncated: number;
+    messagesDropped: number;
+    memoryEntriesDropped: number;
+  };
+}
+
+/**
+ * Assemble optimized context from messages and memory.
+ *
+ * Strategy:
+ * 1. Calculate available budget
+ * 2. Sort memory by priority and type
+ * 3. Allocate budget to components
+ * 4. Truncate tool results as needed
+ * 5. Fill remaining budget with messages
+ */
+export function assembleContext(
+  messages: AgentMessage[],
+  memories: MemoryEntry[],
+  config?: Partial<AssemblyConfig>
+): AssemblyResult {
+  const cfg = { ...DEFAULT_ASSEMBLY_CONFIG, ...config };
+
+  // Determine token budget
+  const modelBudget = cfg.model
+    ? getEffectiveContextWindow(cfg.model)
+    : 100000;
+  const effectiveBudget = cfg.tokenBudget ?? modelBudget;
+
+  // Allocate budget across components
+  const budget = allocateBudget(effectiveBudget, {
+    systemPrompt: DEFAULT_TOKEN_LIMITS.SYSTEM_PROMPT_TOKENS,
+    memoryPriority: 0.2,
+    recentMessagesPriority: 0.5,
+  });
+
+  // Sort memories by priority
+  const sortedMemories = sortMemoriesForAssembly(memories, cfg.memoryPriorityThreshold);
+
+  // Select memories within budget
+  const { selectedMemories, memoryTokens } = selectMemoriesWithinBudget(
+    sortedMemories,
+    budget.memory
+  );
+
+  // Truncate tool results if needed
+  const truncationResult = cfg.truncateToolResults
+    ? truncateLongToolResults(messages, cfg.maxToolResultTokens)
+    : { messages, truncated: 0 };
+
+  // Select messages within remaining budget
+  const remainingBudget = effectiveBudget - memoryTokens - budget.systemPrompt;
+  const selectedMessages = selectMessagesWithinBudget(
+    truncationResult.messages,
+    remainingBudget,
+    cfg.includeRecentMessages
+  );
+
+  const totalTokens = memoryTokens +
+    estimateMessagesTokens(selectedMessages) +
+    budget.systemPrompt;
+
+  return {
+    messages: selectedMessages,
+    memoryEntries: selectedMemories,
+    estimatedTokens: totalTokens,
+    breakdown: {
+      systemPrompt: budget.systemPrompt,
+      memory: memoryTokens,
+      recentMessages: budget.recentMessages,
+      historicalMessages: budget.historicalMessages,
+    },
+    budgetExceeded: totalTokens > effectiveBudget,
+    truncation: {
+      toolResultsTruncated: truncationResult.truncated,
+      messagesDropped: messages.length - selectedMessages.length,
+      memoryEntriesDropped: memories.length - selectedMemories.length,
+    },
+  };
+}
+
+/**
+ * Sort memories for assembly priority.
+ * Order: user > project > feedback > reference
+ * Within each type: high > medium > low, then by updated timestamp
+ */
+function sortMemoriesForAssembly(
+  memories: MemoryEntry[],
+  priorityThreshold: MemoryPriority
+): MemoryEntry[] {
+  const thresholdOrder = PRIORITY_ORDER[priorityThreshold];
+
+  return memories
+    .filter((m) => PRIORITY_ORDER[m.priority] <= thresholdOrder)
+    .toSorted((a, b) => {
+      // Type order first
+      const typeDiff = TYPE_ASSEMBLY_ORDER[a.type] - TYPE_ASSEMBLY_ORDER[b.type];
+      if (typeDiff !== 0) {return typeDiff;}
+
+      // Priority within type
+      const priorityDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];
+      if (priorityDiff !== 0) {return priorityDiff;}
+
+      // Newer first
+      return (
+        new Date(b.updated).getTime() - new Date(a.updated).getTime()
+      );
+    });
+}
+
+/**
+ * Select memories that fit within token budget.
+ */
+function selectMemoriesWithinBudget(
+  memories: MemoryEntry[],
+  budget: number
+): { selectedMemories: MemoryEntry[]; tokens: number } {
+  const selected: MemoryEntry[] = [];
+  let usedTokens = 0;
+
+  for (const memory of memories) {
+    const memoryTokens = estimateMemoryTokens(memory);
+    if (usedTokens + memoryTokens > budget) {
+      continue;
+    }
+    usedTokens += memoryTokens;
+    selected.push(memory);
+  }
+
+  return { selectedMemories: selected, tokens: usedTokens };
+}
+
+/**
+ * Truncate long tool results to fit within per-result budget.
+ */
+function truncateLongToolResults(
+  messages: AgentMessage[],
+  maxTokens: number
+): { messages: AgentMessage[]; truncated: number } {
+  const maxChars = maxTokens * 4; // ~4 chars per token
+  let truncated = 0;
+
+  const result = messages.map((message) => {
+    if (message.type !== "user" || !Array.isArray(message.message.content)) {
+      return message;
+    }
+
+    let touched = false;
+    const newContent = message.message.content.map((block) => {
+      if (block.type !== "tool_result") {return block;}
+
+      const trBlock = block as {
+        type: "tool_result";
+        content?: string;
+        tool_use_id: string;
+      };
+
+      if (typeof trBlock.content !== "string") {return block;}
+      if (trBlock.content.length <= maxChars) {return block;}
+
+      truncated++;
+      touched = true;
+      return {
+        ...trBlock,
+        content: truncateToolResultMiddle(
+          trBlock.content,
+          maxChars
+        ),
+      };
+    });
+
+    if (!touched) {return message;}
+    return {
+      ...message,
+      message: { ...message.message, content: newContent },
+    };
+  });
+
+  return { messages: result, truncated };
+}
+
+/**
+ * Truncate tool result from middle, keeping head and tail.
+ */
+function truncateToolResultMiddle(content: string, maxChars: number): string {
+  if (content.length <= maxChars) {return content;}
+
+  const headSize = Math.floor(maxChars * 0.5);
+  const tailSize = Math.floor(maxChars * 0.3);
+  const marker = "\n[... tool result truncated ...]\n";
+  const availableLength = maxChars - marker.length;
+
+  const head = content.slice(0, headSize);
+  const tail = content.slice(-tailSize);
+
+  // Ensure we don't overlap
+  if (headSize + tailSize >= content.length) {
+    return content.slice(0, maxChars);
+  }
+
+  return head + marker + tail;
+}
+
+/**
+ * Select messages that fit within token budget.
+ * Prioritizes recent messages.
+ */
+function selectMessagesWithinBudget(
+  messages: AgentMessage[],
+  budget: number,
+  recentLimit?: number
+): AgentMessage[] {
+  if (messages.length === 0) {return [];}
+
+  // Always keep the most recent N messages
+  const recentCount = recentLimit ?? messages.length;
+  const recentMessages = messages.slice(-recentCount);
+  const recentTokens = estimateMessagesTokens(recentMessages);
+
+  // If recent messages already exceed budget, truncate from the front
+  if (recentTokens > budget) {
+    const result: AgentMessage[] = [];
+    let usedTokens = 0;
+
+    for (let i = recentMessages.length - 1; i >= 0; i--) {
+      const msgTokens = estimateMessageTokens(recentMessages[i]);
+      if (usedTokens + msgTokens > budget) {
+        // Add a "context truncated" marker if we're dropping older messages
+        if (result.length > 0) {
+          result.unshift(createTruncationMarker());
+        }
+        break;
+      }
+      usedTokens += msgTokens;
+      result.unshift(recentMessages[i]);
+    }
+
+    return result;
+  }
+
+  // We have room for recent messages, try adding older ones
+  const olderMessages = messages.slice(0, -recentCount);
+  const remainingBudget = budget - recentTokens;
+  const selectedOlder = selectOlderMessages(olderMessages, remainingBudget);
+
+  return [...selectedOlder, ...recentMessages];
+}
+
+/**
+ * Select older messages from the front, oldest first (FIFO).
+ */
+function selectOlderMessages(
+  messages: AgentMessage[],
+  budget: number
+): AgentMessage[] {
+  const selected: AgentMessage[] = [];
+  let usedTokens = 0;
+
+  // Take from the front (oldest first)
+  for (const msg of messages) {
+    const msgTokens = estimateMessageTokens(msg);
+    if (usedTokens + msgTokens > budget) {
+      break;
+    }
+    usedTokens += msgTokens;
+    selected.push(msg);
+  }
+
+  return selected;
+}
+
+/**
+ * Create a truncation marker message.
+ */
+function createTruncationMarker(): AgentMessage {
+  return {
+    type: "system",
+    id: `truncation-${Date.now()}`,
+    timestamp: new Date().toISOString(),
+    isMeta: true,
+    message: {
+      role: "system",
+      content: "[Earlier context truncated due to token budget]",
+    },
+  };
+}
+
+/**
+ * Estimate tokens in messages.
+ */
+function estimateMessagesTokens(messages: AgentMessage[]): number {
+  return messages.reduce((sum, msg) => sum + estimateMessageTokens(msg), 0);
+}
+
+/**
+ * Estimate tokens in a single message.
+ */
+function estimateMessageTokens(message: AgentMessage): number {
+  const overhead = 10;
+
+  if (typeof message.message.content === "string") {
+    return overhead + Math.ceil(message.message.content.length / 4);
+  }
+
+  if (Array.isArray(message.message.content)) {
+    return overhead +
+      message.message.content.reduce((sum, block) => {
+        if (block.type === "text") {
+          return sum + Math.ceil((block as { text: string }).text.length / 4);
+        }
+        if (block.type === "tool_result") {
+          const content = (block as { content?: string }).content;
+          if (typeof content === "string") {
+            return sum + Math.ceil(content.length / 4);
+          }
+          return sum + 100;
+        }
+        // tool_use, thinking, etc.
+        return sum + 20;
+      }, 0);
+  }
+
+  return overhead;
+}
+
+/**
+ * Merge memory entries into messages as a system prompt addition.
+ */
+export function formatMemoryAsSystemAddition(
+  memories: MemoryEntry[]
+): string {
+  if (memories.length === 0) {return "";}
+
+  const sections: string[] = [];
+
+  // Group by type
+  const byType = new Map<MemoryType, MemoryEntry[]>();
+  for (const memory of memories) {
+    const existing = byType.get(memory.type) ?? [];
+    existing.push(memory);
+    byType.set(memory.type, existing);
+  }
+
+  // Format each type
+  for (const [type, entries] of byType) {
+    const typeLabel = {
+      user: "User Context",
+      feedback: "Feedback & Corrections",
+      project: "Project Context",
+      reference: "Reference Materials",
+    }[type];
+
+    sections.push(`### ${typeLabel}`);
+    for (const entry of entries) {
+      sections.push(`\n${entry.content}`);
+    }
+    sections.push("");
+  }
+
+  return sections.join("\n");
+}
