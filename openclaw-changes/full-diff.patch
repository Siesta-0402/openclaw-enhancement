@@ -0,0 +1,437 @@
+/**
+ * Compaction Orchestrator
+ * =======================
+ *
+ * Coordinates the four-tier compaction system:
+ * L1: HistorySnip - Passive, message-count based
+ * L2: MicroCompact - Time-based tool result clearing
+ * L3: ContextCollapse - Active middle-section summarization
+ * L4: AutoCompact - Reactive full summarization
+ *
+ * Each tier is independent but they work together to manage context
+ * at different pressure levels.
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+import type {
+  HistorySnipConfig,
+  HistorySnipResult,
+} from "./historySnip.js";
+import type {
+  MicroCompactConfig,
+  MicroCompactResult,
+} from "./microCompact.js";
+import type {
+  ContextCollapseConfig,
+  ContextCollapseResult,
+} from "./contextCollapse.js";
+import type {
+  AutoCompactConfig,
+  AutoCompactResult,
+} from "./autoCompact.js";
+import {
+  applyHistorySnip,
+  shouldHistorySnip,
+} from "./historySnip.js";
+import {
+  applyMicroCompact,
+  shouldMicroCompact,
+} from "./microCompact.js";
+import {
+  applyContextCollapse,
+  shouldContextCollapse,
+} from "./contextCollapse.js";
+import {
+  applyAutoCompact,
+  shouldAutoCompact,
+} from "./autoCompact.js";
+import {
+  getAutoCompactThreshold,
+} from "./tokenBudget.js";
+
+/** Compaction tier levels */
+export type CompactionTier = 1 | 2 | 3 | 4;
+
+/** Compaction tier names */
+export const COMPACTION_TIER_NAMES: Record<CompactionTier, string> = {
+  1: "HistorySnip",
+  2: "MicroCompact",
+  3: "ContextCollapse",
+  4: "AutoCompact",
+};
+
+/** Overall compaction configuration */
+export interface CompactionConfig {
+  historySnip: Partial<HistorySnipConfig>;
+  microCompact: Partial<MicroCompactConfig>;
+  contextCollapse: Partial<ContextCollapseConfig>;
+  autoCompact: Partial<AutoCompactConfig>;
+  /** Maximum tier to allow (for testing) */
+  maxTier: CompactionTier;
+}
+
+/** Default compaction configuration */
+export const DEFAULT_COMPACTION_CONFIG: CompactionConfig = {
+  historySnip: {},
+  microCompact: {},
+  contextCollapse: {},
+  autoCompact: {},
+  maxTier: 4,
+};
+
+/** Result of a compaction operation */
+export interface CompactionOperationResult {
+  /** Whether any compaction was applied */
+  compacted: boolean;
+  /** Highest tier that was applied */
+  tierApplied?: CompactionTier;
+  /** Messages after compaction */
+  messages: AgentMessage[];
+  /** Estimated tokens after compaction */
+  tokensAfter: number;
+  /** Tier-specific results */
+  results: {
+    historySnip?: HistorySnipResult;
+    microCompact?: MicroCompactResult;
+    contextCollapse?: ContextCollapseResult;
+    autoCompact?: AutoCompactResult;
+  };
+  /** Reason for compaction */
+  reason: string;
+}
+
+/** Token estimation for messages (rough) */
+function estimateMessagesTokens(messages: AgentMessage[]): number {
+  return messages.reduce((sum, msg) => {
+    let contentTokens = 0;
+    const content = msg.message.content;
+
+    if (typeof content === "string") {
+      contentTokens = Math.ceil(content.length / 4);
+    } else if (Array.isArray(content)) {
+      for (const block of content) {
+        if (block.type === "text") {
+          contentTokens += Math.ceil((block as { text: string }).text.length / 4);
+        } else if (block.type === "tool_result") {
+          const result = block as { content?: string };
+          if (typeof result.content === "string") {
+            contentTokens += Math.ceil(result.content.length / 4);
+          } else {
+            contentTokens += 100;
+          }
+        } else {
+          contentTokens += 20;
+        }
+      }
+    }
+
+    // Message overhead
+    return sum + contentTokens + 10;
+  }, 0);
+}
+
+/**
+ * Determine which compaction tier should trigger.
+ */
+export function determineCompactionTier(
+  messages: AgentMessage[],
+  tokenCount: number,
+  model: string,
+  config?: Partial<CompactionConfig>
+): CompactionTier | null {
+  const maxTier = config?.maxTier ?? 4;
+
+  // L4: AutoCompact - highest priority check
+  if (maxTier >= 4 && shouldAutoCompact(tokenCount, model, config?.autoCompact)) {
+    return 4;
+  }
+
+  // L3: ContextCollapse
+  if (
+    maxTier >= 3 &&
+    shouldContextCollapse(tokenCount, model, config?.contextCollapse)
+  ) {
+    return 3;
+  }
+
+  // L2: MicroCompact
+  const microResult = shouldMicroCompact(messages, config?.microCompact);
+  if (maxTier >= 2 && microResult.shouldTrigger) {
+    return 2;
+  }
+
+  // L1: HistorySnip
+  if (maxTier >= 1 && shouldHistorySnip(messages.length, config?.historySnip)) {
+    return 1;
+  }
+
+  return null;
+}
+
+/**
+ * Run compaction at the specified tier (or auto-determine).
+ */
+export async function runCompaction(
+  messages: AgentMessage[],
+  model: string,
+  config?: Partial<CompactionConfig>,
+  options?: {
+    targetTier?: CompactionTier;
+    summarizer?: (
+      content: string,
+      instructions?: string
+    ) => Promise<string>;
+  }
+): Promise<CompactionOperationResult> {
+  const tokenCount = estimateMessagesTokens(messages);
+  const targetTier =
+    options?.targetTier ??
+    determineCompactionTier(messages, tokenCount, model, config);
+
+  if (!targetTier) {
+    return {
+      compacted: false,
+      messages,
+      tokensAfter: tokenCount,
+      results: {},
+      reason: "No compaction tier triggered",
+    };
+  }
+
+  const results: CompactionOperationResult["results"] = {};
+  let currentMessages = messages;
+  let currentTokens = tokenCount;
+
+  // Apply tiers sequentially up to target
+  for (const tier of [1, 2, 3, 4] as CompactionTier[]) {
+    if (tier > targetTier) {break;}
+
+    switch (tier) {
+      case 1: {
+        const result = applyHistorySnip(
+          currentMessages,
+          config?.historySnip
+        );
+        results.historySnip = result;
+        if (result.snipped) {
+          currentMessages = result.messages;
+          currentTokens = estimateMessagesTokens(currentMessages);
+        }
+        break;
+      }
+
+      case 2: {
+        const result = applyMicroCompact(
+          currentMessages,
+          config?.microCompact
+        );
+        results.microCompact = result;
+        if (result.compacted) {
+          currentMessages = result.messages;
+          currentTokens = estimateMessagesTokens(currentMessages);
+        }
+        break;
+      }
+
+      case 3: {
+        const result = await applyContextCollapse(
+          currentMessages,
+          currentTokens,
+          model,
+          config?.contextCollapse,
+          options?.summarizer
+        );
+        results.contextCollapse = result;
+        if (result.collapsed) {
+          currentMessages = result.messages;
+          currentTokens = estimateMessagesTokens(currentMessages);
+        }
+        break;
+      }
+
+      case 4: {
+        const result = await applyAutoCompact(
+          currentMessages,
+          currentTokens,
+          model,
+          config?.autoCompact,
+          { summarizer: options?.summarizer }
+        );
+        results.autoCompact = result;
+        if (result.compacted) {
+          currentMessages = result.messages;
+          currentTokens = estimateMessagesTokens(currentMessages);
+        }
+        break;
+      }
+    }
+  }
+
+  return {
+    compacted: targetTier !== null,
+    tierApplied: targetTier,
+    messages: currentMessages,
+    tokensAfter: currentTokens,
+    results,
+    reason: `${COMPACTION_TIER_NAMES[targetTier]} (Tier ${targetTier}) applied`,
+  };
+}
+
+/**
+ * Run a single compaction tier only.
+ */
+export async function runSingleTier(
+  messages: AgentMessage[],
+  model: string,
+  tier: CompactionTier,
+  config?: Partial<CompactionConfig>,
+  options?: {
+    summarizer?: (
+      content: string,
+      instructions?: string
+    ) => Promise<string>;
+  }
+): Promise<CompactionOperationResult> {
+  return runCompaction(messages, model, { ...config, maxTier: tier }, options);
+}
+
+/**
+ * Check what tier would be triggered without applying it.
+ */
+export function previewCompaction(
+  messages: AgentMessage[],
+  model: string,
+  config?: Partial<CompactionConfig>
+): {
+  tier: CompactionTier | null;
+  reason: string;
+  tokenCount: number;
+  threshold: number;
+} {
+  const tokenCount = estimateMessagesTokens(messages);
+  const threshold = getAutoCompactThreshold(model);
+
+  // Check tiers in reverse order (highest first)
+  if (
+    (config?.maxTier ?? 4) >= 4 &&
+    shouldAutoCompact(tokenCount, model, config?.autoCompact)
+  ) {
+    return {
+      tier: 4,
+      reason: "Token count exceeds auto-compact threshold",
+      tokenCount,
+      threshold,
+    };
+  }
+
+  if (
+    (config?.maxTier ?? 4) >= 3 &&
+    shouldContextCollapse(tokenCount, model, config?.contextCollapse)
+  ) {
+    return {
+      tier: 3,
+      reason: "Token count exceeds context collapse threshold",
+      tokenCount,
+      threshold,
+    };
+  }
+
+  const microResult = shouldMicroCompact(messages, config?.microCompact);
+  if ((config?.maxTier ?? 4) >= 2 && microResult.shouldTrigger) {
+    return {
+      tier: 2,
+      reason: `Time gap (${microResult.gapMinutes}min) exceeds microcompact threshold`,
+      tokenCount,
+      threshold,
+    };
+  }
+
+  if (
+    (config?.maxTier ?? 4) >= 1 &&
+    shouldHistorySnip(messages.length, config?.historySnip)
+  ) {
+    return {
+      tier: 1,
+      reason: `Message count (${messages.length}) exceeds HistorySnip threshold`,
+      tokenCount,
+      threshold,
+    };
+  }
+
+  return {
+    tier: null,
+    reason: "No compaction tier triggered",
+    tokenCount,
+    threshold,
+  };
+}
+
+/**
+ * Get a human-readable status of compaction state.
+ */
+export function getCompactionStatus(
+  messages: AgentMessage[],
+  model: string,
+  config?: Partial<CompactionConfig>
+): {
+  level: "none" | "low" | "medium" | "high" | "critical";
+  details: string;
+  tiersTriggered: string[];
+  tokenCount: number;
+  percentUsed: number;
+} {
+  const tokenCount = estimateMessagesTokens(messages);
+  const preview = previewCompaction(messages, model, config);
+  const threshold = getAutoCompactThreshold(model);
+  const percentUsed = Math.round((tokenCount / threshold) * 100);
+
+  const tiersTriggered: string[] = [];
+  let level: "none" | "low" | "medium" | "high" | "critical" = "none";
+
+  if (preview.tier === 4) {
+    level = "critical";
+    tiersTriggered.push("AutoCompact (L4)");
+  } else if (preview.tier === 3) {
+    level = "high";
+    tiersTriggered.push("ContextCollapse (L3)");
+  } else if (preview.tier === 2) {
+    level = "medium";
+    tiersTriggered.push("MicroCompact (L2)");
+  } else if (preview.tier === 1) {
+    level = "low";
+    tiersTriggered.push("HistorySnip (L1)");
+  }
+
+  return {
+    level,
+    details: preview.reason,
+    tiersTriggered,
+    tokenCount,
+    percentUsed,
+  };
+}
+
+// Re-export all tier modules
+export {
+  applyHistorySnip,
+  shouldHistorySnip,
+  DEFAULT_HISTORY_SNIP_CONFIG,
+} from "./historySnip.js";
+
+export {
+  applyMicroCompact,
+  shouldMicroCompact,
+  TIME_BASED_MC_CLEARED_MESSAGE,
+} from "./microCompact.js";
+
+export {
+  applyContextCollapse,
+  shouldContextCollapse,
+} from "./contextCollapse.js";
+
+export {
+  applyAutoCompact,
+  shouldAutoCompact,
+} from "./autoCompact.js";
+
+export * from "./tokenBudget.js";
