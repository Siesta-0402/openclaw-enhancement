@@ -0,0 +1,384 @@
+/**
+ * LspManager - Language Server Protocol lifecycle management
+ */
+
+import { spawn, type ChildProcess } from "node:child_process";
+import { EventEmitter } from "node:events";
+import { logDebug, logWarn } from "../logger.js";
+
+export type ServerState = "stopped" | "starting" | "running" | "stopping" | "error";
+
+export interface LspServerConfig {
+  name: string;
+  command: string;
+  args?: string[];
+  env?: Record<string, string>;
+  rootUri?: string;
+  initializationOptions?: Record<string, unknown>;
+}
+
+export interface ServerCapabilities {
+  hoverProvider?: boolean;
+  completionProvider?: boolean | { triggerCharacters?: string[] };
+  definitionProvider?: boolean | { provider: true };
+  referencesProvider?: boolean | { provider: true };
+  diagnosticProvider?: boolean | { interFileDependencies: boolean; workspaceDiagnostics: boolean };
+  signatureHelpProvider?: boolean | { triggerCharacters?: string[] };
+  declarationProvider?: boolean | { provider: true };
+  typeDefinitionProvider?: boolean | { provider: true };
+  implementationProvider?: boolean | { provider: true };
+  codeActionProvider?: boolean | { provider: true };
+  codeLensProvider?: boolean | { provider: true };
+  documentFormattingProvider?: boolean | { provider: true };
+  documentRangeFormattingProvider?: boolean | { provider: true };
+  documentSymbolProvider?: boolean | { provider: true };
+  workspaceSymbolProvider?: boolean | { provider: true };
+  renameProvider?: boolean | { provider: true };
+  [key: string]: unknown;
+}
+
+export type LspEvent =
+  | { type: "state-change"; serverId: string; oldState: ServerState; newState: ServerState }
+  | { type: "error"; serverId: string; error: string }
+  | { type: "notification"; serverId: string; method: string; params: unknown }
+  | { type: "started"; serverId: string }
+  | { type: "stopped"; serverId: string };
+
+interface LspSession {
+  serverId: string;
+  config: LspServerConfig;
+  process: ChildProcess | null;
+  state: ServerState;
+  capabilities: ServerCapabilities | null;
+  requestId: number;
+  pendingRequests: Map<number, { resolve: (v: unknown) => void; reject: (e: Error) => void }>;
+  buffer: string;
+  initialized: boolean;
+  errorMessage?: string;
+  startedAt?: Date;
+}
+
+function encodeLspMessage(body: unknown): string {
+  const json = JSON.stringify(body);
+  return `Content-Length: ${Buffer.byteLength(json, "utf-8")}\r\n\r\n${json}`;
+}
+
+function parseLspMessages(buffer: string): { messages: unknown[]; remaining: string } {
+  const messages: unknown[] = [];
+  let remaining = buffer;
+
+  while (true) {
+    const headerEnd = remaining.indexOf("\r\n\r\n");
+    if (headerEnd === -1) {
+      break;
+    }
+    const header = remaining.slice(0, headerEnd);
+    const match = header.match(/Content-Length:\s*(\d+)/i);
+    if (!match) {
+      remaining = remaining.slice(headerEnd + 4);
+      continue;
+    }
+    const contentLength = parseInt(match[1], 10);
+    const bodyStart = headerEnd + 4;
+    const bodyEnd = bodyStart + contentLength;
+    if (Buffer.byteLength(remaining.slice(bodyStart), "utf-8") < contentLength) {
+      break;
+    }
+    try {
+      const body = remaining.slice(bodyStart, bodyStart + contentLength);
+      messages.push(JSON.parse(body));
+    } catch {
+      // skip malformed
+    }
+    remaining = remaining.slice(bodyEnd);
+  }
+
+  return { messages, remaining };
+}
+
+export class LspManager extends EventEmitter {
+  private readonly sessions = new Map<string, LspSession>();
+  private readonly workspaceRoot: string;
+
+  constructor(workspaceRoot: string) {
+    super();
+    this.workspaceRoot = workspaceRoot;
+  }
+
+  registerServer(id: string, config: LspServerConfig): void {
+    if (this.sessions.has(id)) {
+      throw new Error(`Server already registered: ${id}`);
+    }
+    this.sessions.set(id, {
+      serverId: id,
+      config,
+      process: null,
+      state: "stopped",
+      capabilities: null,
+      requestId: 0,
+      pendingRequests: new Map(),
+      buffer: "",
+      initialized: false,
+    });
+    logDebug(`LspManager: registered server ${id}`);
+  }
+
+  unregisterServer(id: string): void {
+    const session = this.sessions.get(id);
+    if (!session) {
+      return;
+    }
+    if (session.state === "running" || session.state === "starting") {
+      throw new Error(`Cannot unregister running server: ${id}`);
+    }
+    this.sessions.delete(id);
+    logDebug(`LspManager: unregistered server ${id}`);
+  }
+
+  async startServer(id: string): Promise<void> {
+    const session = this.sessions.get(id);
+    if (!session) {
+      throw new Error(`Server not found: ${id}`);
+    }
+    if (session.state === "running" || session.state === "starting") {
+      return;
+    }
+
+    this.setState(session, "starting");
+
+    return new Promise((resolve, reject) => {
+      const { command, args = [], env = {}, rootUri, initializationOptions } = session.config;
+      const finalEnv = { ...process.env, ...env };
+
+      try {
+        const child = spawn(command, args, {
+          env: finalEnv,
+          stdio: ["pipe", "pipe", "pipe"],
+          cwd: this.workspaceRoot,
+        });
+
+        session.process = child;
+
+        child.stdout?.on("data", (data: Buffer) => {
+          this.handleData(id, data);
+        });
+
+        child.stderr?.on("data", (data: Buffer) => {
+          logWarn(`LspManager[${id}] stderr: ${data.toString()}`);
+        });
+
+        child.on("error", (err) => {
+          logWarn(`LspManager[${id}] process error: ${err.message}`);
+          this.setState(session, "error", err.message);
+          reject(err);
+        });
+
+        child.on("exit", (code, signal) => {
+          logDebug(`LspManager[${id}] exited: code=${code} signal=${signal}`);
+          this.setState(session, "stopped");
+          this.emit({ type: "stopped", serverId: id });
+        });
+
+        // Initialize the LSP session
+        this.sendInitialize(session, rootUri, initializationOptions).then(
+          (capabilities) => {
+            session.capabilities = capabilities;
+            session.initialized = true;
+            this.setState(session, "running");
+            this.emit({ type: "started", serverId: id });
+            resolve();
+          },
+          (err) => {
+            reject(err);
+          },
+        );
+      } catch (err) {
+        const errorMessage = err instanceof Error ? err.message : String(err);
+        this.setState(session, "error", errorMessage);
+        reject(err);
+      }
+    });
+  }
+
+  async stopServer(id: string): Promise<void> {
+    const session = this.sessions.get(id);
+    if (!session) {
+      throw new Error(`Server not found: ${id}`);
+    }
+    if (session.state !== "running" && session.state !== "starting") {
+      return;
+    }
+
+    this.setState(session, "stopping");
+
+    // Send shutdown request
+    try {
+      await this.sendRequestRaw(session, "shutdown", undefined);
+    } catch {
+      // Ignore shutdown errors
+    }
+
+    // Send exit notification
+    this.sendNotificationRaw(session, "exit", undefined);
+
+    // Kill the process
+    session.process?.kill();
+
+    this.setState(session, "stopped");
+    this.emit({ type: "stopped", serverId: id });
+  }
+
+  getCapabilities(id: string): ServerCapabilities | null {
+    return this.sessions.get(id)?.capabilities ?? null;
+  }
+
+  getState(id: string): ServerState | undefined {
+    return this.sessions.get(id)?.state;
+  }
+
+  async sendRequest<T>(id: string, method: string, params: unknown): Promise<T> {
+    const session = this.sessions.get(id);
+    if (!session) {
+      throw new Error(`Server not found: ${id}`);
+    }
+    if (session.state !== "running") {
+      throw new Error(`Server not running: ${id} (state: ${session.state})`);
+    }
+    return this.sendRequestRaw(session, method, params) as Promise<T>;
+  }
+
+  sendNotification(id: string, method: string, params: unknown): void {
+    const session = this.sessions.get(id);
+    if (!session) {
+      throw new Error(`Server not found: ${id}`);
+    }
+    if (session.state !== "running") {
+      throw new Error(`Server not running: ${id}`);
+    }
+    this.sendNotificationRaw(session, method, params);
+  }
+
+  listServers(): Array<{ serverId: string; state: ServerState; capabilities: ServerCapabilities | null }> {
+    return Array.from(this.sessions.values()).map((s) => ({
+      serverId: s.serverId,
+      state: s.state,
+      capabilities: s.capabilities,
+    }));
+  }
+
+  private setState(session: LspSession, newState: ServerState, errorMessage?: string): void {
+    const oldState = session.state;
+    session.state = newState;
+    if (errorMessage) {
+      session.errorMessage = errorMessage;
+    }
+    if (newState === "running") {
+      session.startedAt = new Date();
+    }
+    this.emit({
+      type: "state-change",
+      serverId: session.serverId,
+      oldState,
+      newState,
+    });
+  }
+
+  private sendRequestRaw(session: LspSession, method: string, params: unknown): Promise<unknown> {
+    return new Promise((resolve, reject) => {
+      const id = ++session.requestId;
+      session.pendingRequests.set(id, { resolve, reject });
+      const message = { jsonrpc: "2.0", id, method, params };
+      const encoded = encodeLspMessage(message);
+      session.process?.stdin?.write(encoded, "utf-8");
+
+      // Timeout after 10 seconds
+      setTimeout(() => {
+        if (session.pendingRequests.has(id)) {
+          session.pendingRequests.delete(id);
+          reject(new Error(`LSP request ${method} timed out`));
+        }
+      }, 10_000);
+    });
+  }
+
+  private sendNotificationRaw(session: LspSession, method: string, params: unknown): void {
+    const message = { jsonrpc: "2.0", method, params };
+    const encoded = encodeLspMessage(message);
+    session.process?.stdin?.write(encoded, "utf-8");
+  }
+
+  private async sendInitialize(
+    session: LspSession,
+    rootUri?: string,
+    initializationOptions?: Record<string, unknown>,
+  ): Promise<ServerCapabilities> {
+    const params = {
+      processId: process.pid,
+      clientInfo: { name: "openclaw", version: "1.0.0" },
+      rootUri: rootUri ?? `file://${this.workspaceRoot}`,
+      capabilities: {},
+      initializationOptions,
+    };
+
+    const response = (await this.sendRequestRaw(session, "initialize", params)) as {
+      capabilities: ServerCapabilities;
+    };
+
+    // Send initialized notification
+    this.sendNotificationRaw(session, "initialized", {});
+
+    return response.capabilities;
+  }
+
+  private handleData(id: string, data: Buffer): void {
+    const session = this.sessions.get(id);
+    if (!session) {
+      return;
+    }
+
+    session.buffer += data.toString();
+    const { messages, remaining } = parseLspMessages(session.buffer);
+    session.buffer = remaining;
+
+    for (const msg of messages) {
+      this.handleMessage(session, msg);
+    }
+  }
+
+  private handleMessage(session: LspSession, msg: unknown): void {
+    if (!msg || typeof msg !== "object") {
+      return;
+    }
+    const message = msg as Record<string, unknown>;
+
+    if (message["id"] !== undefined && message["result"] !== undefined) {
+      // Response
+      const id = Number(message["id"]);
+      const pending = session.pendingRequests.get(id);
+      if (pending) {
+        session.pendingRequests.delete(id);
+        pending.resolve(message["result"]);
+      }
+    } else if (message["id"] !== undefined && message["error"] !== undefined) {
+      // Error response
+      const id = Number(message["id"]);
+      const pending = session.pendingRequests.get(id);
+      if (pending) {
+        session.pendingRequests.delete(id);
+        pending.reject(new Error(JSON.stringify(message["error"])));
+      }
+    } else if (message["method"] !== undefined) {
+      // Notification or request
+      const method = String(message["method"]);
+      const params = message["params"];
+
+      if (message["id"] !== undefined) {
+        // Server request (not expected normally, but handle it)
+        logDebug(`LspManager: unexpected server request: ${method}`);
+      } else {
+        // Server notification
+        this.emit({ type: "notification", serverId: session.serverId, method, params });
+      }
+    }
+  }
+}
