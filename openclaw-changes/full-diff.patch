+/**
+ * Green Contract Types - Core type definitions for the Green Contract testing framework
+ */
+
+export enum GreenLevel {
+  /** Critical: All tests must pass or the build fails */
+  CRITICAL = 0,
+  /** High: Tests should pass; failures are serious */
+  HIGH = 1,
+  /** Medium: Tests should pass; failures are notable */
+  MEDIUM = 2,
+  /** Low: Tests run but failures are warnings only */
+  LOW = 3,
+  /** Info: Tests run for visibility; failures don't affect result */
+  INFO = 4,
+}
+
+export interface TestArtifact {
+  type: "screenshot" | "log" | "data" | "file";
+  name: string;
+  path?: string;
+  content?: string;
+  url?: string;
+}
+
+export interface TestResult {
+  passed: boolean;
+  message?: string;
+  durationMs?: number;
+  artifacts?: TestArtifact[];
+  subResults?: TestResult[];
+}
+
+export interface GreenContract {
+  id: string;
+  name: string;
+  description: string;
+  level: GreenLevel;
+  tags?: string[];
+  setup?: () => Promise<void> | void;
+  teardown?: () => Promise<void> | void;
+  test: () => Promise<TestResult> | TestResult;
+}
+
+export interface ContractFilter {
+  level?: GreenLevel;
+  tags?: string[];
+  id?: string;
+}
+
+export function greenLevelToNumber(level: GreenLevel): number {
+  return level;
+}
+
+export function greenLevelToLabel(level: GreenLevel): string {
+  switch (level) {
+    case GreenLevel.CRITICAL: return "CRITICAL";
+    case GreenLevel.HIGH: return "HIGH";
+    case GreenLevel.MEDIUM: return "MEDIUM";
+    case GreenLevel.LOW: return "LOW";
+    case GreenLevel.INFO: return "INFO";
+  }
+}
+
+export function isCriticalLevel(level: GreenLevel): boolean {
+  return level === GreenLevel.CRITICAL;
+}
+
+export function isBlockingLevel(level: GreenLevel): boolean {
+  return level === GreenLevel.CRITICAL || level === GreenLevel.HIGH;
+}
