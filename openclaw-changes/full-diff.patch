+++ b/src/tasks/task-state-machine.ts
@@ -0,0 +1,237 @@
+/**
+ * Task State Machine
+ *
+ * Defines and validates state transitions for tasks.
+ *
+ * State Diagram:
+ *
+ *     ┌─────────┐
+ *     │ queued  │◄────────────────┐
+ *     └────┬────┘                 │
+ *          │ start                │
+ *          ▼                      │
+ *     ┌─────────┐                  │
+ *     │ running │──────────────────┤
+ *     └────┬────┘                  │
+ *          │                       │
+ *    ┌─────┴─────┐                  │
+ *    │           │                  │
+ *    ▼           ▼                  │
+ * ┌────────┐ ┌────────┐            │
+ * │succeeded│ │failed  │            │
+ * └────────┘ └────────┘            │
+ *    ▲           ▲                  │
+ *    │           │                  │
+ *    └─────┬─────┘                  │
+ *          │                       │
+ *    ┌─────┴─────┐                  │
+ *    │           │                  │
+ *    ▼           ▼                  │
+ * ┌─────────┐ ┌────────┐  lost ◄───┤
+ * │timed_out│ │cancelled│          │
+ * └─────────┘ └────────┘            │
+ *                                    │
+ * (lost is an exceptional state      │
+ *  when backing session disappears) │
+ */
+
+import type { TaskRecord, TaskStatus, TaskTerminalOutcome } from "./task-registry.types.js";
+import { isTerminalTaskStatus } from "./task-executor-policy.js";
+
+/**
+ * Active (non-terminal) task statuses.
+ */
+export const ACTIVE_TASK_STATUSES: readonly TaskStatus[] = ["queued", "running"];
+
+/**
+ * Terminal task statuses - once reached, task cannot transition to other states.
+ */
+export const TERMINAL_TASK_STATUSES: readonly TaskStatus[] = [
+  "succeeded",
+  "failed",
+  "timed_out",
+  "cancelled",
+  "lost",
+];
+
+/**
+ * All valid task statuses.
+ */
+export const ALL_TASK_STATUSES: readonly TaskStatus[] = [
+  "queued",
+  "running",
+  "succeeded",
+  "failed",
+  "timed_out",
+  "cancelled",
+  "lost",
+];
+
+/**
+ * Check if a status is an active (non-terminal) status.
+ */
+export function isActiveStatus(status: TaskStatus): boolean {
+  return status === "queued" || status === "running";
+}
+
+/**
+ * Check if a status is a terminal status.
+ * Alias for isTerminalTaskStatus for consistency.
+ */
+export function isTerminalStatus(status: TaskStatus): boolean {
+  return isTerminalTaskStatus(status);
+}
+
+/**
+ * Check if a task is in an active (non-terminal) state.
+ */
+export function isActiveTask(task: TaskRecord): boolean {
+  return isActiveStatus(task.status);
+}
+
+/**
+ * Check if a task has reached a terminal state.
+ */
+export function isTerminalTask(task: TaskRecord): boolean {
+  return isTerminalStatus(task.status);
+}
+
+/**
+ * Check if a task ended in failure (failed, timed_out, or lost).
+ */
+export function isFailedTask(task: TaskRecord): boolean {
+  return task.status === "failed" || task.status === "timed_out" || task.status === "lost";
+}
+
+/**
+ * Check if a task ended in success (succeeded).
+ */
+export function isSucceededTask(task: TaskRecord): boolean {
+  return task.status === "succeeded";
+}
+
+/**
+ * Get the terminal outcome for a task, if it has one.
+ * Returns undefined if task is not in a terminal state.
+ */
+export function getTerminalOutcome(task: TaskRecord): TaskTerminalOutcome | undefined {
+  if (!isTerminalStatus(task.status)) {
+    return undefined;
+  }
+  return task.terminalOutcome;
+}
+
+/**
+ * Check if a status transition is valid.
+ * Returns true if the transition is allowed, false otherwise.
+ *
+ * Valid transitions:
+ * - queued -> running
+ * - running -> succeeded
+ * - running -> failed
+ * - running -> timed_out
+ * - running -> cancelled
+ * - any active state -> lost (exceptional)
+ */
+export function isValidStatusTransition(
+  fromStatus: TaskStatus,
+  toStatus: TaskStatus,
+): boolean {
+  // Same status is always valid (no-op)
+  if (fromStatus === toStatus) {
+    return true;
+  }
+
+  // Terminal states cannot transition
+  if (isTerminalStatus(fromStatus)) {
+    return false;
+  }
+
+  // From queued, only running is valid
+  if (fromStatus === "queued") {
+    return toStatus === "running";
+  }
+
+  // From running, any terminal state is valid
+  if (fromStatus === "running") {
+    return (
+      toStatus === "succeeded" ||
+      toStatus === "failed" ||
+      toStatus === "timed_out" ||
+      toStatus === "cancelled"
+    );
+  }
+
+  // Active states (shouldn't reach here, but defensive)
+  if (isActiveStatus(fromStatus)) {
+    return toStatus === "running" || isTerminalStatus(toStatus);
+  }
+
+  return false;
+}
+
+/**
+ * Resolve the terminal outcome based on status and provided outcome.
+ *
+ * Logic:
+ * - If status is "succeeded", outcome defaults to "succeeded"
+ * - If status is not "succeeded", outcome is undefined unless explicitly set
+ * - If explicitly provided outcome is "blocked", it is preserved
+ */
+export function resolveTerminalOutcome(
+  status: TaskStatus,
+  explicitOutcome?: TaskTerminalOutcome | null,
+): TaskTerminalOutcome | undefined {
+  if (explicitOutcome === "succeeded" || explicitOutcome === "blocked") {
+    return explicitOutcome;
+  }
+  if (status === "succeeded") {
+    return "succeeded";
+  }
+  return undefined;
+}
+
+/**
+ * Get a human-readable description of a task's current state.
+ */
+export function describeTaskState(task: Pick<TaskRecord, "status" | "terminalOutcome">): string {
+  switch (task.status) {
+    case "queued":
+      return "Queued";
+    case "running":
+      return "Running";
+    case "succeeded":
+      if (task.terminalOutcome === "blocked") {
+        return "Blocked";
+      }
+      return "Succeeded";
+    case "failed":
+      return "Failed";
+    case "timed_out":
+      return "Timed Out";
+    case "cancelled":
+      return "Cancelled";
+    case "lost":
+      return "Lost";
+    default:
+      return "Unknown";
+  }
+}
+
+/**
+ * Get the appropriate error/success indicator for a terminal task.
+ */
+export function getTaskExitIndicator(task: TaskRecord): "success" | "failure" | "neutral" {
+  switch (task.status) {
+    case "succeeded":
+      return task.terminalOutcome === "blocked" ? "neutral" : "success";
+    case "failed":
+    case "timed_out":
+    case "lost":
+      return "failure";
+    case "cancelled":
+      return "neutral";
+    default:
+      return "neutral";
+  }
+}
