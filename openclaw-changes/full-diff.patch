@@ -0,0 +1,263 @@
+/**
+ * Memory Store Implementation
+ * ==========================
+ *
+ * In-memory store for memory entries with four-type classification,
+ * frontmatter support, and priority-based retrieval for context assembly.
+ */
+
+import type {
+  MemoryEntry,
+  MemoryPriority,
+  MemoryStore,
+  MemoryType,
+} from "./types.js";
+import {
+  TYPE_ASSEMBLY_ORDER,
+  PRIORITY_ORDER,
+  estimateMemoryTokens,
+} from "./types.js";
+import { parseMemoryRaw, serializeMemoryEntry, touchMemoryEntry } from "./frontmatter.js";
+import { randomUUID } from "crypto";
+
+/** In-memory implementation of MemoryStore */
+export class InMemoryMemoryStore implements MemoryStore {
+  private entries: Map<string, MemoryEntry> = new Map();
+  private indexByType: Map<MemoryType, Set<string>> = new Map();
+  private indexByTag: Map<string, Set<string>> = new Map();
+
+  constructor(initialEntries?: MemoryEntry[]) {
+    // Initialize type indices
+    for (const type of ["user", "feedback", "project", "reference"] as MemoryType[]) {
+      this.indexByType.set(type, new Set());
+    }
+
+    // Load initial entries if provided
+    if (initialEntries) {
+      for (const entry of initialEntries) {
+        this.addEntry(entry);
+      }
+    }
+  }
+
+  /** Internal method to add an already-constructed entry */
+  private addEntry(entry: MemoryEntry): void {
+    this.entries.set(entry.id, entry);
+    this.indexByType.get(entry.type)?.add(entry.id);
+    for (const tag of entry.tags) {
+      if (!this.indexByTag.has(tag)) {
+        this.indexByTag.set(tag, new Set());
+      }
+      this.indexByTag.get(tag)!.add(entry.id);
+    }
+  }
+
+  getByType(type: MemoryType): MemoryEntry[] {
+    const ids = this.indexByType.get(type) ?? new Set();
+    return Array.from(ids)
+      .map((id) => this.entries.get(id)!)
+      .filter(Boolean)
+      .filter((e) => !this.isExpired(e));
+  }
+
+  getById(id: string): MemoryEntry | undefined {
+    const entry = this.entries.get(id);
+    if (!entry) {return undefined;}
+    return this.isExpired(entry) ? undefined : entry;
+  }
+
+  queryByTags(tags: string[], matchAll = false): MemoryEntry[] {
+    if (tags.length === 0) {return this.getAll();}
+
+    const matchingIds = matchAll
+      ? this.intersectTagResults(tags)
+      : this.unionTagResults(tags);
+
+    return Array.from(matchingIds)
+      .map((id) => this.entries.get(id)!)
+      .filter(Boolean)
+      .filter((e) => !this.isExpired(e));
+  }
+
+  add(
+    entryData: Omit<MemoryEntry, "id" | "created" | "updated">
+  ): MemoryEntry {
+    const now = new Date().toISOString();
+    const entry: MemoryEntry = {
+      ...entryData,
+      id: randomUUID(),
+      created: now,
+      updated: now,
+    };
+    this.addEntry(entry);
+    return entry;
+  }
+
+  update(
+    id: string,
+    updates: Partial<Omit<MemoryEntry, "id" | "created">>
+  ): boolean {
+    const existing = this.entries.get(id);
+    if (!existing) {return false;}
+
+    // Remove from old type index if type changed
+    if (updates.type && updates.type !== existing.type) {
+      this.indexByType.get(existing.type)?.delete(id);
+      this.indexByType.get(updates.type)?.add(id);
+    }
+
+    // Remove from old tag indices if tags changed
+    if (updates.tags) {
+      for (const tag of existing.tags) {
+        this.indexByTag.get(tag)?.delete(id);
+      }
+      for (const tag of updates.tags) {
+        if (!this.indexByTag.has(tag)) {
+          this.indexByTag.set(tag, new Set());
+        }
+        this.indexByTag.get(tag)!.add(id);
+      }
+    }
+
+    const updated = touchMemoryEntry({
+      ...existing,
+      ...updates,
+    });
+    this.entries.set(id, updated);
+    return true;
+  }
+
+  remove(id: string): boolean {
+    const entry = this.entries.get(id);
+    if (!entry) {return false;}
+
+    // Clean up indices
+    this.indexByType.get(entry.type)?.delete(id);
+    for (const tag of entry.tags) {
+      this.indexByTag.get(tag)?.delete(id);
+    }
+
+    this.entries.delete(id);
+    return true;
+  }
+
+  getAll(): MemoryEntry[] {
+    return Array.from(this.entries.values()).filter((e) => !this.isExpired(e));
+  }
+
+  getByPriority(min: MemoryPriority, max: MemoryPriority): MemoryEntry[] {
+    const minOrder = PRIORITY_ORDER[min];
+    const maxOrder = PRIORITY_ORDER[max];
+    return this.getAll().filter((e) => {
+      const order = PRIORITY_ORDER[e.priority];
+      return order >= minOrder && order <= maxOrder;
+    });
+  }
+
+  getSortedForAssembly(tokenBudget: number): MemoryEntry[] {
+    // Sort by type order first (user > project > feedback > reference)
+    // Then by priority within each type (high > medium > low)
+    // Then by updated timestamp (newer first)
+    const sorted = this.getAll().toSorted((a, b) => {
+      const typeDiff = TYPE_ASSEMBLY_ORDER[a.type] - TYPE_ASSEMBLY_ORDER[b.type];
+      if (typeDiff !== 0) {return typeDiff;}
+
+      const priorityDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];
+      if (priorityDiff !== 0) {return priorityDiff;}
+
+      // Newer entries first
+      return new Date(b.updated).getTime() - new Date(a.updated).getTime();
+    });
+
+    // Filter by token budget
+    let usedTokens = 0;
+    const result: MemoryEntry[] = [];
+
+    for (const entry of sorted) {
+      const entryTokens = estimateMemoryTokens(entry);
+      if (usedTokens + entryTokens > tokenBudget) {
+        continue;
+      }
+      usedTokens += entryTokens;
+      result.push(entry);
+    }
+
+    return result;
+  }
+
+  invalidateByScope(scope: "session" | "project", id: string): number {
+    let count = 0;
+    for (const [entryId, entry] of this.entries) {
+      if (scope === "session" && entry.sessionId === id) {
+        this.remove(entryId);
+        count++;
+      } else if (scope === "project" && entry.projectId === id) {
+        this.remove(entryId);
+        count++;
+      }
+    }
+    return count;
+  }
+
+  /** Load entries from raw strings (with frontmatter) */
+  loadFromRaw(rawEntries: string[]): number {
+    let loaded = 0;
+    for (const raw of rawEntries) {
+      const parsed = parseMemoryRaw(raw);
+      if (parsed) {
+        const entry: MemoryEntry = {
+          id: randomUUID(),
+          type: parsed.frontmatter.type,
+          created: parsed.frontmatter.created,
+          updated: parsed.frontmatter.updated,
+          tags: parsed.frontmatter.tags,
+          priority: parsed.frontmatter.priority,
+          sessionId: parsed.frontmatter.sessionId,
+          projectId: parsed.frontmatter.projectId,
+          content: parsed.content,
+          expiresAt: parsed.frontmatter.expiresAt ?? null,
+          source: parsed.frontmatter.source,
+        };
+        this.addEntry(entry);
+        loaded++;
+      }
+    }
+    return loaded;
+  }
+
+  /** Export all entries as raw strings */
+  exportToRaw(): string[] {
+    return Array.from(this.entries.values()).map(serializeMemoryEntry);
+  }
+
+  private isExpired(entry: MemoryEntry): boolean {
+    if (!entry.expiresAt) {return false;}
+    return new Date(entry.expiresAt).getTime() < Date.now();
+  }
+
+  private intersectTagResults(tags: string[]): Set<string> {
+    if (tags.length === 0) {return new Set();}
+    const [first, ...rest] = tags;
+    const result = new Set(this.indexByTag.get(first ?? "") ?? []);
+    for (const tag of rest) {
+      const tagIds = this.indexByTag.get(tag) ?? new Set();
+      for (const id of result) {
+        if (!tagIds.has(id)) {
+          result.delete(id);
+        }
+      }
+    }
+    return result;
+  }
+
+  private unionTagResults(tags: string[]): Set<string> {
+    const result = new Set<string>();
+    for (const tag of tags) {
+      const tagIds = this.indexByTag.get(tag) ?? new Set();
+      for (const id of tagIds) {
+        result.add(id);
+      }
+    }
+    return result;
+  }
+}
diff --git a/src/context-engine/memory/types.ts b/src/context-engine/memory/types.ts
new file mode 100644
index 0000000000..8c4658f89d
--- /dev/null
+++ b/src/context-engine/memory/types.ts
@@ -0,0 +1,145 @@
+/**
+ * Memory Types and Frontmatter Definitions
+ * ========================================
+ *
+ * Implements four-type memory classification with YAML frontmatter support:
+ * - user: User-specific context and preferences
+ * - feedback: Conversation feedback and corrections
+ * - project: Project-specific context
+ * - reference: Reference materials and documentation
+ */
+
+import { randomUUID } from "crypto";
+
+/** Memory type enumeration */
+export type MemoryType = "user" | "feedback" | "project" | "reference";
+
+/** Memory priority levels */
+export type MemoryPriority = "high" | "medium" | "low";
+
+/** Memory entry interface with frontmatter */
+export interface MemoryEntry {
+  /** Unique identifier */
+  id: string;
+  /** Memory type classification */
+  type: MemoryType;
+  /** ISO8601 creation timestamp */
+  created: string;
+  /** ISO8601 last updated timestamp */
+  updated: string;
+  /** Semantic tags for retrieval */
+  tags: string[];
+  /** Priority level for assembly ordering */
+  priority: MemoryPriority;
+  /** Optional session ID (for feedback type) */
+  sessionId?: string;
+  /** Optional project ID (for project type) */
+  projectId?: string;
+  /** Content body (after frontmatter) */
+  content: string;
+  /** Embedding vector (optional, for semantic search) */
+  embedding?: number[];
+  /** Expiry timestamp (null = never expires) */
+  expiresAt: string | null;
+  /** Source location for reference type */
+  source?: string;
+}
+
+/** Frontmatter-only metadata (without content) */
+export interface MemoryFrontmatter {
+  type: MemoryType;
+  created: string;
+  updated: string;
+  tags: string[];
+  priority: MemoryPriority;
+  sessionId?: string;
+  projectId?: string;
+  expiresAt?: string | null;
+  source?: string;
+}
+
+/** Parsed memory entry from raw text */
+export interface ParsedMemory {
+  frontmatter: MemoryFrontmatter;
+  content: string;
+  raw: string;
+}
+
+/** Memory store interface */
+export interface MemoryStore {
+  /** Get all entries of a specific type */
+  getByType(type: MemoryType): MemoryEntry[];
+  /** Get entry by ID */
+  getById(id: string): MemoryEntry | undefined;
+  /** Query entries by tags */
+  queryByTags(tags: string[], matchAll?: boolean): MemoryEntry[];
+  /** Add a new entry */
+  add(entry: Omit<MemoryEntry, "id" | "created" | "updated">): MemoryEntry;
+  /** Update an existing entry */
+  update(id: string, updates: Partial<Omit<MemoryEntry, "id" | "created">>): boolean;
+  /** Remove an entry */
+  remove(id: string): boolean;
+  /** Get all entries, optionally filtered */
+  getAll(): MemoryEntry[];
+  /** Get entries within a priority range */
+  getByPriority(min: MemoryPriority, max: MemoryPriority): MemoryEntry[];
+  /** Get entries sorted by priority for context assembly */
+  getSortedForAssembly(tokenBudget: number): MemoryEntry[];
+  /** Invalidate entries by session or project */
+  invalidateByScope(scope: "session" | "project", id: string): number;
+}
+
+/** Default frontmatter values by type */
+export const DEFAULT_MEMORY_PRIORITY: Record<MemoryType, MemoryPriority> = {
+  user: "high",
+  feedback: "medium",
+  project: "medium",
+  reference: "low",
+};
+
+/** Priority ordering for assembly (lower number = higher priority) */
+export const PRIORITY_ORDER: Record<MemoryPriority, number> = {
+  high: 0,
+  medium: 1,
+  low: 2,
+};
+
+/** Memory type ordering for assembly */
+export const TYPE_ASSEMBLY_ORDER: Record<MemoryType, number> = {
+  user: 0,
+  project: 1,
+  feedback: 2,
+  reference: 3,
+};
+
+/** Create a new memory entry with generated ID and timestamps */
+export function createMemoryEntry(
+  type: MemoryType,
+  content: string,
+  options?: Partial<Omit<MemoryEntry, "id" | "type" | "content" | "created" | "updated">>
+): MemoryEntry {
+  const now = new Date().toISOString();
+  return {
+    id: randomUUID(),
+    type,
+    created: now,
+    updated: now,
+    tags: options?.tags ?? [],
+    priority: options?.priority ?? DEFAULT_MEMORY_PRIORITY[type],
+    sessionId: options?.sessionId,
+    projectId: options?.projectId,
+    content,
+    embedding: options?.embedding,
+    expiresAt: options?.expiresAt ?? null,
+    source: options?.source,
+  };
+}
+
+/** Estimate token count for a memory entry (rough approximation) */
+export function estimateMemoryTokens(entry: MemoryEntry): number {
+  // Rough estimation: ~4 characters per token
+  const frontmatterLength = JSON.stringify(entry).length - entry.content.length;
+  const frontmatterTokens = Math.ceil(frontmatterLength / 4);
+  const contentTokens = Math.ceil(entry.content.length / 4);
+  return frontmatterTokens + contentTokens;
+}
