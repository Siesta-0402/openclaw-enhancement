@@ -0,0 +1,60 @@
+/**
+ * Memory Module
+ * =============
+ *
+ * Four-type memory classification system with frontmatter support.
+ *
+ * Types:
+ * - user: User-specific context and preferences (highest priority)
+ * - feedback: Conversation feedback and corrections
+ * - project: Project-specific context
+ * - reference: Reference materials and documentation
+ *
+ * Usage:
+ * ```ts
+ * import { createMemoryStore, createMemoryEntry, parseMemoryRaw, serializeMemoryEntry } from './memory';
+ *
+ * // Create a memory store
+ * const store = createMemoryStore();
+ *
+ * // Add entries with frontmatter
+ * store.add({
+ *   type: 'user',
+ *   content: 'User prefers concise responses.',
+ *   tags: ['preferences', 'communication'],
+ *   priority: 'high',
+ * });
+ *
+ * // Get entries for context assembly within token budget
+ * const relevant = store.getSortedForAssembly(5000);
+ * ```
+ */
+
+export {
+  type MemoryEntry,
+  type MemoryFrontmatter,
+  type MemoryPriority,
+  type MemoryStore,
+  type MemoryType,
+  type ParsedMemory,
+  createMemoryEntry,
+  DEFAULT_MEMORY_PRIORITY,
+  estimateMemoryTokens,
+  PRIORITY_ORDER,
+  TYPE_ASSEMBLY_ORDER,
+} from "./types.js";
+
+export {
+  parseMemoryRaw,
+  parseFrontmatter,
+  serializeMemoryEntry,
+  serializeFrontmatter,
+  touchMemoryEntry,
+} from "./frontmatter.js";
+
+export { InMemoryMemoryStore } from "./store.js";
+
+/** Create a new in-memory store with optional initial entries */
+export function createMemoryStore(entries?: MemoryEntry[]): MemoryStore {
+  return new InMemoryMemoryStore(entries);
+}
