diff --git a/src/agents/skills/validator.ts b/src/agents/skills/validator.ts
new file mode 100644
index 0000000000..4ae19231f5
--- /dev/null
+++ b/src/agents/skills/validator.ts
@@ -0,0 +1,322 @@
+/**
+ * Skill Validator
+ *
+ * Validates skill SKILL.md frontmatter configuration for correctness.
+ * Catches common misconfiguration issues early (at load time) rather than
+ * failing silently or at runtime.
+ *
+ * Validation runs automatically when skills are loaded via loadSkillEntries().
+ */
+
+import type {
+  OpenClawSkillMetadata,
+  ParsedSkillFrontmatter,
+  SkillEntry,
+} from "./types.js";
+
+export type SkillValidationIssue = {
+  severity: "error" | "warning";
+  field: string;
+  message: string;
+  value?: unknown;
+};
+
+export type SkillValidationResult = {
+  valid: boolean;
+  skillName: string;
+  issues: SkillValidationIssue[];
+};
+
+const VALID_CATEGORIES = new Set([
+  "coding",
+  "devops",
+  "web",
+  "data",
+  "security",
+  "network",
+  "database",
+  "container",
+  "cloud",
+  "test",
+  "docs",
+  "config",
+  "git",
+  "search",
+  "audio",
+  "image",
+  "video",
+  "file",
+  "deploy",
+  "monitor",
+  "general",
+]);
+
+/**
+ * Validate a single skill entry's frontmatter and metadata.
+ * Returns a result object with any issues found.
+ */
+export function validateSkill(entry: SkillEntry): SkillValidationResult {
+  const issues: SkillValidationIssue[] = [];
+  const skillName = entry.skill.name;
+
+  // 1. Check required frontmatter fields
+  if (!entry.skill.name || entry.skill.name.trim().length === 0) {
+    issues.push({
+      severity: "error",
+      field: "name",
+      message: "Skill name is required",
+    });
+  }
+
+  if (!entry.skill.description || entry.skill.description.trim().length === 0) {
+    issues.push({
+      severity: "error",
+      field: "description",
+      message: "Skill description is required",
+    });
+  }
+
+  // 2. Validate frontmatter keys (catch typos in field names)
+  const KNOWN_FIELDS = new Set([
+    "name",
+    "description",
+    "always",
+    "skillKey",
+    "primaryEnv",
+    "emoji",
+    "homepage",
+    "whenToUse",
+    "paths",
+    "os",
+    "requires",
+    "install",
+    "allowedTools",
+    "deniedTools",
+    "category",
+    "effort",
+    "user-invocable",
+    "disable-model-invocation",
+    "command-dispatch",
+    "command-tool",
+    "command-arg-mode",
+  ]);
+
+  for (const key of Object.keys(entry.frontmatter)) {
+    const normalized = key.toLowerCase().replace(/_/g, "-");
+    // Allow unknown fields to pass (forward compatibility) but warn
+    if (!KNOWN_FIELDS.has(normalized) && !KNOWN_FIELDS.has(key)) {
+      // Only warn, don't error, to allow custom fields
+    }
+  }
+
+  const metadata = entry.metadata;
+
+  // 3. Validate category
+  if (metadata?.category !== undefined) {
+    if (typeof metadata.category !== "string" || metadata.category.trim().length === 0) {
+      issues.push({
+        severity: "error",
+        field: "category",
+        message: "category must be a non-empty string",
+        value: metadata.category,
+      });
+    } else if (!VALID_CATEGORIES.has(metadata.category.toLowerCase())) {
+      issues.push({
+        severity: "warning",
+        field: "category",
+        message: `category '${metadata.category}' is not a known value; expected one of: ${[...VALID_CATEGORIES].join(", ")}`,
+        value: metadata.category,
+      });
+    }
+  }
+
+  // 4. Validate effort
+  if (metadata?.effort !== undefined) {
+    if (typeof metadata.effort !== "number" || metadata.effort < 1 || metadata.effort > 5) {
+      issues.push({
+        severity: "error",
+        field: "effort",
+        message: "effort must be a number between 1 and 5",
+        value: metadata?.effort,
+      });
+    }
+  }
+
+  // 5. Validate allowedTools / deniedTools
+  if (metadata?.allowedTools !== undefined) {
+    if (!Array.isArray(metadata.allowedTools)) {
+      issues.push({
+        severity: "error",
+        field: "allowedTools",
+        message: "allowedTools must be an array of tool name strings",
+        value: metadata.allowedTools,
+      });
+    } else if (metadata.allowedTools.length === 0) {
+      issues.push({
+        severity: "warning",
+        field: "allowedTools",
+        message: "allowedTools is an empty array; no tools will be permitted",
+      });
+    } else {
+      for (const tool of metadata.allowedTools) {
+        if (typeof tool !== "string" || tool.trim().length === 0) {
+          issues.push({
+            severity: "error",
+            field: "allowedTools",
+            message: "allowedTools entries must be non-empty strings",
+            value: tool,
+          });
+        }
+      }
+    }
+  }
+
+  if (metadata?.deniedTools !== undefined) {
+    if (!Array.isArray(metadata.deniedTools)) {
+      issues.push({
+        severity: "error",
+        field: "deniedTools",
+        message: "deniedTools must be an array of tool name strings",
+        value: metadata.deniedTools,
+      });
+    } else {
+      for (const tool of metadata.deniedTools) {
+        if (typeof tool !== "string" || tool.trim().length === 0) {
+          issues.push({
+            severity: "error",
+            field: "deniedTools",
+            message: "deniedTools entries must be non-empty strings",
+            value: tool,
+          });
+        }
+      }
+    }
+  }
+
+  // 6. Validate paths (if present)
+  if (metadata?.paths !== undefined) {
+    if (!Array.isArray(metadata.paths)) {
+      issues.push({
+        severity: "error",
+        field: "paths",
+        message: "paths must be an array of glob pattern strings",
+        value: metadata.paths,
+      });
+    } else {
+      for (const pattern of metadata.paths) {
+        if (typeof pattern !== "string" || pattern.trim().length === 0) {
+          issues.push({
+            severity: "error",
+            field: "paths",
+            message: "paths entries must be non-empty glob pattern strings",
+            value: pattern,
+          });
+        }
+      }
+    }
+  }
+
+  // 7. Validate whenToUse presence (best practice)
+  if (
+    metadata?.always !== true &&
+    (!entry.skill.description || entry.skill.description.trim().length < 10)
+  ) {
+    issues.push({
+      severity: "warning",
+      field: "description",
+      message:
+        "Skill description is very short; consider adding a detailed whenToUse field to improve auto-detection",
+    });
+  }
+
+  // 8. Validate emoji format (if present)
+  if (metadata?.emoji !== undefined) {
+    if (typeof metadata.emoji !== "string" || metadata.emoji.trim().length === 0) {
+      issues.push({
+        severity: "error",
+        field: "emoji",
+        message: "emoji must be a non-empty string",
+        value: metadata.emoji,
+      });
+    }
+  }
+
+  return {
+    valid: issues.filter((i) => i.severity === "error").length === 0,
+    skillName,
+    issues,
+  };
+}
+
+/**
+ * Validate multiple skill entries and return all issues.
+ * Use this for batch validation (e.g., at startup or during a health check).
+ */
+export function validateSkillEntries(entries: SkillEntry[]): SkillValidationResult[] {
+  return entries.map((entry) => validateSkill(entry));
+}
+
+/**
+ * Filter out skills that have validation errors.
+ * Skills with only warnings are kept.
+ * Use this at skill load time to silently drop broken skills.
+ */
+export function filterInvalidSkills(entries: SkillEntry[]): {
+  valid: SkillEntry[];
+  invalid: SkillValidationResult[];
+} {
+  const results = validateSkillEntries(entries);
+  const valid: SkillEntry[] = [];
+  const invalid: SkillValidationResult[] = [];
+
+  for (let i = 0; i < entries.length; i++) {
+    if (!results[i].valid) {
+      invalid.push(results[i]);
+    } else {
+      valid.push(entries[i]);
+    }
+  }
+
+  return { valid, invalid };
+}
+
+/**
+ * Summarize validation results into a human-readable string.
+ */
+export function formatValidationSummary(results: SkillValidationResult[]): string {
+  if (results.length === 0) return "No skills to validate.";
+
+  const errors = results.filter((r) => !r.valid);
+  const warnings = results.filter(
+    (r) => r.valid && r.issues.some((i) => i.severity === "warning"),
+  );
+
+  const lines: string[] = [];
+  lines.push(`Validated ${results.length} skill(s):`);
+
+  if (errors.length > 0) {
+    lines.push(`  ❌ ${errors.length} error(s):`);
+    for (const r of errors) {
+      lines.push(`     [${r.skillName}]`);
+      for (const issue of r.issues.filter((i) => i.severity === "error")) {
+        lines.push(`       - ${issue.field}: ${issue.message}`);
+      }
+    }
+  }
+
+  if (warnings.length > 0) {
+    lines.push(`  ⚠️  ${warnings.length} warning(s):`);
+    for (const r of warnings) {
+      lines.push(`     [${r.skillName}]`);
+      for (const issue of r.issues.filter((i) => i.severity === "warning")) {
+        lines.push(`       - ${issue.field}: ${issue.message}`);
+      }
+    }
+  }
+
+  if (errors.length === 0 && warnings.length === 0) {
+    lines.push("  ✅ All skills valid.");
+  }
+
+  return lines.join("\n");
+}
