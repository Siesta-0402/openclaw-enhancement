+/**
+ * Token Budget Management
+ * =======================
+ *
+ * Utilities for managing token budgets during context assembly
+ * and compaction decisions.
+ */
+
+/** Default context window sizes by model family */
+export const DEFAULT_CONTEXT_WINDOWS: Record<string, number> = {
+  "claude-opus-4": 200000,
+  "claude-sonnet-4": 200000,
+  "claude-3-5": 200000,
+  "claude-3": 200000,
+  "gpt-4o": 128000,
+  "gpt-4-turbo": 128000,
+  "gpt-4": 128000,
+  "gpt-3.5-turbo": 16385,
+  "default": 100000,
+};
+
+/** Default token limits */
+export const DEFAULT_TOKEN_LIMITS = {
+  /** Reserve this many tokens for output during compaction */
+  OUTPUT_RESERVE: 20000,
+  /** Buffer tokens below auto-compact threshold */
+  AUTOCOMPACT_BUFFER: 13000,
+  /** Buffer tokens for warning threshold */
+  WARNING_BUFFER: 20000,
+  /** Buffer tokens for manual compaction */
+  MANUAL_COMPACT_BUFFER: 3000,
+  /** Max tokens per tool result */
+  MAX_TOOL_RESULT_TOKENS: 2000,
+  /** Max tokens for recent message preservation */
+  RECENT_MESSAGES_TOKENS: 5000,
+  /** Max tokens for system prompt */
+  SYSTEM_PROMPT_TOKENS: 10000,
+};
+
+/**
+ * Get the effective context window size for a model,
+ * minus reserved output tokens.
+ */
+export function getEffectiveContextWindow(
+  model: string,
+  options?: { outputReserve?: number }
+): number {
+  const outputReserve = options?.outputReserve ?? DEFAULT_TOKEN_LIMITS.OUTPUT_RESERVE;
+  const contextWindow = getContextWindow(model);
+  return contextWindow - outputReserve;
+}
+
+/**
+ * Get the context window size for a model.
+ */
+export function getContextWindow(model: string): number {
+  const lowerModel = model.toLowerCase();
+
+  for (const [key, size] of Object.entries(DEFAULT_CONTEXT_WINDOWS)) {
+    if (lowerModel.includes(key.toLowerCase())) {
+      return size;
+    }
+  }
+
+  return DEFAULT_CONTEXT_WINDOWS.default;
+}
+
+/**
+ * Get the auto-compact threshold for a model.
+ * This is the token count at which auto-compaction should trigger.
+ */
+export function getAutoCompactThreshold(model: string): number {
+  const effectiveWindow = getEffectiveContextWindow(model);
+  return effectiveWindow - DEFAULT_TOKEN_LIMITS.AUTOCOMPACT_BUFFER;
+}
+
+/**
+ * Get the warning threshold for a model.
+ * Below auto-compact but above this shows a warning.
+ */
+export function getWarningThreshold(model: string): number {
+  const autoCompactThreshold = getAutoCompactThreshold(model);
+  return autoCompactThreshold - DEFAULT_TOKEN_LIMITS.WARNING_BUFFER;
+}
+
+/**
+ * Get the blocking limit for a model.
+ * Above this, new prompts are rejected.
+ */
+export function getBlockingLimit(model: string): number {
+  const effectiveWindow = getEffectiveContextWindow(model);
+  return effectiveWindow - DEFAULT_TOKEN_LIMITS.MANUAL_COMPACT_BUFFER;
+}
+
+/**
+ * Calculate how many tokens are available for context assembly
+ * given a total budget.
+ */
+export function calculateAvailableForContext(
+  totalBudget: number,
+  systemPromptTokens: number
+): number {
+  return Math.max(0, totalBudget - systemPromptTokens);
+}
+
+/**
+ * Token budget allocation for context assembly.
+ * Distributes budget across different context components.
+ */
+export interface BudgetAllocation {
+  systemPrompt: number;
+  memory: number;
+  recentMessages: number;
+  historicalMessages: number;
+}
+
+/**
+ * Allocate token budget across context components.
+ * Priority order: system > memory > recent > historical
+ */
+export function allocateBudget(
+  totalBudget: number,
+  options?: {
+    systemPrompt?: number;
+    memoryPriority?: number;
+    recentMessagesPriority?: number;
+  }
+): BudgetAllocation {
+  const systemPrompt =
+    options?.systemPrompt ?? DEFAULT_TOKEN_LIMITS.SYSTEM_PROMPT_TOKENS;
+  const memoryPriority = options?.memoryPriority ?? 0.3; // 30% of remaining
+  const recentPriority = options?.recentMessagesPriority ?? 0.5; // 50% of remaining
+
+  const remainingAfterSystem = Math.max(0, totalBudget - systemPrompt);
+  const memoryBudget = Math.floor(remainingAfterSystem * memoryPriority);
+  const remainingAfterMemory = remainingAfterSystem - memoryBudget;
+  const recentBudget = Math.floor(remainingAfterMemory * recentPriority);
+  const historicalBudget = remainingAfterMemory - recentBudget;
+
+  return {
+    systemPrompt,
+    memory: memoryBudget,
+    recentMessages: recentBudget,
+    historicalMessages: Math.max(0, historicalBudget),
+  };
+}
+
+/**
+ * Calculate what percentage of the context window is in use.
+ */
+export function calculateUsagePercent(
+  tokenCount: number,
+  model: string
+): number {
+  const effectiveWindow = getEffectiveContextWindow(model);
+  return Math.round((tokenCount / effectiveWindow) * 100);
+}
+
+/**
+ * Check if compaction is recommended based on token usage.
+ */
+export function shouldCompactionTrigger(
+  tokenCount: number,
+  model: string,
+  options?: {
+    force?: boolean;
+    thresholdOverride?: number;
+  }
+): boolean {
+  if (options?.force) {return true;}
+
+  const threshold = options?.thresholdOverride ?? getAutoCompactThreshold(model);
+  return tokenCount >= threshold;
+}
