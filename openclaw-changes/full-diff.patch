+/**
+ * AutoCompact (L4)
+ * =================
+ *
+ * Reactive compaction that fully summarizes conversation history
+ * when context pressure reaches critical levels.
+ *
+ * Trigger: Token count exceeds auto-compact threshold (~87% of window)
+ * Action: Full conversation summary with boundary marker
+ * Tokens saved: ~80-90% of original context
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+import { logger } from "@mariozechner/pi-agent-core/logger";
+
+/** Configuration for AutoCompact */
+export interface AutoCompactConfig {
+  /** Token threshold for auto-compact trigger */
+  thresholdPercent: number;
+  /** Buffer below threshold to prevent immediate re-trigger */
+  bufferTokens: number;
+  /** Max output tokens for summary generation */
+  maxSummaryTokens: number;
+  /** Enable auto-compact */
+  enabled: boolean;
+}
+
+/** Default AutoCompact configuration */
+export const DEFAULT_AUTO_COMPACT_CONFIG: AutoCompactConfig = {
+  thresholdPercent: 87,
+  bufferTokens: 13000,
+  maxSummaryTokens: 20000,
+  enabled: true,
+};
+
+/** System message for auto-compact boundary */
+interface AutoCompactBoundary extends AgentMessage {
+  type: "system";
+  isCompactBoundary: true;
+  isAutoCompactBoundary: true;
+  compactMetadata?: {
+    type: "auto_compact";
+    preCompactTokenCount: number;
+    summaryTokenCount: number;
+    turnsSincePreviousCompact?: number;
+    isRecompaction: boolean;
+  };
+}
+
+/** Result of AutoCompact operation */
+export interface AutoCompactResult {
+  /** Whether compaction was applied */
+  compacted: boolean;
+  /** Messages after compaction */
+  messages: AgentMessage[];
+  /** Summary message(s) */
+  summaryMessages: AgentMessage[];
+  /** Boundary marker */
+  boundaryMessage?: AutoCompactBoundary;
+  /** Tokens before compaction */
+  tokensBefore: number;
+  /** Tokens after compaction */
+  tokensAfter?: number;
+  /** Details */
+  details: {
+    messagesCompressed: number;
+    boundaryType: "auto" | "manual";
+    summaryTokens: number;
+    willRetriggerSoon: boolean;
+  };
+}
+
+import { getCircuitBreaker, withCircuitBreaker } from "./circuitBreaker.js";
+
+/**
+ * L4 AutoCompact: Full conversation summarization.
+ *
+ * This is the last resort compaction tier. It compresses the entire
+ * conversation history into a single summary, preserving only the
+ * boundary marker and recent messages.
+ *
+ * Circuit Breaker Integration:
+ * When the circuit breaker is open, compaction is skipped to prevent
+ * cascading failures from repeated failed compaction attempts.
+ */
+export async function applyAutoCompact(
+  messages: AgentMessage[],
+  tokenCount: number,
+  model: string,
+  config: Partial<AutoCompactConfig> = {},
+  options?: {
+    isManual?: boolean;
+    customInstructions?: string;
+    previousCompactTurnId?: string;
+    turnsSincePreviousCompact?: number;
+    summarizer?: (
+      content: string,
+      instructions?: string
+    ) => Promise<string>;
+  }
+): Promise<AutoCompactResult> {
+  const cfg = { ...DEFAULT_AUTO_COMPACT_CONFIG, ...config };
+
+  // Check circuit breaker - skip compaction if circuit is open
+  const circuitBreaker = getCircuitBreaker();
+  if (circuitBreaker.isOpen()) {
+    logger.info("[AutoCompact] Circuit breaker is open, skipping compaction");
+    return {
+      compacted: false,
+      messages,
+      summaryMessages: [],
+      tokensBefore: tokenCount,
+      details: {
+        messagesCompressed: 0,
+        boundaryType: options?.isManual ? "manual" : "auto",
+        summaryTokens: 0,
+        willRetriggerSoon: false,
+      },
+    };
+  }
+
+  if (!cfg.enabled) {
+    return {
+      compacted: false,
+      messages,
+      summaryMessages: [],
+      tokensBefore: tokenCount,
+      details: {
+        messagesCompressed: 0,
+        boundaryType: options?.isManual ? "manual" : "auto",
+        summaryTokens: 0,
+        willRetriggerSoon: false,
+      },
+    };
+  }
+
+  // Check threshold
+  const threshold = getThreshold(model, cfg.thresholdPercent);
+  const effectiveThreshold = threshold - cfg.bufferTokens;
+
+  if (!options?.isManual && tokenCount < effectiveThreshold) {
+    return {
+      compacted: false,
+      messages,
+      summaryMessages: [],
+      tokensBefore: tokenCount,
+      details: {
+        messagesCompressed: 0,
+        boundaryType: "auto",
+        summaryTokens: 0,
+        willRetriggerSoon: false,
+      },
+    };
+  }
+
+  // Messages to potentially exclude from summary (recent N)
+  // Keep the last 5-10 messages to maintain recent context
+  const recentKeepCount = 10;
+  const recentMessages = messages.slice(-recentKeepCount);
+  const messagesToSummarize = messages.slice(0, -recentKeepCount);
+
+  if (messagesToSummarize.length === 0) {
+    return {
+      compacted: false,
+      messages,
+      summaryMessages: [],
+      tokensBefore: tokenCount,
+      details: {
+        messagesCompressed: 0,
+        boundaryType: options?.isManual ? "manual" : "auto",
+        summaryTokens: 0,
+        willRetriggerSoon: false,
+      },
+    };
+  }
+
+  // Generate summary (wrapped in circuit breaker tracking)
+  try {
+    let summary = "";
+    let summaryTokens = 0;
+
+    if (options?.summarizer) {
+      const content = formatConversationForSummary(messagesToSummarize);
+      const instructions =
+        options.customInstructions ?? getDefaultSummaryInstructions();
+      summary = await options.summarizer(content, instructions);
+      summaryTokens = estimateTokens(summary);
+    } else {
+      summary = generateFallbackCompactSummary(messagesToSummarize);
+      summaryTokens = estimateTokens(summary);
+    }
+
+    // Track success
+    circuitBreaker.trackSuccess();
+
+    // Create boundary marker
+    const boundaryMessage: AutoCompactBoundary = {
+      type: "system",
+      id: `auto-compact-boundary-${Date.now()}`,
+      timestamp: new Date().toISOString(),
+      isMeta: true,
+      isCompactBoundary: true,
+      isAutoCompactBoundary: true,
+      message: {
+        role: "system",
+        content: `[Previous conversation has been summarized. Key points: ${summary.slice(0, 300)}${summary.length > 300 ? "..." : ""}]`,
+      },
+      compactMetadata: {
+        type: "auto_compact",
+        preCompactTokenCount: tokenCount,
+        summaryTokenCount: summaryTokens,
+        turnsSincePreviousCompact: options?.turnsSincePreviousCompact,
+        isRecompaction:
+          options?.turnsSincePreviousCompact !== undefined &&
+          options?.turnsSincePreviousCompact > 0,
+      },
+    };
+
+    // Create summary message
+    const summaryMessage: AgentMessage = {
+      type: "user",
+      id: `compact-summary-${Date.now()}`,
+      timestamp: new Date().toISOString(),
+      isMeta: true,
+      isCompactSummary: true,
+      message: {
+        role: "user",
+        content: `Summary of earlier conversation:\n\n${summary}`,
+      },
+    };
+
+    // Build result: boundary + summary + recent messages
+    const result = [boundaryMessage, summaryMessage, ...recentMessages];
+    const tokensAfter = estimateMessagesTokens(result);
+
+    // Check if this will likely trigger again soon
+    const nextThreshold = getThreshold(model, cfg.thresholdPercent);
+    const willRetriggerSoon = tokensAfter >= nextThreshold;
+
+    return {
+      compacted: true,
+      messages: result,
+      summaryMessages: [summaryMessage],
+      boundaryMessage,
+      tokensBefore: tokenCount,
+      tokensAfter,
+      details: {
+        messagesCompressed: messagesToSummarize.length,
+        boundaryType: options?.isManual ? "manual" : "auto",
+        summaryTokens,
+        willRetriggerSoon,
+      },
+    };
+  } catch (error) {
+    // Track failure for circuit breaker
+    circuitBreaker.trackFailure();
+    logger.warn("[AutoCompact] Compaction failed, circuit breaker updated", error);
+    throw error;
+  }
+}
+
+/**
+ * Check if AutoCompact should trigger.
+ */
+export function shouldAutoCompact(
+  tokenCount: number,
+  model: string,
+  config?: Partial<AutoCompactConfig>
+): boolean {
+  const cfg = { ...DEFAULT_AUTO_COMPACT_CONFIG, ...config };
+  const threshold = getThreshold(model, cfg.thresholdPercent);
+  return tokenCount >= threshold;
+}
+
+/** Get threshold in tokens */
+function getThreshold(model: string, percent: number): number {
+  const effectiveWindow = getEffectiveWindowForModel(model);
+  return Math.floor(effectiveWindow * (percent / 100));
+}
+
+/** Get effective window for model */
+function getEffectiveWindowForModel(model: string): number {
+  const lowerModel = model.toLowerCase();
+  if (lowerModel.includes("claude")) {return 180000;}
+  if (lowerModel.includes("gpt-4")) {return 110000;}
+  if (lowerModel.includes("gpt-3.5")) {return 14000;}
+  return 80000;
+}
+
+/** Format conversation for summary */
+function formatConversationForSummary(messages: AgentMessage[]): string {
+  return messages
+    .map((msg) => {
+      const role = msg.type === "assistant" ? "Assistant" : "User";
+      const content = extractTextContent(msg);
+      const toolUses = extractToolUses(msg);
+      const toolResults = extractToolResults(msg);
+
+      let text = `${role}: ${content}`;
+      if (toolUses.length > 0) {
+        text += `\n[Tools used: ${toolUses.join(", ")}]`;
+      }
+      if (toolResults.length > 0) {
+        text += `\n[Tool results: ${toolResults.slice(0, 3).join("; ")}${toolResults.length > 3 ? "..." : ""}]`;
+      }
+      return text;
+    })
+    .join("\n\n");
+}
+
+/** Extract text content */
+function extractTextContent(message: AgentMessage): string {
+  if (typeof message.message.content === "string") {
+    return message.message.content;
+  }
+  if (Array.isArray(message.message.content)) {
+    return message.message.content
+      .filter((block) => block.type === "text")
+      .map((block) => (block as { text: string }).text)
+      .join("\n");
+  }
+  return "";
+}
+
+/** Extract tool use names */
+function extractToolUses(message: AgentMessage): string[] {
+  if (
+    message.type !== "assistant" ||
+    !Array.isArray(message.message.content)
+  ) {
+    return [];
+  }
+  return message.message.content
+    .filter((block) => block.type === "tool_use")
+    .map((block) => (block as { name: string }).name);
+}
+
+/** Extract tool result summaries */
+function extractToolResults(message: AgentMessage): string[] {
+  if (message.type !== "user" || !Array.isArray(message.message.content)) {
+    return [];
+  }
+  return message.message.content
+    .filter((block) => block.type === "tool_result")
+    .map((block) => {
+      const content = (block as { content: string }).content;
+      if (typeof content === "string") {
+        return content.slice(0, 100);
+      }
+      return "[complex result]";
+    });
+}
+
+/** Default summary instructions */
+function getDefaultSummaryInstructions(): string {
+  return `Create a comprehensive summary of the conversation that preserves:
+- All key decisions and outcomes reached
+- Important context, requirements, and constraints
+- Technical details, code patterns, and architecture decisions
+- Any unresolved issues or follow-up needed
+- User preferences and feedback noted
+
+The summary should allow a fresh AI to continue the conversation seamlessly.
+Keep it concise but complete (target 500-1000 tokens).`;
+}
+
+/** Generate fallback summary without LLM */
+function generateFallbackCompactSummary(messages: AgentMessage[]): string {
+  const stats = {
+    userMessages: 0,
+    assistantMessages: 0,
+    toolUses: 0,
+    topics: [] as string[],
+  };
+
+  for (const msg of messages) {
+    if (msg.type === "user") {stats.userMessages++;}
+    if (msg.type === "assistant") {stats.assistantMessages++;}
+  }
+
+  // Extract first user message topic
+  const firstUser = messages.find((m) => m.type === "user");
+  if (firstUser) {
+    const content = extractTextContent(firstUser);
+    stats.topics.push(`Initial request: ${content.slice(0, 100)}`);
+  }
+
+  // Extract last assistant action
+  const lastAssistant = messages.findLast((m) => m.type === "assistant");
+  if (lastAssistant) {
+    const content = extractTextContent(lastAssistant);
+    if (content) {
+      stats.topics.push(`Last action: ${content.slice(0, 100)}`);
+    }
+  }
+
+  return [
+    `Conversation summary (${stats.userMessages} user messages, ${stats.assistantMessages} assistant messages).`,
+    ...stats.topics,
+  ].join(" | ");
+}
+
+/** Estimate tokens */
+function estimateTokens(text: string): number {
+  return Math.ceil(text.length / 4);
+}
+
+/** Estimate tokens in messages */
+function estimateMessagesTokens(messages: AgentMessage[]): number {
+  return messages.reduce((sum, msg) => sum + estimateMessageTokens(msg), 0);
+}
+
+/** Estimate tokens in single message */
+function estimateMessageTokens(message: AgentMessage): number {
+  const overhead = 10;
+  if (typeof message.message.content === "string") {
+    return overhead + estimateTokens(message.message.content);
+  }
+  if (Array.isArray(message.message.content)) {
+    return overhead +
+      message.message.content.reduce((sum, block) => {
+        if (block.type === "text") {
+          return sum + estimateTokens((block as { text: string }).text);
+        }
+        return sum + 20;
+      }, 0);
+  }
+  return overhead;
+}
