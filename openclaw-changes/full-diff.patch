@@ -0,0 +1,171 @@
+/**
+ * GreenContractEvaluator - Contract registration and evaluation
+ */
+
+import type { ContractFilter, GreenContract, TestResult } from "./types.js";
+import { GreenLevel } from "./types.js";
+
+export interface ContractResult {
+  contractId: string;
+  contractName: string;
+  level: GreenLevel;
+  result: TestResult;
+  durationMs: number;
+  timestamp: Date;
+}
+
+export interface EvaluationSummary {
+  total: number;
+  passed: number;
+  failed: number;
+  skipped: number;
+  durationMs: number;
+  results: ContractResult[];
+  failures: ContractResult[];
+}
+
+export class GreenContractEvaluator {
+  private readonly contracts = new Map<string, GreenContract>();
+
+  register(contract: GreenContract): void {
+    if (this.contracts.has(contract.id)) {
+      throw new Error(`Contract already registered: ${contract.id}`);
+    }
+    if (!contract.test) {
+      throw new Error(`Contract ${contract.id} must have a test function`);
+    }
+    this.contracts.set(contract.id, { ...contract, tags: contract.tags ?? [] });
+  }
+
+  unregister(contractId: string): boolean {
+    return this.contracts.delete(contractId);
+  }
+
+  getContract(id: string): GreenContract | undefined {
+    return this.contracts.get(id);
+  }
+
+  listContracts(filter?: ContractFilter): GreenContract[] {
+    let results = Array.from(this.contracts.values());
+
+    if (!filter) {
+      return results;
+    }
+
+    if (filter.id) {
+      results = results.filter((c) => c.id === filter.id);
+    }
+    if (filter.level !== undefined) {
+      results = results.filter((c) => c.level === filter.level);
+    }
+    if (filter.tags && filter.tags.length > 0) {
+      results = results.filter((c) => filter.tags!.some((t) => c.tags?.includes(t)));
+    }
+
+    return results;
+  }
+
+  async evaluate(contractId: string): Promise<TestResult> {
+    const contract = this.contracts.get(contractId);
+    if (!contract) {
+      throw new Error(`Contract not found: ${contractId}`);
+    }
+
+    const startTime = Date.now();
+
+    // Run setup if defined
+    if (contract.setup) {
+      try {
+        await contract.setup();
+      } catch (err) {
+        return {
+          passed: false,
+          message: `Setup failed: ${err instanceof Error ? err.message : String(err)}`,
+          durationMs: Date.now() - startTime,
+        };
+      }
+    }
+
+    // Run the test
+    let result: TestResult;
+    try {
+      result = await contract.test();
+    } catch (err) {
+      result = {
+        passed: false,
+        message: `Test threw: ${err instanceof Error ? err.message : String(err)}`,
+      };
+    }
+
+    // Run teardown if defined (don't fail the test if teardown fails)
+    if (contract.teardown) {
+      try {
+        await contract.teardown();
+      } catch {
+        // Ignore teardown errors
+      }
+    }
+
+    result.durationMs = Date.now() - startTime;
+    return result;
+  }
+
+  async evaluateAll(filter?: ContractFilter): Promise<EvaluationSummary> {
+    const contracts = this.listContracts(filter);
+    const results: ContractResult[] = [];
+    const startTime = Date.now();
+    let passed = 0;
+    let failed = 0;
+    let skipped = 0;
+
+    for (const contract of contracts) {
+      try {
+        const result = await this.evaluate(contract.id);
+        if (result.passed) {
+          passed++;
+        } else {
+          failed++;
+        }
+        results.push({
+          contractId: contract.id,
+          contractName: contract.name,
+          level: contract.level,
+          result,
+          durationMs: result.durationMs ?? 0,
+          timestamp: new Date(),
+        });
+      } catch (err) {
+        failed++;
+        results.push({
+          contractId: contract.id,
+          contractName: contract.name,
+          level: contract.level,
+          result: {
+            passed: false,
+            message: `Evaluation error: ${err instanceof Error ? err.message : String(err)}`,
+          },
+          durationMs: Date.now() - startTime,
+          timestamp: new Date(),
+        });
+      }
+    }
+
+    return {
+      total: contracts.length,
+      passed,
+      failed,
+      skipped,
+      durationMs: Date.now() - startTime,
+      results,
+      failures: results.filter((r) => !r.result.passed),
+    };
+  }
+
+  hasContract(id: string): boolean {
+    return this.contracts.has(id);
+  }
+
+  getContractCount(): number {
+    return this.contracts.size;
+  }
+}
