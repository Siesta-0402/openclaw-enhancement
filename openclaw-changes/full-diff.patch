@@ -0,0 +1,334 @@
+/**
+ * ContextCollapse (L3)
+ * ====================
+ *
+ * Active compaction that summarizes the middle portion of conversation
+ * while preserving head and tail segments.
+ *
+ * Trigger: Token count exceeds 90% of effective context window
+ * Action: Summarize middle third, create boundary marker
+ * Tokens saved: ~60-70% of summarized portion
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+
+/** Configuration for ContextCollapse */
+export interface ContextCollapseConfig {
+  /** Token threshold as percentage of effective context window */
+  thresholdPercent: number;
+  /** Percentage of middle section to summarize */
+  middleSectionPercent: number;
+  /** Preserve at least this many messages from head */
+  minHeadPreserve: number;
+  /** Preserve at least this many messages from tail */
+  minTailPreserve: number;
+  /** Custom instructions for summarization */
+  customInstructions?: string;
+}
+
+/** Default ContextCollapse configuration */
+export const DEFAULT_CONTEXT_COLLAPSE_CONFIG: ContextCollapseConfig = {
+  thresholdPercent: 90,
+  middleSectionPercent: 33,
+  minHeadPreserve: 5,
+  minTailPreserve: 10,
+};
+
+/** Result of ContextCollapse operation */
+export interface ContextCollapseResult {
+  /** Whether collapse was applied */
+  collapsed: boolean;
+  /** Messages after collapse */
+  messages: AgentMessage[];
+  /** Summary of collapsed content */
+  summary?: string;
+  /** Boundary marker message */
+  boundaryMessage?: AgentMessage;
+  /** Tokens before collapse */
+  tokensBefore: number;
+  /** Tokens after collapse */
+  tokensAfter?: number;
+  /** Details of the collapse */
+  details: {
+    messagesSummarized: number;
+    headPreserved: number;
+    tailPreserved: number;
+    summaryTokens: number;
+  };
+}
+
+/** System message types for compact boundaries */
+interface CompactBoundaryMessage extends AgentMessage {
+  type: "system";
+  isCompactBoundary: true;
+  compactMetadata?: {
+    type: "context_collapse";
+    preCompactTokenCount: number;
+    messagesSummarized: number;
+    summaryTokenCount: number;
+    lastKeptMessageId?: string;
+  };
+}
+
+/**
+ * L3 ContextCollapse: Summarize middle section of conversation.
+ *
+ * When context pressure is high but not critical, this tier preserves
+ * the most recent context (tail) and any essential setup (head),
+ * while summarizing the middle portion that represents historical context.
+ */
+export async function applyContextCollapse(
+  messages: AgentMessage[],
+  tokenCount: number,
+  model: string,
+  config: Partial<ContextCollapseConfig> = {},
+  summarizer?: (
+    content: string,
+    instructions?: string
+  ) => Promise<string>
+): Promise<ContextCollapseResult> {
+  const cfg = { ...DEFAULT_CONTEXT_COLLAPSE_CONFIG, ...config };
+
+  // Check if collapse should trigger
+  const threshold = getThreshold(model, cfg.thresholdPercent);
+  if (tokenCount < threshold) {
+    return {
+      collapsed: false,
+      messages,
+      tokensBefore: tokenCount,
+      details: {
+        messagesSummarized: 0,
+        headPreserved: messages.length,
+        tailPreserved: 0,
+        summaryTokens: 0,
+      },
+    };
+  }
+
+  // Calculate section sizes
+  const totalMessages = messages.length;
+  const headSize = Math.max(
+    cfg.minHeadPreserve,
+    Math.floor(totalMessages * 0.2)
+  );
+  const tailSize = Math.max(
+    cfg.minTailPreserve,
+    Math.floor(totalMessages * 0.3)
+  );
+
+  // Ensure we have a meaningful middle section
+  if (headSize + tailSize >= totalMessages) {
+    return {
+      collapsed: false,
+      messages,
+      tokensBefore: tokenCount,
+      details: {
+        messagesSummarized: 0,
+        headPreserved: messages.length,
+        tailPreserved: 0,
+        summaryTokens: 0,
+      },
+    };
+  }
+
+  const middleSection = messages.slice(headSize, totalMessages - tailSize);
+  const headSection = messages.slice(0, headSize);
+  const tailSection = messages.slice(totalMessages - tailSize);
+
+  // Generate summary of middle section
+  let summary = "";
+  let summaryTokens = 0;
+
+  if (summarizer && middleSection.length > 0) {
+    const middleContent = formatMessagesForSummary(middleSection);
+    summary = await summarizer(
+      middleContent,
+      cfg.customInstructions ?? getDefaultCollapseInstructions()
+    );
+    summaryTokens = estimateTokens(summary);
+  } else {
+    // Fallback: simple concatenation with truncation
+    summary = generateFallbackSummary(middleSection);
+    summaryTokens = estimateTokens(summary);
+  }
+
+  // Create boundary marker
+  const boundaryMessage: CompactBoundaryMessage = {
+    type: "system",
+    id: `compact-boundary-${Date.now()}`,
+    timestamp: new Date().toISOString(),
+    isMeta: true,
+    isCompactBoundary: true,
+    message: {
+      role: "system",
+      content: `[Earlier conversation summarized: ${summary.slice(0, 500)}${summary.length > 500 ? "..." : ""}]`,
+    },
+    compactMetadata: {
+      type: "context_collapse",
+      preCompactTokenCount: tokenCount,
+      messagesSummarized: middleSection.length,
+      summaryTokenCount: summaryTokens,
+      lastKeptMessageId: tailSection[0]?.id,
+    },
+  };
+
+  // Build collapsed message list
+  const result = [
+    ...headSection,
+    boundaryMessage,
+    ...tailSection,
+  ];
+
+  const tokensAfter = estimateMessagesTokens(result);
+
+  return {
+    collapsed: true,
+    messages: result,
+    summary,
+    boundaryMessage,
+    tokensBefore: tokenCount,
+    tokensAfter,
+    details: {
+      messagesSummarized: middleSection.length,
+      headPreserved: headSection.length,
+      tailPreserved: tailSection.length,
+      summaryTokens,
+    },
+  };
+}
+
+/**
+ * Check if ContextCollapse should trigger.
+ */
+export function shouldContextCollapse(
+  tokenCount: number,
+  model: string,
+  config?: Partial<ContextCollapseConfig>
+): boolean {
+  const cfg = { ...DEFAULT_CONTEXT_COLLAPSE_CONFIG, ...config };
+  const threshold = getThreshold(model, cfg.thresholdPercent);
+  return tokenCount >= threshold;
+}
+
+/** Get threshold in tokens for a model */
+function getThreshold(model: string, percent: number): number {
+  // Import from tokenBudget to avoid circular dependency at runtime
+  const effectiveWindow = getEffectiveWindowForModel(model);
+  return Math.floor(effectiveWindow * (percent / 100));
+}
+
+/** Mock effective window (imported from tokenBudget in real implementation) */
+function getEffectiveWindowForModel(model: string): number {
+  const lowerModel = model.toLowerCase();
+  if (lowerModel.includes("claude")) {return 180000;}
+  if (lowerModel.includes("gpt-4")) {return 110000;}
+  if (lowerModel.includes("gpt-3.5")) {return 14000;}
+  return 80000;
+}
+
+/** Format messages for summarization */
+function formatMessagesForSummary(messages: AgentMessage[]): string {
+  return messages
+    .map((msg) => {
+      const role = msg.type === "assistant" ? "Assistant" : "User";
+      const content = extractTextContent(msg);
+      return `${role}: ${content}`;
+    })
+    .join("\n\n");
+}
+
+/** Extract text content from a message */
+function extractTextContent(message: AgentMessage): string {
+  if (typeof message.message.content === "string") {
+    return message.message.content;
+  }
+
+  if (Array.isArray(message.message.content)) {
+    return message.message.content
+      .filter((block) => block.type === "text")
+      .map((block) => (block as { text: string }).text)
+      .join("\n");
+  }
+
+  return "";
+}
+
+/** Generate a fallback summary when no summarizer is available */
+function generateFallbackSummary(messages: AgentMessage[]): string {
+  const summaryParts: string[] = [];
+  let userTurns = 0;
+  let assistantTurns = 0;
+
+  for (const msg of messages) {
+    if (msg.type === "user") {userTurns++;}
+    if (msg.type === "assistant") {assistantTurns++;}
+  }
+
+  summaryParts.push(
+    `Conversation overview: ${userTurns} user messages and ${assistantTurns} assistant responses.`
+  );
+
+  // Extract key topics from first and last messages
+  const firstContent = messages[0] ? extractTextContent(messages[0]) : "";
+  const lastContent =
+    messages[messages.length - 1]
+      ? extractTextContent(messages[messages.length - 1])
+      : "";
+
+  if (firstContent) {
+    summaryParts.push(`Started with: ${firstContent.slice(0, 200)}`);
+  }
+  if (lastContent) {
+    summaryParts.push(`Most recent: ${lastContent.slice(0, 200)}`);
+  }
+
+  return summaryParts.join(" | ");
+}
+
+/** Default instructions for collapse summarization */
+function getDefaultCollapseInstructions(): string {
+  return `Summarize the conversation concisely, preserving:
+- Key decisions and outcomes
+- Important context or constraints mentioned
+- Any unresolved topics or follow-ups needed
+Keep the summary under 500 tokens.`;
+}
+
+/** Rough token estimation */
+function estimateTokens(text: string): number {
+  return Math.ceil(text.length / 4);
+}
+
+/** Estimate tokens in a message array */
+function estimateMessagesTokens(messages: AgentMessage[]): number {
+  return messages.reduce((sum, msg) => sum + estimateMessageTokens(msg), 0);
+}
+
+/** Estimate tokens in a single message */
+function estimateMessageTokens(message: AgentMessage): number {
+  // Base overhead for message structure
+  const overhead = 10;
+
+  if (typeof message.message.content === "string") {
+    return overhead + estimateTokens(message.message.content);
+  }
+
+  if (Array.isArray(message.message.content)) {
+    return overhead +
+      message.message.content.reduce((sum, block) => {
+        if (block.type === "text") {
+          return sum + estimateTokens(block.text);
+        }
+        if (block.type === "tool_result") {
+          const content = block.content;
+          if (typeof content === "string") {
+            return sum + estimateTokens(content);
+          }
+        }
+        // Tool uses, thinking, etc. add overhead
+        return sum + 20;
+      }, 0);
+  }
+
+  return overhead;
+}
diff --git a/src/context-engine/compact/historySnip.ts b/src/context-engine/compact/historySnip.ts
