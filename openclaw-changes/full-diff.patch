+/**
+ * LSP Tools - Tool definitions for LSP operations
+ */
+
+import { z } from "zod";
+import type { LspManager } from "./lsp-manager.js";
+import { getLanguageForFilePath } from "./language-map.js";
+
+// Re-export LSP types for use in tools
+export interface LspPosition {
+  line: number;
+  character: number;
+}
+
+export interface LspTextDocumentIdentifier {
+  uri: string;
+}
+
+export interface LspLocation {
+  uri: string;
+  range: {
+    start: LspPosition;
+    end: LspPosition;
+  };
+}
+
+export interface LspHover {
+  contents: string | { language: string; value: string };
+  range?: {
+    start: LspPosition;
+    end: LspPosition;
+  };
+}
+
+export interface LspCompletionItem {
+  label: string;
+  kind?: number;
+  detail?: string;
+  documentation?: string;
+  insertText?: string;
+  filterText?: string;
+  textEdit?: {
+    newText: string;
+    range: { start: LspPosition; end: LspPosition };
+  };
+}
+
+export interface LspDiagnostic {
+  range: {
+    start: LspPosition;
+    end: LspPosition;
+  };
+  severity?: number;
+  code?: number | string;
+  source?: string;
+  message: string;
+}
+
+export interface LspReference {
+  uri: string;
+  range: {
+    start: LspPosition;
+    end: LspPosition;
+  };
+}
+
+export function createLspToolDefinitions(lspManager: LspManager) {
+  return [
+    {
+      name: "lsp_diagnostics",
+      description: "Get current diagnostics (errors, warnings, infos) for a file",
+      inputSchema: {
+        fileUri: z.string().describe("URI of the file to get diagnostics for"),
+      },
+      async handle({ fileUri }: { fileUri: string }) {
+        const language = getLanguageForFilePath(fileUri);
+        if (!language) {
+          return {
+            content: [{ type: "text", text: `Unknown file type for: ${fileUri}` }],
+            isError: true,
+          };
+        }
+        const serverId = language;
+        const state = lspManager.getState(serverId);
+        if (state !== "running") {
+          return {
+            content: [{ type: "text", text: `LSP server not running for ${language}: ${state}` }],
+            isError: true,
+          };
+        }
+        try {
+          const diagnostics = await lspManager.sendRequest<LspDiagnostic[]>(serverId, "textDocument/diagnostic", {
+            textDocument: { uri: fileUri },
+          });
+          if (!diagnostics || diagnostics.length === 0) {
+            return {
+              content: [{ type: "text", text: `No diagnostics for ${fileUri}` }],
+            };
+          }
+          return {
+            content: [{ type: "text", text: JSON.stringify(diagnostics, null, 2) }],
+            structuredContent: { diagnostics },
+          };
+        } catch (err) {
+          return {
+            content: [{ type: "text", text: `Error getting diagnostics: ${err}` }],
+            isError: true,
+          };
+        }
+      },
+    },
+    {
+      name: "lsp_hover",
+      description: "Get hover information at a cursor position in a file",
+      inputSchema: {
+        fileUri: z.string().describe("URI of the file"),
+        line: z.number().int().min(0).describe("Line number (0-indexed)"),
+        character: z.number().int().min(0).describe("Character offset (0-indexed)"),
+      },
+      async handle({ fileUri, line, character }: { fileUri: string; line: number; character: number }) {
+        const language = getLanguageForFilePath(fileUri);
+        if (!language) {
+          return {
+            content: [{ type: "text", text: `Unknown file type for: ${fileUri}` }],
+            isError: true,
+          };
+        }
+        const state = lspManager.getState(language);
+        if (state !== "running") {
+          return {
+            content: [{ type: "text", text: `LSP server not running for ${language}: ${state}` }],
+            isError: true,
+          };
+        }
+        try {
+          const result = await lspManager.sendRequest<LspHover | null>(language, "textDocument/hover", {
+            textDocument: { uri: fileUri },
+            position: { line, character },
+          });
+          if (!result) {
+            return {
+              content: [{ type: "text", text: `No hover information at ${fileUri}:${line}:${character}` }],
+            };
+          }
+          const text = typeof result.contents === "string"
+            ? result.contents
+            : `**${result.contents.language}**\n\`\`\`\n${result.contents.value}\n\`\`\``;
+          return {
+            content: [{ type: "text", text }],
+            structuredContent: { hover: result },
+          };
+        } catch (err) {
+          return {
+            content: [{ type: "text", text: `Error getting hover: ${err}` }],
+            isError: true,
+          };
+        }
+      },
+    },
+    {
+      name: "lsp_definition",
+      description: "Go to the definition of a symbol at a position",
+      inputSchema: {
+        fileUri: z.string().describe("URI of the file"),
+        line: z.number().int().min(0).describe("Line number (0-indexed)"),
+        character: z.number().int().min(0).describe("Character offset (0-indexed)"),
+      },
+      async handle({ fileUri, line, character }: { fileUri: string; line: number; character: number }) {
+        const language = getLanguageForFilePath(fileUri);
+        if (!language) {
+          return {
+            content: [{ type: "text", text: `Unknown file type for: ${fileUri}` }],
+            isError: true,
+          };
+        }
+        const state = lspManager.getState(language);
+        if (state !== "running") {
+          return {
+            content: [{ type: "text", text: `LSP server not running for ${language}: ${state}` }],
+            isError: true,
+          };
+        }
+        try {
+          const result = await lspManager.sendRequest<LspLocation | LspLocation[] | null>(
+            language,
+            "textDocument/definition",
+            { textDocument: { uri: fileUri }, position: { line, character } },
+          );
+          if (!result) {
+            return {
+              content: [{ type: "text", text: `No definition found at ${fileUri}:${line}:${character}` }],
+            };
+          }
+          const locations = Array.isArray(result) ? result : [result];
+          return {
+            content: [{ type: "text", text: `Found ${locations.length} definition(s)` }],
+            structuredContent: { definitions: locations },
+          };
+        } catch (err) {
+          return {
+            content: [{ type: "text", text: `Error getting definition: ${err}` }],
+            isError: true,
+          };
+        }
+      },
+    },
+    {
+      name: "lsp_references",
+      description: "Find all references to a symbol at a position",
+      inputSchema: {
+        fileUri: z.string().describe("URI of the file"),
+        line: z.number().int().min(0).describe("Line number (0-indexed)"),
+        character: z.number().int().min(0).describe("Character offset (0-indexed)"),
+        includeDeclaration: z.boolean().optional().default(true).describe("Include the declaration"),
+      },
+      async handle(
+        { fileUri, line, character, includeDeclaration = true }: {
+          fileUri: string;
+          line: number;
+          character: number;
+          includeDeclaration?: boolean;
+        },
+      ) {
+        const language = getLanguageForFilePath(fileUri);
+        if (!language) {
+          return {
+            content: [{ type: "text", text: `Unknown file type for: ${fileUri}` }],
+            isError: true,
+          };
+        }
+        const state = lspManager.getState(language);
+        if (state !== "running") {
+          return {
+            content: [{ type: "text", text: `LSP server not running for ${language}: ${state}` }],
+            isError: true,
+          };
+        }
+        try {
+          const result = await lspManager.sendRequest<LspReference[] | null>(language, "textDocument/references", {
+            textDocument: { uri: fileUri },
+            position: { line, character },
+            context: { includeDeclaration },
+          });
+          if (!result || result.length === 0) {
+            return {
+              content: [{ type: "text", text: `No references found at ${fileUri}:${line}:${character}` }],
+            };
+          }
+          return {
+            content: [{ type: "text", text: `Found ${result.length} reference(s)` }],
+            structuredContent: { references: result },
+          };
+        } catch (err) {
+          return {
+            content: [{ type: "text", text: `Error getting references: ${err}` }],
+            isError: true,
+          };
+        }
+      },
+    },
+    {
+      name: "lsp_completion",
+      description: "Get completion items at a position in a file",
+      inputSchema: {
+        fileUri: z.string().describe("URI of the file"),
+        line: z.number().int().min(0).describe("Line number (0-indexed)"),
+        character: z.number().int().min(0).describe("Character offset (0-indexed)"),
+        triggerKind: z.number().int().optional().describe("Completion trigger kind (1=none, 2=trigger, 3=triggerForIncompleteCompletions)"),
+      },
+      async handle(
+        { fileUri, line, character, triggerKind }: {
+          fileUri: string;
+          line: number;
+          character: number;
+          triggerKind?: number;
+        },
+      ) {
+        const language = getLanguageForFilePath(fileUri);
+        if (!language) {
+          return {
+            content: [{ type: "text", text: `Unknown file type for: ${fileUri}` }],
+            isError: true,
+          };
+        }
+        const state = lspManager.getState(language);
+        if (state !== "running") {
+          return {
+            content: [{ type: "text", text: `LSP server not running for ${language}: ${state}` }],
+            isError: true,
+          };
+        }
+        try {
+          const params: Record<string, unknown> = {
+            textDocument: { uri: fileUri },
+            position: { line, character },
+          };
+          if (triggerKind !== undefined) {
+            params.context = { triggerKind };
+          }
+          const result = await lspManager.sendRequest<{ isIncomplete: boolean; items: LspCompletionItem[] } | null>(
+            language,
+            "textDocument/completion",
+            params,
+          );
+          if (!result || result.items.length === 0) {
+            return {
+              content: [{ type: "text", text: `No completions at ${fileUri}:${line}:${character}` }],
+            };
+          }
+          return {
+            content: [{ type: "text", text: `${result.items.length} completion item(s)` }],
+            structuredContent: { completions: result.items, isIncomplete: result.isIncomplete },
+          };
+        } catch (err) {
+          return {
+            content: [{ type: "text", text: `Error getting completions: ${err}` }],
+            isError: true,
+          };
+        }
+      },
+    },
+  ];
+}
+
+export type LspToolName = "lsp_diagnostics" | "lsp_hover" | "lsp_definition" | "lsp_references" | "lsp_completion";
+
+export const LSP_TOOL_NAMES: LspToolName[] = [
+  "lsp_diagnostics",
+  "lsp_hover",
+  "lsp_definition",
+  "lsp_references",
+  "lsp_completion",
+];
