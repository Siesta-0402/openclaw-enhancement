+/**
+ * Language Map - Extension to Language to LSP Server mapping
+ */
+
+export interface LanguageConfig {
+  languageId: string;
+  extensions: string[];
+  shebang?: string[];
+  lspServerId?: string;
+}
+
+export const EXTENSION_TO_LANGUAGE: Record<string, string> = {
