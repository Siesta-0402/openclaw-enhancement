+/**
+ * CircuitBreaker for AutoCompact
+ * ==============================
+ *
+ * Prevents cascading failures in auto-compaction by tracking consecutive
+ * failures and opening the circuit to halt further compaction attempts.
+ */
+
+import { logger } from "@mariozechner/pi-agent-core/logger";
+
+/** Maximum consecutive auto-compact failures before circuit opens */
+export const MAX_CONSECUTIVE_AUTOCOMPACT_FAILURES = 3;
+
+/** Circuit states */
+export type CircuitState = "closed" | "open" | "half-open";
+
+/**
+ * CircuitBreaker for AutoCompact operations.
+ *
+ * Tracks consecutive failures and opens the circuit when the threshold
+ * is reached, preventing further compaction attempts that are likely
+ * to fail.
+ */
+export class CircuitBreaker {
+  private consecutiveFailures = 0;
+  private state: CircuitState = "closed";
+  private lastFailureTime: number | null = null;
+  private readonly maxFailures: number;
+
+  constructor(maxFailures: number = MAX_CONSECUTIVE_AUTOCOMPACT_FAILURES) {
+    this.maxFailures = maxFailures;
+  }
+
+  /**
+   * Record a compaction failure.
+   */
+  trackFailure(): void {
+    this.consecutiveFailures++;
+    this.lastFailureTime = Date.now();
+
+    if (this.consecutiveFailures >= this.maxFailures) {
+      this.state = "open";
+      logger.warn(
+        `[CircuitBreaker] Opened after ${this.consecutiveFailures} consecutive failures`
+      );
+    }
+  }
+
+  /**
+   * Record a successful compaction.
+   * Resets the failure counter and closes the circuit.
+   */
+  trackSuccess(): void {
+    this.consecutiveFailures = 0;
+    this.state = "closed";
+    this.lastFailureTime = null;
+  }
+
+  /**
+   * Check if the circuit is open (compaction should be skipped).
+   */
+  isOpen(): boolean {
+    return this.state === "open";
+  }
+
+  /**
+   * Get the current circuit state.
+   */
+  getState(): CircuitState {
+    return this.state;
+  }
+
+  /**
+   * Get the number of consecutive failures.
+   */
+  getConsecutiveFailures(): number {
+    return this.consecutiveFailures;
+  }
+
+  /**
+   * Get the time of the last failure (if any).
+   */
+  getLastFailureTime(): number | null {
+    return this.lastFailureTime;
+  }
+
+  /**
+   * Manually reset the circuit breaker.
+   */
+  reset(): void {
+    this.consecutiveFailures = 0;
+    this.state = "closed";
+    this.lastFailureTime = null;
+  }
+
+  /**
+   * Attempt to close the circuit from half-open state.
+   * Called when a compaction attempt is made after circuit opened.
+   */
+  attemptClose(): void {
+    if (this.state === "open" && this.consecutiveFailures < this.maxFailures) {
+      this.state = "half-open";
+    }
+  }
+}
+
+/** Global circuit breaker instance for auto-compact */
+let globalCircuitBreaker: CircuitBreaker | null = null;
+
+/**
+ * Get the global circuit breaker instance.
+ */
+export function getCircuitBreaker(): CircuitBreaker {
+  if (!globalCircuitBreaker) {
+    globalCircuitBreaker = new CircuitBreaker();
+  }
+  return globalCircuitBreaker;
+}
+
+/**
+ * Wrap an auto-compact operation with circuit breaker protection.
+ */
+export async function withCircuitBreaker<T>(
+  operation: () => Promise<T>,
+  onCircuitOpen?: () => void
+): Promise<{ result?: T; skipped: boolean; circuitOpen: boolean }> {
+  const cb = getCircuitBreaker();
+
+  if (cb.isOpen()) {
+    onCircuitOpen?.();
+    return { skipped: true, circuitOpen: true };
+  }
+
+  try {
+    const result = await operation();
+    cb.trackSuccess();
+    return { result, skipped: false, circuitOpen: false };
+  } catch (error) {
+    cb.trackFailure();
+    logger.warn(
+      `[CircuitBreaker] Compaction failure #${cb.getConsecutiveFailures()}`,
+      error
+    );
+    return { skipped: false, circuitOpen: cb.isOpen() };
+  }
+}
