+/**
+ * TestResultCollector - Collects and aggregates test results
+ */
+
+import type { ContractResult, EvaluationSummary } from "./evaluator.js";
+import { GreenLevel, greenLevelToLabel } from "./types.js";
+
+export class TestResultCollector {
+  private readonly results: ContractResult[] = [];
+
+  addResult(result: ContractResult): void {
+    this.results.push({ ...result });
+  }
+
+  getResults(): ContractResult[] {
+    return [...this.results];
+  }
+
+  getFailures(): ContractResult[] {
+    return this.results.filter((r) => !r.result.passed);
+  }
+
+  getSummary(): EvaluationSummary {
+    const total = this.results.length;
+    const passed = this.results.filter((r) => r.result.passed).length;
+    const failed = total - passed;
+    const skipped = 0;
+    const durationMs = this.results.reduce((sum, r) => sum + (r.durationMs ?? 0), 0);
+
+    return {
+      total,
+      passed,
+      failed,
+      skipped,
+      durationMs,
+      results: this.getResults(),
+      failures: this.getFailures(),
+    };
+  }
+
+  clear(): void {
+    this.results.length = 0;
+  }
+
+  serialize(): string {
+    const summary = this.getSummary();
+    return JSON.stringify(summary, null, 2);
+  }
+
+  summarizeByLevel(): Record<string, { total: number; passed: number; failed: number }> {
+    const summary: Record<string, { total: number; passed: number; failed: number }> = {};
+
+    for (const level of Object.values(GreenLevel)) {
+      const levelLabel = greenLevelToLabel(level);
+      const levelResults = this.results.filter((r) => r.level === level);
+      summary[levelLabel] = {
+        total: levelResults.length,
+        passed: levelResults.filter((r) => r.result.passed).length,
+        failed: levelResults.filter((r) => !r.result.passed).length,
+      };
+    }
+
+    return summary;
+  }
+
+  hasFailuresAtLevel(level: GreenLevel): boolean {
+    return this.results.some((r) => r.level === level && !r.result.passed);
+  }
+
+  getFailureCount(): number {
+    return this.getFailures().length;
+  }
+
+  getPassCount(): number {
+    return this.results.filter((r) => r.result.passed).length;
+  }
+
+  formatSummary(): string {
+    const summary = this.getSummary();
+    const byLevel = this.summarizeByLevel();
+
+    const lines: string[] = [
+      `Total: ${summary.total} | Passed: ${summary.passed} | Failed: ${summary.failed} | Duration: ${summary.durationMs}ms`,
+      "",
+      "Results by level:",
+    ];
+
+    for (const [level, stats] of Object.entries(byLevel)) {
+      if (stats.total > 0) {
+        const status = stats.failed > 0 ? `❌ ${stats.failed} failed` : "✅ all passed";
+        lines.push(`  ${level}: ${stats.total} contracts (${status})`);
+      }
+    }
+
+    if (summary.failures.length > 0) {
+      lines.push("");
+      lines.push("Failures:");
+      for (const failure of summary.failures) {
+        lines.push(`  [${greenLevelToLabel(failure.level)}] ${failure.contractName}: ${failure.result.message ?? "no message"}`);
+      }
+    }
+
+    return lines.join("\n");
+  }
+}
