@@ -0,0 +1,206 @@
+/**
+ * Session Memory Compaction
+ * ========================
+ *
+ * Session-scoped memory compaction that leverages session context
+ * to create compact summaries without full LLM summarization.
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+
+/** Configuration for session memory compaction */
+export interface SessionMemoryCompactConfig {
+  /** Enable session memory compaction */
+  enabled: boolean;
+  /** Max session messages to keep before summarizing */
+  maxSessionMessages: number;
+  /** Extract key patterns from session */
+  extractPatterns: boolean;
+}
+
+/** Default configuration */
+export const DEFAULT_SESSION_MEMORY_CONFIG: SessionMemoryCompactConfig = {
+  enabled: true,
+  maxSessionMessages: 30,
+  extractPatterns: true,
+};
+
+/** Extracted patterns from a session */
+export interface SessionPatterns {
+  /** Files that were read */
+  filesAccessed: string[];
+  /** Commands that were run */
+  commandsRun: string[];
+  /** Topics discussed */
+  topics: string[];
+  /** Decisions made */
+  decisions: string[];
+  /** User preferences noted */
+  preferences: string[];
+}
+
+/** Result of session memory compaction */
+export interface SessionMemoryCompactResult {
+  /** Whether compaction was applied */
+  compacted: boolean;
+  /** Extracted session patterns */
+  patterns: SessionPatterns;
+  /** Summary message generated */
+  summaryMessage?: AgentMessage;
+  /** Messages after compaction */
+  messages: AgentMessage[];
+}
+
+/**
+ * Try session memory compaction.
+ * This is attempted before full AutoCompact to preserve more context.
+ */
+export async function trySessionMemoryCompaction(
+  messages: AgentMessage[],
+  config?: Partial<SessionMemoryCompactConfig>
+): Promise<SessionMemoryCompactResult | null> {
+  const cfg = { ...DEFAULT_SESSION_MEMORY_CONFIG, ...config };
+
+  if (!cfg.enabled || messages.length <= cfg.maxSessionMessages) {
+    return null;
+  }
+
+  // Extract patterns from the session
+  const patterns = extractSessionPatterns(messages);
+
+  // Create a summary based on patterns
+  const summary = generatePatternBasedSummary(patterns);
+
+  // Keep the most recent messages
+  const recentMessages = messages.slice(-cfg.maxSessionMessages);
+
+  // Create summary message
+  const summaryMessage: AgentMessage = {
+    type: "user",
+    id: `session-memory-${Date.now()}`,
+    timestamp: new Date().toISOString(),
+    isMeta: true,
+    isCompactSummary: true,
+    message: {
+      role: "user",
+      content: `Session memory:\n\n${summary}`,
+    },
+  };
+
+  return {
+    compacted: true,
+    patterns,
+    summaryMessage,
+    messages: [summaryMessage, ...recentMessages],
+  };
+}
+
+/**
+ * Extract patterns from session messages.
+ */
+export function extractSessionPatterns(messages: AgentMessage[]): SessionPatterns {
+  const patterns: SessionPatterns = {
+    filesAccessed: [],
+    commandsRun: [],
+    topics: [],
+    decisions: [],
+    preferences: [],
+  };
+
+  const filePattern = /([a-zA-Z0-9_\-./]+\.[a-zA-Z]+)/g;
+  const commandPattern = /(?:run|execute|call)\s+`?([a-zA-Z0-9_\-./|]+)`?/gi;
+  const topicPattern = /(?:about|regarding|concerning|topic:)\s*([^.!?]+)/gi;
+  const decisionPattern = /(?:decided|chose|selected|agreed)\s+(?:to\s+)?([^.!?]+)/gi;
+  const preferencePattern = /(?:prefer|preference|like|favor)\s+([^.!?]+)/gi;
+
+  for (const msg of messages) {
+    if (typeof msg.message.content === "string") {
+      const content = msg.message.content;
+
+      // Extract file paths
+      let match;
+      while ((match = filePattern.exec(content)) !== null) {
+        if (isLikelyFilePath(match[1])) {
+          patterns.filesAccessed.push(match[1]);
+        }
+      }
+
+      // Extract commands
+      while ((match = commandPattern.exec(content)) !== null) {
+        patterns.commandsRun.push(match[1]);
+      }
+
+      // Extract topics
+      while ((match = topicPattern.exec(content)) !== null) {
+        patterns.topics.push(match[1].trim());
+      }
+
+      // Extract decisions
+      while ((match = decisionPattern.exec(content)) !== null) {
+        patterns.decisions.push(match[1].trim());
+      }
+
+      // Extract preferences
+      while ((match = preferencePattern.exec(content)) !== null) {
+        patterns.preferences.push(match[1].trim());
+      }
+    }
+  }
+
+  // Deduplicate
+  patterns.filesAccessed = [...new Set(patterns.filesAccessed)];
+  patterns.commandsRun = [...new Set(patterns.commandsRun)];
+  patterns.topics = [...new Set(patterns.topics)];
+  patterns.decisions = [...new Set(patterns.decisions)];
+  patterns.preferences = [...new Set(patterns.preferences)];
+
+  return patterns;
+}
+
+/**
+ * Check if a string looks like a file path.
+ */
+function isLikelyFilePath(str: string): boolean {
+  // Has extension
+  if (!str.includes(".")) return false;
+  // Has path separator
+  if (!str.includes("/") && !str.includes("\\")) return false;
+  // Not too long
+  if (str.length > 200) return false;
+  return true;
+}
+
+/**
+ * Generate a summary based on extracted patterns.
+ */
+function generatePatternBasedSummary(patterns: SessionPatterns): string {
+  const parts: string[] = [];
+
+  if (patterns.topics.length > 0) {
+    parts.push(`Topics: ${patterns.topics.slice(0, 5).join(", ")}`);
+  }
+
+  if (patterns.filesAccessed.length > 0) {
+    const uniqueFiles = patterns.filesAccessed.slice(0, 10);
+    parts.push(`Files accessed: ${uniqueFiles.join(", ")}`);
+  }
+
+  if (patterns.commandsRun.length > 0) {
+    const uniqueCommands = patterns.commandsRun.slice(0, 5);
+    parts.push(`Commands run: ${uniqueCommands.join(", ")}`);
+  }
+
+  if (patterns.decisions.length > 0) {
+    parts.push(`Decisions: ${patterns.decisions.slice(0, 3).join("; ")}`);
+  }
+
+  if (patterns.preferences.length > 0) {
+    parts.push(`Preferences: ${patterns.preferences.slice(0, 3).join("; ")}`);
+  }
+
+  if (parts.length === 0) {
+    return "General conversation (no specific patterns extracted)";
+  }
+
+  return parts.join("\n");
+}
