+  cpp: { languageId: "cpp", extensions: [".cpp", ".cc", ".cxx", ".hpp", ".hxx", ".h"], lspServerId: "ccls" },
+  csharp: { languageId: "csharp", extensions: [".cs"], lspServerId: "omnisharp" },
+  ruby: { languageId: "ruby", extensions: [".rb"], lspServerId: "solargraph" },
+  php: { languageId: "php", extensions: [".php"], lspServerId: "phpactor" },
+  swift: { languageId: "swift", extensions: [".swift"], lspServerId: "sourcekit-lsp" },
+  kotlin: { languageId: "kotlin", extensions: [".kt", ".kts"], lspServerId: "kotlin-language-server" },
+  scala: { languageId: "scala", extensions: [".scala", ".sc"], lspServerId: "metals" },
+  shell: { languageId: "shell", extensions: [".sh", ".bash", ".zsh", ".fish"], lspServerId: "bash-language-server" },
+  powershell: { languageId: "powershell", extensions: [".ps1", ".psm1"], lspServerId: "powershell-lsp" },
+  yaml: { languageId: "yaml", extensions: [".yaml", ".yml"], lspServerId: "yaml-language-server" },
+  json: { languageId: "json", extensions: [".json", ".jsonc", ".json5"], lspServerId: "json-lsp" },
+  xml: { languageId: "xml", extensions: [".xml"], lspServerId: "xmllint" },
+  html: { languageId: "html", extensions: [".html", ".htm"], lspServerId: "html-language-server" },
+  css: { languageId: "css", extensions: [".css"], lspServerId: "css-language-server" },
+  scss: { languageId: "scss", extensions: [".scss", ".sass"], lspServerId: "css-language-server" },
+  less: { languageId: "less", extensions: [".less"], lspServerId: "css-language-server" },
+  markdown: { languageId: "markdown", extensions: [".md", ".mdx"], lspServerId: "markdown-language-server" },
+  sql: { languageId: "sql", extensions: [".sql"], lspServerId: "sql-language-server" },
+  vue: { languageId: "vue", extensions: [".vue"], lspServerId: "volar" },
+  svelte: { languageId: "svelte", extensions: [".svelte"], lspServerId: "svelte-language-server" },
+};
+
+export function getLanguageForExtension(extension: string): string | undefined {
+  return EXTENSION_TO_LANGUAGE[extension.toLowerCase()];
+}
+
+export function getExtensionsForLanguage(languageId: string): string[] {
+  return LANGUAGE_TO_EXTENSIONS[languageId] ?? [];
+}
+
+export function getLanguageConfig(languageId: string): LanguageConfig | undefined {
+  return LANGUAGE_CONFIGS[languageId];
+}
+
+export function getLspServerIdForLanguage(languageId: string): string | undefined {
+  return LANGUAGE_CONFIGS[languageId]?.lspServerId;
+}
+
+export function getLanguageForFilePath(filePath: string): string | undefined {
+  const lastDot = filePath.lastIndexOf(".");
+  if (lastDot < 0) {
+    return undefined;
+  }
+  const ext = filePath.slice(lastDot);
+  return getLanguageForExtension(ext);
+}
