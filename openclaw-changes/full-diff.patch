+/**
+ * Post-Compaction Cleanup
+ * ========================
+ *
+ * Cleanup operations that run after successful compaction
+ * to ensure consistent state and proper cache management.
+ */
+
+/**
+ * Run post-compaction cleanup operations.
+ *
+ * This should be called after any successful compaction operation
+ * to:
+ * - Reset transient state
+ * - Notify cache break detection
+ * - Update session metadata
+ * - Clear suppression flags
+ */
+export function runPostCompactCleanup(
+  querySource?: string
+): void {
+  // Reset microcompact state if exists
+  // (handled by resetMicrocompactState in microCompact.ts)
+
+  // Notify cache break detection if enabled
+  // (handled by notifyCompaction in the caller)
+
+  // Re-append session metadata for --resume display
+  // (handled by reAppendSessionMetadata in the caller)
+
+  // Mark post-compaction state
+  // (handled by markPostCompaction in the caller)
+
+  // Clear any compaction suppression flags
+  clearCompactWarningSuppression();
+}
+
+/** Suppression state for compact warnings */
+let compactWarningSuppressed = false;
+
+/**
+ * Suppress the compact warning after successful compaction.
+ */
+export function suppressCompactWarning(): void {
+  compactWarningSuppressed = true;
+}
+
+/**
+ * Clear compact warning suppression.
+ */
+export function clearCompactWarningSuppression(): void {
+  compactWarningSuppressed = false;
+}
+
+/**
+ * Check if compact warning is currently suppressed.
+ */
+export function isCompactWarningSuppressed(): boolean {
+  return compactWarningSuppressed;
+}
+
+/**
+ * State tracking for compaction runs.
+ */
+export interface CompactionTrackingState {
+  /** Whether a compaction just ran */
+  compacted: boolean;
+  /** Turn counter since last compaction */
+  turnCounter: number;
+  /** Unique ID for this compaction turn */
+  turnId: string;
+  /** Consecutive failure count */
+  consecutiveFailures: number;
+}
+
+/** Current tracking state */
+let trackingState: CompactionTrackingState = {
+  compacted: false,
+  turnCounter: 0,
+  turnId: "",
+  consecutiveFailures: 0,
+};
+
+/**
+ * Get the current compaction tracking state.
+ */
+export function getCompactionTrackingState(): CompactionTrackingState {
+  return { ...trackingState };
+}
+
+/**
+ * Reset the compaction tracking state.
+ */
+export function resetCompactionTracking(): void {
+  trackingState = {
+    compacted: false,
+    turnCounter: 0,
+    turnId: "",
+    consecutiveFailures: 0,
+  };
+}
+
+/**
+ * Increment turn counter (called after each turn).
+ */
+export function incrementTurnCounter(): void {
+  trackingState.turnCounter++;
+}
+
+/**
+ * Mark that compaction occurred.
+ */
+export function markCompactionOccurred(): void {
+  trackingState.compacted = true;
+  trackingState.turnCounter = 0;
+  trackingState.turnId = `compact-${Date.now()}`;
+  trackingState.consecutiveFailures = 0;
+}
+
+/**
+ * Mark that compaction failed.
+ */
+export function markCompactionFailed(): void {
+  trackingState.consecutiveFailures++;
+  // Don't reset turnCounter - we track consecutive failures separately
+}
