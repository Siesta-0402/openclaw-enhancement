diff --git a/src/agents/skills/tool-permission.ts b/src/agents/skills/tool-permission.ts
new file mode 100644
index 0000000000..9e8b54fd88
--- /dev/null
+++ b/src/agents/skills/tool-permission.ts
@@ -0,0 +1,141 @@
+/**
+ * Tool Permission System for Skills
+ *
+ * Allows skills to declare which tools they are permitted or forbidden to use
+ * via the `allowedTools` and `deniedTools` frontmatter fields.
+ *
+ * Permission rules:
+ * - If `allowedTools` is defined, ONLY tools in that list may be used.
+ * - `deniedTools` removes specific tools from that set.
+ * - If `allowedTools` is undefined, all tools are allowed except those in `deniedTools`.
+ * - A tool in both lists is treated as denied (deny takes precedence).
+ *
+ * This mirrors the TOOL_ALLOW_BY_MESSAGE_PROVIDER / TOOL_DENY_BY_MESSAGE_PROVIDER
+ * pattern used in agents/pi-tools.ts.
+ */
+
+import type { AnyAgentTool } from "../tools/common.js";
+import type { OpenClawSkillMetadata, SkillEntry } from "./types.js";
+
+export type ToolPermissionResult =
+  | { allowed: true }
+  | { allowed: false; reason: "not-in-allowed-list" | "in-denied-list" };
+
+/**
+ * Check whether a specific tool is permitted for a given skill entry.
+ *
+ * @param toolName - Name of the tool to check (AnyAgentTool.name)
+ * @param skillEntry - The skill entry whose permission rules apply
+ * @returns Object with `allowed: true` or `{ allowed: false, reason: string }`
+ */
+export function checkToolPermission(
+  toolName: string,
+  skillEntry: SkillEntry,
+): ToolPermissionResult {
+  const { allowedTools, deniedTools } = skillEntry.metadata ?? {};
+
+  // Build effective deny set (deduplicated, deny wins if overlap)
+  const denySet = deniedTools
+    ? new Set(deniedTools.filter((n): n is string => typeof n === "string" && n.trim().length > 0))
+    : new Set<string>();
+
+  if (denySet.has(toolName)) {
+    return { allowed: false, reason: "in-denied-list" };
+  }
+
+  // If allow list is defined, only those tools are permitted
+  if (allowedTools && allowedTools.length > 0) {
+    const allowSet = new Set(
+      allowedTools.filter((n): n is string => typeof n === "string" && n.trim().length > 0),
+    );
+    // Deny takes precedence even if tool appears in both lists
+    if (allowSet.has(toolName) && !denySet.has(toolName)) {
+      return { allowed: true };
+    }
+    return { allowed: false, reason: "not-in-allowed-list" };
+  }
+
+  // No allow list: everything not explicitly denied is allowed
+  return { allowed: true };
+}
+
+/**
+ * Filter an array of AnyAgentTool to only those permitted by the given skill entry.
+ *
+ * @param tools - Full list of available tools
+ * @param skillEntry - Skill entry whose permission rules apply
+ * @returns Filtered array of permitted tools
+ */
+export function filterToolsByPermission(
+  tools: AnyAgentTool[],
+  skillEntry: SkillEntry,
+): AnyAgentTool[] {
+  return tools.filter((tool) => {
+    const result = checkToolPermission(tool.name, skillEntry);
+    return result.allowed;
+  });
+}
+
+/**
+ * Merge tool permissions from multiple active skill entries.
+ * Permissions are combined such that a tool is allowed only if
+ * ALL active skills permit it (intersection semantics).
+ *
+ * @param tools - Full list of available tools
+ * @param activeSkillEntries - All currently active skill entries
+ * @returns Filtered array of tools permitted by every active skill
+ */
+export function filterToolsByMultipleSkills(
+  tools: AnyAgentTool[],
+  activeSkillEntries: SkillEntry[],
+): AnyAgentTool[] {
+  if (activeSkillEntries.length === 0) {
+    return tools;
+  }
+  return tools.filter((tool) => {
+    for (const entry of activeSkillEntries) {
+      const result = checkToolPermission(tool.name, entry);
+      if (!result.allowed) {
+        return false;
+      }
+    }
+    return true;
+  });
+}
+
+/**
+ * Resolve allowedTools/deniedTools from raw frontmatter metadata object.
+ * Normalizes and deduplicates entries, applying deny-overlap rule.
+ *
+ * @param metadata - Raw resolved metadata object
+ * @returns Object with normalized allowedTools and deniedTools arrays
+ */
+export function resolveToolPermissionMetadata(
+  metadata: Record<string, unknown>,
+): Pick<OpenClawSkillMetadata, "allowedTools" | "deniedTools"> {
+  const rawAllowed = metadata.allowedTools;
+  const rawDenied = metadata.deniedTools;
+
+  const normalize = (raw: unknown): string[] => {
+    if (Array.isArray(raw)) {
+      return raw
+        .filter((v): v is string => typeof v === "string" && v.trim().length > 0)
+        .map((v) => v.trim());
+    }
+    if (typeof raw === "string") {
+      return raw
+        .split(",")
+        .map((s) => s.trim())
+        .filter((s) => s.length > 0);
+    }
+    return [];
+  };
+
+  const denied = normalize(rawDenied);
+  const allowed = normalize(rawAllowed).filter((n) => !denied.includes(n));
+
+  return {
+    allowedTools: allowed.length > 0 ? allowed : undefined,
+    deniedTools: denied.length > 0 ? denied : undefined,
+  };
+}
