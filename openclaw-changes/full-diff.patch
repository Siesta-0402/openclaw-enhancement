@@ -0,0 +1,223 @@
+/**
+ * Task ID encoding and decoding utilities.
+ *
+ * Format: tsk_<base62_timestamp>_<base62_random>
+ * - prefix: "tsk_"
+ * - timestamp: base62 encoded Unix ms timestamp (10 chars)
+ * - random: 12 chars of base62 random
+ *
+ * This encoding provides:
+ * - Lexicographic time ordering (earlier = smaller)
+ * - Collision resistance via random component
+ * - Easy prefix scanning for debugging/logging
+ */
+
+const TASK_ID_PREFIX = "tsk_";
+const BASE62_CHARS = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz";
+const TIMESTAMP_LENGTH = 10;
+const RANDOM_LENGTH = 12;
+const TOTAL_LENGTH = TASK_ID_PREFIX.length + TIMESTAMP_LENGTH + 1 + RANDOM_LENGTH; // "tsk_" + 10 + "_" + 12
+
+const TIMESTAMP_MAX = BigInt(Math.pow(62, TIMESTAMP_LENGTH));
+const RANDOM_MAX = BigInt(Math.pow(62, RANDOM_LENGTH));
+
+function encodeBase62(value: bigint, length: number): string {
+  if (value < 0) {
+    throw new Error("Cannot encode negative values");
+  }
+  let result = "";
+  let remaining = value;
+  for (let i = 0; i < length; i++) {
+    const digit = Number(remaining % BigInt(62));
+    result = BASE62_CHARS[digit] + result;
+    remaining = remaining / BigInt(62);
+  }
+  return result;
+}
+
+function decodeBase62(encoded: string): bigint {
+  let result = BigInt(0);
+  for (let i = 0; i < encoded.length; i++) {
+    const char = encoded[i];
+    const digitIndex = BASE62_CHARS.indexOf(char);
+    if (digitIndex < 0) {
+      throw new Error(`Invalid base62 character: ${char}`);
+    }
+    result = result * BigInt(62) + BigInt(digitIndex);
+  }
+  return result;
+}
+
+/**
+ * Generate a new Task ID.
+ * Uses crypto.getRandomValues for cryptographically secure random component.
+ */
+export function generateTaskId(): string {
+  const timestamp = Date.now();
+  // Encode timestamp as base62
+  const timestampEncoded = encodeBase62(BigInt(timestamp), TIMESTAMP_LENGTH);
+
+  // Generate random component using crypto
+  const randomBigint = generateSecureRandomBigint(RANDOM_MAX);
+  const randomEncoded = encodeBase62(randomBigint, RANDOM_LENGTH);
+
+  return `${TASK_ID_PREFIX}${timestampEncoded}_${randomEncoded}`;
+}
+
+/**
+ * Generate a cryptographically secure random bigint in range [0, max).
+ * Uses multiple 32-bit values to construct the bigint.
+ */
+function generateSecureRandomBigint(max: bigint): bigint {
+  // Calculate how many bytes we need to represent max
+  const maxBytes = Math.ceil(max.toString(2).length / 8) + 1;
+  const numWords = Math.ceil(maxBytes / 4); // 4 bytes per word
+
+  const words = new Uint32Array(numWords);
+
+  // Fill with random values until we get one in range
+  let result: bigint;
+  let attempts = 0;
+  const maxAttempts = 100;
+
+  do {
+    // Use multiple reads from crypto to fill the words
+    const randomBuffer = new Uint8Array(numWords * 4);
+    crypto.getRandomValues(randomBuffer);
+    for (let i = 0; i < numWords; i++) {
+      words[i] =
+        randomBuffer[i * 4] |
+        (randomBuffer[i * 4 + 1] << 8) |
+        (randomBuffer[i * 4 + 2] << 16) |
+        (randomBuffer[i * 4 + 3] << 24);
+    }
+
+    // Combine words into bigint
+    result = BigInt(0);
+    for (let i = numWords - 1; i >= 0; i--) {
+      result = result * BigInt(0x100000000) + BigInt(words[i]);
+    }
+    attempts++;
+
+    if (attempts >= maxAttempts) {
+      // Fall back to modulo if we can't find a valid value quickly
+      // This slightly biases distribution but is negligible for our purposes
+      break;
+    }
+  } while (result >= max);
+
+  return result % max;
+}
+
+/**
+ * Parse a Task ID into its components.
+ * Returns null if the ID is invalid.
+ */
+export interface ParsedTaskId {
+  prefix: string;
+  timestamp: number;
+  random: string;
+  raw: string;
+}
+
+export function parseTaskId(taskId: string): ParsedTaskId | null {
+  if (typeof taskId !== "string" || taskId.length !== TOTAL_LENGTH) {
+    return null;
+  }
+
+  if (!taskId.startsWith(TASK_ID_PREFIX)) {
+    return null;
+  }
+
+  const remainder = taskId.slice(TASK_ID_PREFIX.length);
+  const parts = remainder.split("_");
+
+  if (parts.length !== 2 || parts[0].length !== TIMESTAMP_LENGTH || parts[1].length !== RANDOM_LENGTH) {
+    return null;
+  }
+
+  const [timestampStr, randomStr] = parts;
+
+  // Verify all characters are valid base62
+  for (const char of timestampStr) {
+    if (!BASE62_CHARS.includes(char)) return null;
+  }
+  for (const char of randomStr) {
+    if (!BASE62_CHARS.includes(char)) return null;
+  }
+
+  let timestamp: number;
+  try {
+    timestamp = Number(decodeBase62(timestampStr));
+  } catch {
+    return null;
+  }
+
+  // Sanity check on timestamp (reasonable range: year 2020 - 2100)
+  const minTimestamp = 1577836800000; // 2020-01-01
+  const maxTimestamp = 4102444800000; // 2100-01-01
+  if (timestamp < minTimestamp || timestamp > maxTimestamp) {
+    return null;
+  }
+
+  return {
+    prefix: TASK_ID_PREFIX,
+    timestamp,
+    random: randomStr,
+    raw: taskId,
+  };
+}
+
+/**
+ * Extract timestamp from a Task ID without full parsing.
+ * Returns null if the ID format is invalid.
+ */
+export function extractTaskIdTimestamp(taskId: string): number | null {
+  if (typeof taskId !== "string" || !taskId.startsWith(TASK_ID_PREFIX)) {
+    return null;
+  }
+
+  const remainder = taskId.slice(TASK_ID_PREFIX.length);
+  const parts = remainder.split("_");
+
+  if (parts.length !== 2 || parts[0].length !== TIMESTAMP_LENGTH) {
+    return null;
+  }
+
+  try {
+    return Number(decodeBase62(parts[0]));
+  } catch {
+    return null;
+  }
+}
+
+/**
+ * Check if a string is a valid Task ID.
+ */
+export function isValidTaskId(taskId: string): boolean {
+  return parseTaskId(taskId) !== null;
+}
+
+/**
+ * Check if a Task ID was created before a given timestamp.
+ * Useful for filtering old tasks.
+ */
+export function isTaskIdBefore(taskId: string, timestamp: number): boolean {
+  const extracted = extractTaskIdTimestamp(taskId);
+  return extracted !== null && extracted < timestamp;
+}
+
+/**
+ * Get sorting key for Task IDs (timestamp component).
+ * Returns -1 for invalid IDs.
+ */
+export function getTaskIdSortKey(taskId: string): number {
+  return extractTaskIdTimestamp(taskId) ?? -1;
+}
+
+export const TASK_ID_CONSTANTS = {
+  PREFIX: TASK_ID_PREFIX,
+  TIMESTAMP_LENGTH,
+  RANDOM_LENGTH,
+  TOTAL_LENGTH,
+} as const;
