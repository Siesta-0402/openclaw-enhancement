index 0000000000..8732cba1a5
--- /dev/null
+++ b/src/context-engine/compact/historySnip.ts
@@ -0,0 +1,189 @@
+/**
+ * HistorySnip Compaction (L1)
+ * ===========================
+ *
+ * Passive compaction triggered by message count thresholds.
+ * Actions:
+ * - Remove oldest assistant thinking blocks
+ * - Truncate long tool results
+ * - Preserve full message structure
+ *
+ * This is the lightest compaction level, meant to run transparently
+ * without changing message semantics significantly.
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+
+/** Configuration for HistorySnip */
+export interface HistorySnipConfig {
+  /** Max messages before snipping triggers */
+  maxMessages: number;
+  /** Max tool result length in characters */
+  maxToolResultChars: number;
+  /** Preserve last N tool results fully */
+  preserveRecentToolResults: number;
+  /** Remove thinking blocks older than this */
+  removeThinkingAfterTurns: number;
+}
+
+/** Default HistorySnip configuration */
+export const DEFAULT_HISTORY_SNIP_CONFIG: HistorySnipConfig = {
+  maxMessages: 50,
+  maxToolResultChars: 8000,
+  preserveRecentToolResults: 5,
+  removeThinkingAfterTurns: 10,
+};
+
+/** Result of a HistorySnip operation */
+export interface HistorySnipResult {
+  /** Whether any changes were made */
+  snipped: boolean;
+  /** Messages after snipping */
+  messages: AgentMessage[];
+  /** Estimated tokens saved */
+  tokensSaved: number;
+  /** Details of what was changed */
+  details: {
+    thinkingBlocksRemoved: number;
+    toolResultsTruncated: number;
+    messagesRemoved: number;
+  };
+}
+
+/**
+ * L1 HistorySnip: Light compaction based on message count.
+ *
+ * This is the first line of defense - it silently removes heavyweight
+ * but non-essential content from old messages without changing structure.
+ */
+export function applyHistorySnip(
+  messages: AgentMessage[],
+  config: Partial<HistorySnipConfig> = {}
+): HistorySnipResult {
+  const cfg = { ...DEFAULT_HISTORY_SNIP_CONFIG, ...config };
+
+  // If we're under the threshold, no snipping needed
+  if (messages.length <= cfg.maxMessages) {
+    return {
+      snipped: false,
+      messages,
+      tokensSaved: 0,
+      details: {
+        thinkingBlocksRemoved: 0,
+        toolResultsTruncated: 0,
+        messagesRemoved: 0,
+      },
+    };
+  }
+
+  let thinkingBlocksRemoved = 0;
+  let toolResultsTruncated = 0;
+  let messagesRemoved = 0;
+  let tokensSaved = 0;
+
+  // Work on a copy to avoid mutating the original
+  const result = messages.map((message, index) => {
+    // Only process messages older than the threshold from the end
+    const ageFromEnd = messages.length - index;
+    if (ageFromEnd <= cfg.maxMessages) {
+      return message;
+    }
+
+    const processed = { ...message };
+
+    // Remove thinking blocks from old assistant messages
+    if (
+      processed.type === "assistant" &&
+      Array.isArray(processed.message.content)
+    ) {
+      processed.message.content = processed.message.content.filter((block) => {
+        if (block.type === "thinking") {
+          thinkingBlocksRemoved++;
+          tokensSaved += estimateThinkingTokens(block.thinking ?? "");
+          return false;
+        }
+        return true;
+      });
+    }
+
+    // Truncate tool results from old messages
+    if (
+      processed.type === "user" &&
+      Array.isArray(processed.message.content)
+    ) {
+      processed.message.content = processed.message.content.map((block) => {
+        if (
+          block.type === "tool_result" &&
+          typeof block.content === "string" &&
+          block.content.length > cfg.maxToolResultChars
+        ) {
+          // Check if this is in the "recent" window - preserve those
+          if (ageFromEnd <= cfg.preserveRecentToolResults) {
+            return block;
+          }
+
+          toolResultsTruncated++;
+          const truncated = truncateMiddle(
+            block.content,
+            cfg.maxToolResultChars
+          );
+          tokensSaved += block.content.length - truncated.length;
+          return { ...block, content: truncated };
+        }
+        return block;
+      });
+    }
+
+    return processed;
+  });
+
+  return {
+    snipped: thinkingBlocksRemoved > 0 || toolResultsTruncated > 0,
+    messages: result,
+    tokensSaved,
+    details: {
+      thinkingBlocksRemoved,
+      toolResultsTruncated,
+      messagesRemoved,
+    },
+  };
+}
+
+/**
+ * Check if HistorySnip should trigger for a given message count.
+ */
+export function shouldHistorySnip(
+  messageCount: number,
+  config?: Partial<HistorySnipConfig>
+): boolean {
+  const cfg = { ...DEFAULT_HISTORY_SNIP_CONFIG, ...config };
+  return messageCount > cfg.maxMessages;
+}
+
+/** Estimate tokens in a thinking block */
+function estimateThinkingTokens(thinking: string): number {
+  // Rough: ~4 chars per token
+  return Math.ceil(thinking.length / 4);
+}
+
+/**
+ * Truncate a string from the middle, keeping head and tail.
+ * Inserts [...] in the middle to indicate truncation.
+ */
+function truncateMiddle(str: string, maxLength: number): string {
+  if (str.length <= maxLength) {return str;}
+
+  const headLength = Math.floor(maxLength * 0.6);
+  const tailLength = Math.floor(maxLength * 0.3);
+  const marker = "\n[... tool result truncated ...]\n";
+
+  const head = str.slice(0, headLength);
+  const tail = str.slice(-tailLength);
+
+  // If the string is too short to truncate properly, just cut it
+  if (headLength + tailLength >= str.length) {
+    return str.slice(0, maxLength);
+  }
+
+  return head + marker + tail;
+}
