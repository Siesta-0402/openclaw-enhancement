+/**
+ * Permission Policy Engine - Evaluates permissions for tool invocations
+ */
+
+import type { ToolCategory, ToolRiskLevel } from "./tool-registry.js";
+
+export type PolicyEffect = "allow" | "deny" | "prompt";
+
+export type PolicyCondition =
+  | { kind: "always" }
+  | { kind: "never" }
+  | { kind: "boolean"; flag: string }
+  | { kind: "time-range"; start: string; end: string }
+  | { kind: "path-match"; paths: string[]; pattern: string };
+
+export type PolicyTarget =
+  | { type: "tool"; toolName: string }
+  | { type: "category"; category: ToolCategory }
+  | { type: "tag"; tag: string }
+  | { type: "risk-level"; level: ToolRiskLevel };
+
+export interface PermissionPolicy {
+  id: string;
+  name: string;
+  description: string;
+  target: PolicyTarget;
+  effect: PolicyEffect;
+  conditions?: PolicyCondition[];
+  priority: number;
+}
+
+export interface PermissionContext {
+  toolName: string;
+  category: ToolCategory;
+  riskLevel: ToolRiskLevel;
+  tags: string[];
+  input?: Record<string, unknown>;
+  flags?: Record<string, boolean>;
+  timestamp?: Date;
+  requestingPath?: string;
+}
+
+export interface PolicyResult {
+  effect: PolicyEffect;
+  policyId: string;
+  reason?: string;
+  matchedTarget: PolicyTarget;
+}
+
+export interface EvaluationResult {
+  allowed: boolean;
+  reason: string;
+  policiesEvaluated: PolicyResult[];
+  needsPrompt: boolean;
+}
+
+export class PolicyEngine {
+  private readonly policies: PermissionPolicy[] = [];
+
+  addPolicy(policy: PermissionPolicy): void {
+    const existing = this.policies.findIndex((p) => p.id === policy.id);
+    if (existing >= 0) {
+      throw new Error(`Policy already exists: ${policy.id}`);
+    }
+    this.policies.push(policy);
+    this.policies.sort((a, b) => b.priority - a.priority);
+  }
+
+  removePolicy(policyId: string): boolean {
+    const idx = this.policies.findIndex((p) => p.id === policyId);
+    if (idx < 0) {
+      return false;
+    }
+    this.policies.splice(idx, 1);
+    return true;
+  }
+
+  listPolicies(): PermissionPolicy[] {
+    return [...this.policies];
+  }
+
+  updatePolicy(policyId: string, updates: Partial<PermissionPolicy>): boolean {
+    const idx = this.policies.findIndex((p) => p.id === policyId);
+    if (idx < 0) {
+      return false;
+    }
+    this.policies[idx] = { ...this.policies[idx], ...updates };
+    this.policies.sort((a, b) => b.priority - a.priority);
+    return true;
+  }
+
+  evaluatePermission(toolName: string, context: PermissionContext): EvaluationResult {
+    const matchingPolicies = this.findMatchingPolicies(toolName, context);
+    const policiesEvaluated: PolicyResult[] = [];
+
+    if (matchingPolicies.length === 0) {
+      return {
+        allowed: true,
+        reason: "No matching policies, default allow",
+        policiesEvaluated: [],
+        needsPrompt: false,
+      };
+    }
+
+    for (const policy of matchingPolicies) {
+      const result = this.evaluatePolicy(policy, context);
+      policiesEvaluated.push(result);
+
+      if (result.effect === "deny") {
+        return {
+          allowed: false,
+          reason: `Denied by policy: ${policy.name}`,
+          policiesEvaluated,
+          needsPrompt: false,
+        };
+      }
+
+      if (result.effect === "prompt") {
+        return {
+          allowed: true,
+          reason: `Prompt required by policy: ${policy.name}`,
+          policiesEvaluated,
+          needsPrompt: true,
+        };
+      }
+    }
+
+    return {
+      allowed: true,
+      reason: `Allowed by ${matchingPolicies.length} policy(ies)`,
+      policiesEvaluated,
+      needsPrompt: false,
+    };
+  }
+
+  private findMatchingPolicies(
+    toolName: string,
+    context: PermissionContext,
+  ): PermissionPolicy[] {
+    return this.policies.filter((policy) => this.targetMatches(policy.target, toolName, context));
+  }
+
+  private targetMatches(
+    target: PolicyTarget,
+    toolName: string,
+    context: PermissionContext,
+  ): boolean {
+    switch (target.type) {
+      case "tool":
+        return target.toolName === toolName;
+      case "category":
+        return target.category === context.category;
+      case "tag":
+        return context.tags.includes(target.tag);
+      case "risk-level":
+        return target.level === context.riskLevel;
+      default:
+        return false;
+    }
+  }
+
+  private evaluatePolicy(policy: PermissionPolicy, context: PermissionContext): PolicyResult {
+    if (!policy.conditions || policy.conditions.length === 0) {
+      return {
+        effect: policy.effect,
+        policyId: policy.id,
+        matchedTarget: policy.target,
+      };
+    }
+
+    for (const condition of policy.conditions) {
+      if (!this.conditionHolds(condition, context)) {
+        return {
+          effect: "allow",
+          policyId: policy.id,
+          reason: `Condition ${condition.kind} not met`,
+          matchedTarget: policy.target,
+        };
+      }
+    }
+
+    return {
+      effect: policy.effect,
+      policyId: policy.id,
+      matchedTarget: policy.target,
+    };
+  }
+
+  private conditionHolds(condition: PolicyCondition, context: PermissionContext): boolean {
+    switch (condition.kind) {
+      case "always":
+        return true;
+      case "never":
+        return false;
+      case "boolean":
+        return context.flags?.[condition.flag] === true;
+      case "time-range": {
+        if (!context.timestamp) return true;
+        const now = context.timestamp.toTimeString().slice(0, 5);
+        return now >= condition.start && now <= condition.end;
+      }
+      case "path-match": {
+        if (!context.requestingPath) return true;
+        return condition.paths.some((p) => context.requestingPath!.startsWith(p));
+      }
+      default:
+        return true;
+    }
+  }
+}
+
+// Singleton instance
+let globalPolicyEngine: PolicyEngine | null = null;
+
+export function getGlobalPolicyEngine(): PolicyEngine {
+  if (!globalPolicyEngine) {
+    globalPolicyEngine = new PolicyEngine();
+  }
+  return globalPolicyEngine;
+}
diff --git a/src/mcp/server-registry.ts b/src/mcp/server-registry.ts
new file mode 100644
index 0000000000..25aadbdc97
--- /dev/null
+++ b/src/mcp/server-registry.ts
@@ -0,0 +1,156 @@
+/**
+ * MCP Server Registry - State management for MCP servers
+ */
+
+export enum ServerState {
+  STOPPED = "stopped",
+  STARTING = "starting",
+  RUNNING = "running",
+  STOPPING = "stopping",
+  ERROR = "error",
+}
+
+export interface McpServerConfig {
+  name: string;
+  command: string;
+  args?: string[];
+  env?: Record<string, string>;
+  rootUri?: string;
+  transport?: "stdio" | "http";
+  port?: number;
+  initializationOptions?: Record<string, unknown>;
+}
+
+export interface McpServerDescriptor {
+  id: string;
+  config: McpServerConfig;
+  state: ServerState;
+  errorMessage?: string;
+  startedAt?: Date;
+  pid?: number;
+}
+
+export type ServerEvent =
+  | { type: "state-change"; serverId: string; oldState: ServerState; newState: ServerState }
+  | { type: "error"; serverId: string; error: string }
+  | { type: "started"; serverId: string }
+  | { type: "stopped"; serverId: string };
+
+type ServerEventHandler = (event: ServerEvent) => void;
+
+export class McpServerRegistry {
+  private readonly servers = new Map<string, McpServerDescriptor>();
+  private readonly eventHandlers = new Set<ServerEventHandler>();
+
+  registerServer(id: string, config: McpServerConfig): void {
+    if (this.servers.has(id)) {
+      throw new Error(`Server already registered: ${id}`);
+    }
+    this.servers.set(id, {
+      id,
+      config,
+      state: ServerState.STOPPED,
+    });
+  }
+
+  unregisterServer(id: string): boolean {
+    const descriptor = this.servers.get(id);
+    if (!descriptor) {
+      return false;
+    }
+    if (descriptor.state === ServerState.RUNNING || descriptor.state === ServerState.STARTING) {
+      throw new Error(`Cannot unregister server while running: ${id}`);
+    }
+    return this.servers.delete(id);
+  }
+
+  getServerState(id: string): ServerState | undefined {
+    return this.servers.get(id)?.state;
+  }
+
+  getServerConfig(id: string): McpServerConfig | undefined {
+    return this.servers.get(id)?.config;
+  }
+
+  getServerDescriptor(id: string): McpServerDescriptor | undefined {
+    return this.servers.get(id);
+  }
+
+  listServers(): McpServerDescriptor[] {
+    return Array.from(this.servers.values());
+  }
+
+  listServersByState(state: ServerState): McpServerDescriptor[] {
+    return this.listServers().filter((s) => s.state === state);
+  }
+
+  setServerState(id: string, state: ServerState, errorMessage?: string): void {
+    const descriptor = this.servers.get(id);
+    if (!descriptor) {
+      throw new Error(`Server not found: ${id}`);
+    }
+    const oldState = descriptor.state;
+    descriptor.state = state;
+    if (state === ServerState.RUNNING) {
+      descriptor.startedAt = new Date();
+    }
+    if (errorMessage) {
+      descriptor.errorMessage = errorMessage;
+    }
+    this.emit({
+      type: "state-change",
+      serverId: id,
+      oldState,
+      newState: state,
+    });
+  }
+
+  setServerPid(id: string, pid: number): void {
+    const descriptor = this.servers.get(id);
+    if (!descriptor) {
+      throw new Error(`Server not found: ${id}`);
+    }
+    descriptor.pid = pid;
+  }
+
+  onEvent(handler: ServerEventHandler): () => void {
+    this.eventHandlers.add(handler);
+    return () => this.eventHandlers.delete(handler);
+  }
+
+  private emit(event: ServerEvent): void {
+    for (const handler of this.eventHandlers) {
+      try {
+        handler(event);
+      } catch {
+        // Ignore handler errors
+      }
+    }
+  }
+
+  isServerRegistered(id: string): boolean {
+    return this.servers.has(id);
+  }
+
+  getServerCount(): number {
+    return this.servers.size;
+  }
+
+  clear(): void {
+    const runningServers = this.listServersByState(ServerState.RUNNING);
+    if (runningServers.length > 0) {
+      throw new Error(`Cannot clear registry with running servers: ${runningServers.map((s) => s.id).join(", ")}`);
+    }
+    this.servers.clear();
+  }
+}
+
+// Singleton instance
+let globalRegistry: McpServerRegistry | null = null;
+
+export function getGlobalServerRegistry(): McpServerRegistry {
+  if (!globalRegistry) {
+    globalRegistry = new McpServerRegistry();
+  }
+  return globalRegistry;
+}
diff --git a/src/mcp/tool-registry.ts b/src/mcp/tool-registry.ts
new file mode 100644
index 0000000000..07ffdd2a66
--- /dev/null
+++ b/src/mcp/tool-registry.ts
@@ -0,0 +1,102 @@
+/**
+ * Tool Registry - Manages metadata schema for MCP tools
+ */
+
+export type ToolCategory = "filesystem" | "network" | "process" | "computation" | "communication";
+export type ToolRiskLevel = "low" | "medium" | "high" | "critical";
+
+export type ToolCapability =
+  | { kind: "file-read"; paths?: string[] }
+  | { kind: "file-write"; paths?: string[] }
+  | { kind: "network-http"; methods?: string[]; hosts?: string[] }
+  | { kind: "network-https"; methods?: string[]; hosts?: string[] }
+  | { kind: "process-spawn"; command?: string }
+  | { kind: "process-exec" };
+
+export interface ToolMetadata {
+  name: string;
+  description: string;
+  category: ToolCategory;
+  tags: string[];
+  inputSchema: Record<string, unknown>;
+  outputSchema?: Record<string, unknown>;
+  capabilities: ToolCapability[];
+  riskLevel: ToolRiskLevel;
+  deprecationNotice?: string;
+}
+
+export interface ToolFilter {
+  category?: ToolCategory;
+  riskLevel?: ToolRiskLevel;
+  tag?: string;
+  namePattern?: RegExp;
+}
+
+export class ToolRegistry {
+  private readonly tools = new Map<string, ToolMetadata>();
+
+  registerTool(metadata: ToolMetadata): void {
+    if (this.tools.has(metadata.name)) {
+      throw new Error(`Tool already registered: ${metadata.name}`);
+    }
+    this.tools.set(metadata.name, { ...metadata });
+  }
+
+  getTool(name: string): ToolMetadata | undefined {
+    return this.tools.get(name);
+  }
+
+  listTools(filter?: ToolFilter): ToolMetadata[] {
+    let results = Array.from(this.tools.values());
+
+    if (!filter) {
+      return results;
+    }
+
+    if (filter.category) {
+      results = results.filter((t) => t.category === filter.category);
+    }
+    if (filter.riskLevel) {
+      results = results.filter((t) => t.riskLevel === filter.riskLevel);
+    }
+    if (filter.tag) {
+      results = results.filter((t) => t.tags.includes(filter.tag!));
+    }
+    if (filter.namePattern) {
+      results = results.filter((t) => filter.namePattern!.test(t.name));
+    }
+
+    return results;
+  }
+
+  unregisterTool(name: string): boolean {
+    return this.tools.delete(name);
+  }
+
+  updateTool(name: string, metadata: Partial<ToolMetadata>): boolean {
+    const existing = this.tools.get(name);
+    if (!existing) {
+      return false;
+    }
+    this.tools.set(name, { ...existing, ...metadata });
+    return true;
+  }
+
+  hasTool(name: string): boolean {
+    return this.tools.has(name);
+  }
+
+  getToolCount(): number {
+    return this.tools.size;
+  }
+}
+
+// Singleton instance for global registry
+let globalRegistry: ToolRegistry | null = null;
+
+export function getGlobalToolRegistry(): ToolRegistry {
+  if (!globalRegistry) {
+    globalRegistry = new ToolRegistry();
+  }
+  return globalRegistry;
+}
diff --git a/src/tasks/task-api.ts b/src/tasks/task-api.ts
new file mode 100644
index 0000000000..608320e196
--- /dev/null
+++ b/src/tasks/task-api.ts
@@ -0,0 +1,544 @@
+/**
+ * Unified Task API
+ *
+ * Provides a clean, high-level interface for task management.
+ * All functions delegate to the underlying task-registry implementation.
+ *
+ * @example
+ * ```typescript
+ * import { createTask, transitionTask, queryTasks } from "./tasks/task-api.js";
+ *
+ * // Create a task
+ * const task = createTask({
+ *   runtime: "subagent",
+ *   task: "Process data",
+ *   ownerKey: "session:abc123",
+ * });
+ *
+ * // Transition to running
+ * transitionTask(task.taskId, { status: "running" });
+ *
+ * // Query tasks
+ * const activeTasks = queryTasks({ status: ["queued", "running"] });
+ * ```
+ */
+
+import {
+  cancelTaskById,
+  createTaskRecord,
+  deleteTaskRecordById,
+  ensureTaskRegistryReady,
+  findLatestTaskForFlowId,
+  findLatestTaskForOwnerKey,
+  findLatestTaskForRelatedSessionKey,
+  findTaskByRunId,
+  getTaskById,
+  getTaskRegistrySnapshot,
+  getTaskRegistrySummary,
+  isParentFlowLinkError,
+  linkTaskToFlowById,
+  listTaskRecords,
+  listTasksForFlowId,
+  listTasksForOwnerKey,
+  listTasksForRelatedSessionKey,
+  markTaskLostById,
+  markTaskRunningByRunId,
+  markTaskTerminalById,
+  markTaskTerminalByRunId,
+  recordTaskProgressByRunId,
+  resolveTaskForLookupToken,
+  setTaskCleanupAfterById,
+  setTaskProgressById,
+  setTaskRunDeliveryStatusByRunId,
+  setTaskTimingById,
+  updateTaskNotifyPolicyById,
+} from "./runtime-internal.js";
+
+import type {
+  TaskDeliveryState,
+  TaskDeliveryStatus,
+  TaskNotifyPolicy,
+  TaskRecord,
+  TaskRegistrySnapshot,
+  TaskRegistrySummary,
+  TaskRuntime,
+  TaskScopeKind,
+  TaskStatus,
+  TaskTerminalOutcome,
+} from "./task-registry.types.js";
+
+// Re-export types for convenience
+export type {
+  TaskDeliveryState,
+  TaskDeliveryStatus,
+  TaskNotifyPolicy,
+  TaskRecord,
+  TaskRegistrySnapshot,
+  TaskRegistrySummary,
+  TaskRuntime,
+  TaskScopeKind,
+  TaskStatus,
+  TaskTerminalOutcome,
+};
+
+// Re-export error type
+export { isParentFlowLinkError, ParentFlowLinkError } from "./task-registry.js";
+
+// ============================================
+// Task Creation
+// ============================================
+
+export interface CreateTaskParams {
+  /** Execution runtime type */
+  runtime: TaskRuntime;
+  /** Task description/instruction */
+  task: string;
+  /** Optional source ID for tracing */
+  sourceId?: string;
+  /** Session that requested this task */
+  requesterSessionKey?: string;
+  /** Owner session key (defaults to requesterSessionKey) */
+  ownerKey?: string;
+  /** Task scope: session or system */
+  scopeKind?: TaskScopeKind;
+  /** Delivery origin context */
+  requesterOrigin?: TaskDeliveryState["requesterOrigin"];
+  /** Child session key (for cancellable tasks) */
+  childSessionKey?: string;
+  /** Parent flow ID for orchestrated tasks */
+  parentFlowId?: string;
+  /** Parent task ID for nested tasks */
+  parentTaskId?: string;
+  /** Agent ID for routing */
+  agentId?: string;
+  /** Run ID for grouping related tasks */
+  runId?: string;
+  /** Human-readable label */
+  label?: string;
+  /** Prefer metadata update over creation */
+  preferMetadata?: boolean;
+  /** Initial status (defaults to "queued") */
+  status?: TaskStatus;
+  /** Delivery status */
+  deliveryStatus?: TaskDeliveryStatus;
+  /** Notification policy */
+  notifyPolicy?: TaskNotifyPolicy;
+  /** When task started */
+  startedAt?: number;
+  /** Last event timestamp */
+  lastEventAt?: number;
+  /** Cleanup scheduled at timestamp */
+  cleanupAfter?: number;
+  /** Progress message */
+  progressSummary?: string | null;
+  /** Terminal summary message */
+  terminalSummary?: string | null;
+  /** Terminal outcome */
+  terminalOutcome?: TaskTerminalOutcome | null;
+}
+
+/**
+ * Create a new task record.
+ * Alias for createTaskRecord with enhanced typing.
+ */
+export function createTask(params: CreateTaskParams): TaskRecord {
+  return createTaskRecord(params);
+}
+
+// ============================================
+// Task Transitions
+// ============================================
+
+export interface TransitionTaskParams {
+  /** Target task ID */
+  taskId: string;
+  /** New status (for terminal transitions) */
+  status?: Extract<TaskStatus, "succeeded" | "failed" | "timed_out" | "cancelled">;
+  /** Started timestamp */
+  startedAt?: number;
+  /** Ended timestamp */
+  endedAt?: number;
+  /** Last event timestamp */
+  lastEventAt?: number;
+  /** Error message */
+  error?: string;
+  /** Progress message */
+  progressSummary?: string | null;
+  /** Terminal summary */
+  terminalSummary?: string | null;
+  /** Terminal outcome */
+  terminalOutcome?: TaskTerminalOutcome | null;
+}
+
+/**
+ * Transition a task to a new state by ID.
+ */
+export function transitionTask(params: TransitionTaskParams): TaskRecord | null {
+  ensureTaskRegistryReady();
+  const { taskId, ...rest } = params;
+
+  if (rest.status) {
+    return markTaskTerminalById({
+      taskId,
+      status: rest.status,
+      endedAt: rest.endedAt ?? Date.now(),
+      lastEventAt: rest.lastEventAt,
+      error: rest.error,
+      terminalSummary: rest.terminalSummary,
+      terminalOutcome: rest.terminalOutcome,
+    });
+  }
+
+  // Non-terminal updates
+  if (rest.startedAt != null || rest.lastEventAt != null) {
+    return setTaskTimingById({
+      taskId,
+      startedAt: rest.startedAt,
+      lastEventAt: rest.lastEventAt,
+    });
+  }
+
+  if (rest.progressSummary !== undefined) {
+    return setTaskProgressById({
+      taskId,
+      progressSummary: rest.progressSummary,
+      lastEventAt: rest.lastEventAt ?? Date.now(),
+    });
+  }
+
+  return getTaskById(taskId) ?? null;
+}
+
+export interface TransitionTaskByRunIdParams {
+  /** Run ID to match tasks */
+  runId: string;
+  /** Runtime filter */
+  runtime?: TaskRuntime;
+  /** Session key filter */
+  sessionKey?: string;
+  /** New status */
+  status?: TaskStatus;
+  /** Started timestamp */
+  startedAt?: number;
+  /** Ended timestamp */
+  endedAt?: number;
+  /** Last event timestamp */
+  lastEventAt?: number;
+  /** Error message */
+  error?: string;
+  /** Progress message */
+  progressSummary?: string | null;
+  /** Terminal summary */
+  terminalSummary?: string | null;
+  /** Terminal outcome */
+  terminalOutcome?: TaskTerminalOutcome | null;
+}
+
+/**
+ * Transition multiple tasks by run ID.
+ */
+export function transitionTasksByRunId(
+  params: TransitionTaskByRunIdParams,
+): TaskRecord[] {
+  ensureTaskRegistryReady();
+  const { runId, runtime, sessionKey, status, ...rest } = params;
+
+  if (status === "running") {
+    return markTaskRunningByRunId({
+      runId,
+      runtime,
+      sessionKey,
+      startedAt: rest.startedAt,
+      lastEventAt: rest.lastEventAt,
+      progressSummary: rest.progressSummary,
+    });
+  }
+
+  if (
+    status === "succeeded" ||
+    status === "failed" ||
+    status === "timed_out" ||
+    status === "cancelled"
+  ) {
+    return markTaskTerminalByRunId({
+      runId,
+      runtime,
+      sessionKey,
+      status,
+      startedAt: rest.startedAt,
+      endedAt: rest.endedAt ?? Date.now(),
+      lastEventAt: rest.lastEventAt,
+      error: rest.error,
+      progressSummary: rest.progressSummary,
+      terminalSummary: rest.terminalSummary,
+      terminalOutcome: rest.terminalOutcome,
+    });
+  }
+
+  if (rest.progressSummary !== undefined) {
+    return recordTaskProgressByRunId({
+      runId,
+      runtime,
+      sessionKey,
+      lastEventAt: rest.lastEventAt ?? Date.now(),
+      progressSummary: rest.progressSummary,
+    });
+  }
+
+  return [];
+}
+
+// ============================================
+// Task Queries
+// ============================================
+
+export interface QueryTasksParams {
+  /** Filter by status(es) */
+  status?: TaskStatus | TaskStatus[];
+  /** Filter by runtime */
+  runtime?: TaskRuntime;
+  /** Filter by owner key */
+  ownerKey?: string;
+  /** Filter by flow ID */
+  flowId?: string;
+  /** Filter by related session key */
+  sessionKey?: string;
+  /** Filter by agent ID */
+  agentId?: string;
+}
+
+/**
+ * Query tasks with optional filters.
+ */
+export function queryTasks(params?: QueryTasksParams): TaskRecord[] {
+  ensureTaskRegistryReady();
+
+  if (!params) {
+    return listTaskRecords();
+  }
+
+  const { status, runtime, ownerKey, flowId, sessionKey, agentId } = params;
+
+  // Get base task list based on primary filter
+  let tasks: TaskRecord[];
+
+  if (sessionKey) {
+    tasks = listTasksForRelatedSessionKey(sessionKey);
+  } else if (ownerKey) {
+    tasks = listTasksForOwnerKey(ownerKey);
+  } else if (flowId) {
+    tasks = listTasksForFlowId(flowId);
+  } else {
+    tasks = listTaskRecords();
+  }
+
+  // Apply filters
+  if (status) {
+    const statuses = Array.isArray(status) ? status : [status];
+    tasks = tasks.filter((t) => statuses.includes(t.status));
+  }
+
+  if (runtime) {
+    tasks = tasks.filter((t) => t.runtime === runtime);
+  }
+
+  if (agentId) {
+    tasks = tasks.filter((t) => t.agentId?.trim() === agentId.trim());
+  }
+
+  return tasks;
+}
+
+/**
+ * Get a single task by ID.
+ */
+export function getTask(taskId: string): TaskRecord | undefined {
+  return getTaskById(taskId);
+}
+
+/**
+ * Find a task by run ID.
+ */
+export function findTask(runId: string): TaskRecord | undefined {
+  return findTaskByRunId(runId);
+}
+
+/**
+ * Find the latest task for a session.
+ */
+export function findLatestTask(sessionKey: string): TaskRecord | undefined {
+  return findLatestTaskForRelatedSessionKey(sessionKey);
+}
+
+/**
+ * Find the latest task for an owner.
+ */
+export function findLatestTaskForOwner(ownerKey: string): TaskRecord | undefined {
+  return findLatestTaskForOwnerKey(ownerKey);
+}
+
+/**
+ * Find the latest task for a flow.
+ */
+export function findLatestTaskForFlow(flowId: string): TaskRecord | undefined {
+  return findLatestTaskForFlowId(flowId);
+}
+
+/**
+ * Resolve a task by lookup token (ID, run ID, or session key).
+ */
+export function resolveTask(token: string): TaskRecord | undefined {
+  return resolveTaskForLookupToken(token);
+}
+
+// ============================================
+// Task Lifecycle Operations
+// ============================================
+
+export interface CancelTaskParams {
+  taskId: string;
+  cfg: import("../config/config.js").OpenClawConfig;
+}
+
+/**
+ * Cancel a task by ID.
+ */
+export async function cancelTask(
+  params: CancelTaskParams,
+): Promise<{ found: boolean; cancelled: boolean; reason?: string; task?: TaskRecord }> {
+  return cancelTaskById(params);
+}
+
+/**
+ * Mark a task as lost (backing session disappeared).
+ */
+export function markTaskLost(params: {
+  taskId: string;
+  endedAt?: number;
+  lastEventAt?: number;
+  error?: string;
+  cleanupAfter?: number;
+}): TaskRecord | null {
+  return markTaskLostById({
+    taskId: params.taskId,
+    endedAt: params.endedAt ?? Date.now(),
+    lastEventAt: params.lastEventAt,
+    error: params.error,
+    cleanupAfter: params.cleanupAfter,
+  });
+}
+
+/**
+ * Link a task to a flow.
+ */
+export function linkTaskToFlow(params: { taskId: string; flowId: string }): TaskRecord | null {
+  return linkTaskToFlowById(params);
+}
+
+/**
+ * Update task notification policy.
+ */
+export function updateTaskNotifyPolicy(params: {
+  taskId: string;
+  notifyPolicy: TaskNotifyPolicy;
+}): TaskRecord | null {
+  return updateTaskNotifyPolicyById(params);
+}
+
+/**
+ * Update task delivery status by run ID.
+ */
+export function updateTaskDeliveryStatus(params: {
+  runId: string;
+  runtime?: TaskRuntime;
+  sessionKey?: string;
+  deliveryStatus: TaskDeliveryStatus;
+}): TaskRecord[] {
+  return setTaskRunDeliveryStatusByRunId(params);
+}
+
+// ============================================
+// Registry Operations
+// ============================================
+
+/**
+ * Get task registry summary (counts by status and runtime).
+ */
+export function getTaskSummary(): TaskRegistrySummary {
+  return getTaskRegistrySummary();
+}
+
+/**
+ * Get full task registry snapshot.
+ */
+export function getTaskSnapshot(): TaskRegistrySnapshot {
+  return getTaskRegistrySnapshot();
+}
+
+/**
+ * Delete a task by ID.
+ */
+export function deleteTask(taskId: string): boolean {
+  return deleteTaskRecordById(taskId);
+}
+
+// ============================================
+// Task Hierarchy
+// ============================================
+
+/**
+ * Get child tasks for a task.
+ */
+export function getChildTasks(taskId: string): TaskRecord[] {
+  return queryTasks({}).filter((t) => t.parentTaskId === taskId);
+}
+
+/**
+ * Get child tasks for a flow.
+ */
+export function getFlowChildTasks(flowId: string): TaskRecord[] {
+  return listTasksForFlowId(flowId);
+}
+
+/**
+ * Check if a task has active children.
+ */
+export function hasActiveChildren(taskId: string): boolean {
+  return getChildTasks(taskId).some(
+    (t) => t.status === "queued" || t.status === "running",
+  );
+}
+
+/**
+ * Check if a flow has active tasks.
+ */
+export function flowHasActiveTasks(flowId: string): boolean {
+  return listTasksForFlowId(flowId).some(
+    (t) => t.status === "queued" || t.status === "running",
+  );
+}
+
