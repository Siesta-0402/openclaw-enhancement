@@ -0,0 +1,198 @@
+/**
+ * Frontmatter Parsing and Serialization
+ * ======================================
+ *
+ * Handles YAML frontmatter parsing for memory entries.
+ * Supports the four-type memory classification with type-specific fields.
+ */
+
+import type {
+  MemoryEntry,
+  MemoryFrontmatter,
+  MemoryPriority,
+  MemoryType,
+  ParsedMemory,
+} from "./types.js";
+
+/** Regex to match YAML frontmatter */
+const FRONTMATTER_REGEX = /^---\n([\s\S]*?)\n---\n([\s\S]*)$/;
+
+/** Regex to parse individual YAML lines */
+const YAML_LINE_REGEX = /^(\w+):\s*(.*)$/;
+
+/** Parse a raw memory string into frontmatter and content */
+export function parseMemoryRaw(raw: string): ParsedMemory | null {
+  const match = raw.match(FRONTMATTER_REGEX);
+  if (!match) {
+    return null;
+  }
+
+  const [, frontmatterYaml, content] = match;
+  const frontmatter = parseFrontmatter(frontmatterYaml);
+
+  if (!frontmatter || !content.trim()) {
+    return null;
+  }
+
+  return {
+    frontmatter,
+    content: content.trim(),
+    raw,
+  };
+}
+
+/** Parse YAML frontmatter string into structured object */
+export function parseFrontmatter(yaml: string): MemoryFrontmatter | null {
+  const result: Partial<MemoryFrontmatter> = {};
+  const lines = yaml.split("\n");
+
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (!trimmed || trimmed.startsWith("#")) {
+      continue;
+    }
+
+    const match = trimmed.match(YAML_LINE_REGEX);
+    if (!match) {
+      continue;
+    }
+
+    const [, key, value] = match;
+    const trimmedValue = value.trim();
+
+    switch (key) {
+      case "type":
+        if (isMemoryType(trimmedValue)) {
+          result.type = trimmedValue;
+        }
+        break;
+      case "priority":
+        if (isMemoryPriority(trimmedValue)) {
+          result.priority = trimmedValue;
+        }
+        break;
+      case "tags":
+        result.tags = parseTags(trimmedValue);
+        break;
+      case "created":
+      case "updated":
+      case "expiresAt":
+        if (key === "expiresAt") {
+          result.expiresAt = trimmedValue === "null" ? null : trimmedValue;
+        } else {
+          (result as Record<string, string>)[key] = trimmedValue;
+        }
+        break;
+      case "sessionId":
+      case "projectId":
+      case "source":
+        (result as Record<string, string | undefined>)[key] =
+          trimmedValue === "" ? undefined : trimmedValue;
+        break;
+    }
+  }
+
+  // Validate required fields
+  if (!result.type || !result.created || !result.updated) {
+    return null;
+  }
+
+  return {
+    type: result.type,
+    created: result.created,
+    updated: result.updated,
+    tags: result.tags ?? [],
+    priority: result.priority ?? getDefaultPriority(result.type),
+    sessionId: result.sessionId,
+    projectId: result.projectId,
+    expiresAt: result.expiresAt ?? null,
+    source: result.source,
+  };
+}
+
+/** Serialize a memory entry back to raw string with frontmatter */
+export function serializeMemoryEntry(entry: MemoryEntry): string {
+  const frontmatter = serializeFrontmatter(entry);
+  return `---\n${frontmatter}\n---\n${entry.content}`;
+}
+
+/** Serialize frontmatter object to YAML string */
+export function serializeFrontmatter(entry: MemoryEntry): string {
+  const lines: string[] = [];
+
+  lines.push(`type: ${entry.type}`);
+  lines.push(`created: ${entry.created}`);
+  lines.push(`updated: ${entry.updated}`);
+  lines.push(`priority: ${entry.priority}`);
+
+  if (entry.tags.length > 0) {
+    lines.push(`tags: [${entry.tags.join(", ")}]`);
+  }
+
+  if (entry.sessionId) {
+    lines.push(`sessionId: ${entry.sessionId}`);
+  }
+
+  if (entry.projectId) {
+    lines.push(`projectId: ${entry.projectId}`);
+  }
+
+  if (entry.expiresAt) {
+    lines.push(`expiresAt: ${entry.expiresAt}`);
+  } else {
+    lines.push(`expiresAt: null`);
+  }
+
+  if (entry.source) {
+    lines.push(`source: ${entry.source}`);
+  }
+
+  return lines.join("\n");
+}
+
+/** Parse a tags string (handles both [a, b, c] and a, b, c formats) */
+function parseTags(value: string): string[] {
+  const trimmed = value.trim();
+  if (trimmed.startsWith("[")) {
+    // Array format: [tag1, tag2, tag3]
+    const inner = trimmed.slice(1, -1);
+    return inner
+      .split(",")
+      .map((t) => t.trim())
+      .filter(Boolean);
+  }
+  // Space/comma separated
+  return trimmed
+    .split(/[,\s]+/)
+    .map((t) => t.trim())
+    .filter(Boolean);
+}
+
+/** Type guard for MemoryType */
+function isMemoryType(value: string): value is MemoryType {
+  return ["user", "feedback", "project", "reference"].includes(value);
+}
+
+/** Type guard for MemoryPriority */
+function isMemoryPriority(value: string): value is MemoryPriority {
+  return ["high", "medium", "low"].includes(value);
+}
+
+/** Get default priority for a memory type */
+function getDefaultPriority(type: MemoryType): MemoryPriority {
+  const defaults: Record<MemoryType, MemoryPriority> = {
+    user: "high",
+    feedback: "medium",
+    project: "medium",
+    reference: "low",
+  };
+  return defaults[type];
+}
+
+/** Update the updated timestamp when modifying an entry */
+export function touchMemoryEntry(entry: MemoryEntry): MemoryEntry {
+  return {
+    ...entry,
+    updated: new Date().toISOString(),
+  };
+}
