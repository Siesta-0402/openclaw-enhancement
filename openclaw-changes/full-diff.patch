--- /dev/null
+++ b/src/testing/green-contract/runner.ts
@@ -0,0 +1,227 @@
+/**
+ * RegressionRunner - Executes regression tests across contracts
+ */
+
+import type { GreenContractEvaluator, EvaluationSummary, ContractResult } from "./evaluator.js";
+import { TestResultCollector } from "./collector.js";
+import type { GreenLevel, ContractFilter } from "./types.js";
+import { GreenLevel as GL } from "./types.js";
+
+export interface RegressionOptions {
+  /** Only run contracts at or above this level (lower number = higher priority) */
+  minLevel?: GreenLevel;
+  /** Only run contracts with these tags */
+  tags?: string[];
+  /** Parallel execution count (default: 1) */
+  concurrency?: number;
+  /** Timeout per contract in ms (default: 30000) */
+  timeoutMs?: number;
+  /** Continue on failure (default: false) */
+  failFast?: boolean;
+  /** Baseline results to compare against */
+  baseline?: EvaluationSummary;
+}
+
+export interface RegressionDiff {
+  newFailures: string[];
+  fixedFailures: string[];
+  stillFailing: string[];
+  regressions: Array<{ contractId: string; contractName: string; before: boolean; after: boolean }>;
+  summary: {
+    totalContracts: number;
+    improved: number;
+    regressed: number;
+    unchanged: number;
+  };
+}
+
+export class RegressionRunner {
+  constructor(
+    private readonly evaluator: GreenContractEvaluator,
+    private readonly collector: TestResultCollector,
+  ) {}
+
+  async run(options: RegressionOptions = {}): Promise<EvaluationSummary> {
+    const {
+      minLevel = GL.INFO,
+      tags,
+      concurrency = 1,
+      timeoutMs = 30_000,
+      failFast = false,
+    } = options;
+
+    this.collector.clear();
+
+    // Build filter: only contracts at or above minLevel
+    const contracts = this.evaluator.listContracts({ tags });
+
+    // Filter by level (only levels >= minLevel, since lower number = higher priority)
+    const filteredContracts = contracts.filter((c) => c.level <= minLevel);
+
+    if (concurrency === 1) {
+      // Sequential execution
+      for (const contract of filteredContracts) {
+        const result = await this.runContract(contract.id, timeoutMs);
+        this.collector.addResult(result);
+        if (failFast && !result.result.passed && this.isBlockingLevel(contract.level)) {
+          break;
+        }
+      }
+    } else {
+      // Parallel execution
+      await this.runParallel(filteredContracts.map((c) => c.id), concurrency, timeoutMs, failFast);
+    }
+
+    return this.collector.getSummary();
+  }
+
+  async runBaseline(): Promise<EvaluationSummary> {
+    this.collector.clear();
+    const summary = await this.evaluator.evaluateAll();
+    for (const result of summary.results) {
+      this.collector.addResult(result);
+    }
+    return summary;
+  }
+
+  compareWithBaseline(summary: EvaluationSummary): RegressionDiff {
+    const baseline = summary.baseline;
+    if (!baseline) {
+      return {
+        newFailures: [],
+        fixedFailures: [],
+        stillFailing: [],
+        regressions: [],
+        summary: { totalContracts: 0, improved: 0, regressed: 0, unchanged: 0 },
+      };
+    }
+
+    const baselineMap = new Map(baseline.results.map((r) => [r.contractId, r]));
+    const newFailures: string[] = [];
+    const fixedFailures: string[] = [];
+    const stillFailing: string[] = [];
+    const regressions: Array<{ contractId: string; contractName: string; before: boolean; after: boolean }> = [];
+
+    for (const result of summary.results) {
+      const baselineResult = baselineMap.get(result.contractId);
+      if (!baselineResult) {
+        // New contract, no comparison
+        continue;
+      }
+
+      const beforePassed = baselineResult.result.passed;
+      const afterPassed = result.result.passed;
+
+      if (!beforePassed && afterPassed) {
+        fixedFailures.push(result.contractId);
+      } else if (beforePassed && !afterPassed) {
+        regressions.push({
+          contractId: result.contractId,
+          contractName: result.contractName,
+          before: true,
+          after: false,
+        });
+      } else if (!beforePassed && !afterPassed) {
+        stillFailing.push(result.contractId);
+      }
+    }
+
+    for (const result of summary.failures) {
+      if (!baselineMap.has(result.contractId) || baselineMap.get(result.contractId)!.result.passed) {
+        newFailures.push(result.contractId);
+      }
+    }
+
+    return {
+      newFailures,
+      fixedFailures,
+      stillFailing,
+      regressions,
+      summary: {
+        totalContracts: summary.results.length,
+        improved: fixedFailures.length,
+        regressed: regressions.length,
+        unchanged: summary.results.length - fixedFailures.length - regressions.length - newFailures.length,
+      },
+    };
+  }
+
+  private async runContract(contractId: string, timeoutMs: number): Promise<ContractResult> {
+    const contract = this.evaluator.getContract(contractId);
+    if (!contract) {
+      return {
+        contractId,
+        contractName: "unknown",
+        level: GL.INFO,
+        result: { passed: false, message: "Contract not found" },
+        durationMs: 0,
+        timestamp: new Date(),
+      };
+    }
+
+    const startTime = Date.now();
+
+    try {
+      const timeoutPromise = new Promise<never>((_, reject) => {
+        setTimeout(() => reject(new Error("Contract timed out")), timeoutMs);
+      });
+
+      const result = await Promise.race([this.evaluator.evaluate(contractId), timeoutPromise]);
+      return {
+        contractId,
+        contractName: contract.name,
+        level: contract.level,
+        result: result as import("./types.js").TestResult,
+        durationMs: Date.now() - startTime,
+        timestamp: new Date(),
+      };
+    } catch (err) {
+      return {
+        contractId,
+        contractName: contract.name,
+        level: contract.level,
+        result: {
+          passed: false,
+          message: `Execution error: ${err instanceof Error ? err.message : String(err)}`,
+          durationMs: Date.now() - startTime,
+        },
+        durationMs: Date.now() - startTime,
+        timestamp: new Date(),
+      };
+    }
+  }
+
+  private async runParallel(
+    contractIds: string[],
+    concurrency: number,
+    timeoutMs: number,
+    failFast: boolean,
+  ): Promise<void> {
+    const queue = [...contractIds];
+    const running: Promise<void>[] = [];
+
+    const runNext = async (): Promise<void> => {
+      while (queue.length > 0) {
+        if (failFast && this.collector.getFailureCount() > 0) {
+          break;
+        }
+        const contractId = queue.shift();
+        if (!contractId) {
+          break;
+        }
+        const result = await this.runContract(contractId, timeoutMs);
+        this.collector.addResult(result);
+      }
+    };
+
+    for (let i = 0; i < Math.min(concurrency, contractIds.length); i++) {
+      running.push(runNext());
+    }
+
+    await Promise.all(running);
+  }
+
+  private isBlockingLevel(level: GreenLevel): boolean {
+    return level === GL.CRITICAL || level === GL.HIGH;
+  }
+}
