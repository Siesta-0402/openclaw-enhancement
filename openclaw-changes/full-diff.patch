+/**
+ * MicroCompact (L2)
+ * ==================
+ *
+ * Time-based compaction that clears old tool result content
+ * while preserving structure. Inspired by Claude Code's microcompact.
+ *
+ * Trigger: Time gap since last assistant message exceeds threshold
+ * Action: Content-clear old tool results, keep recent N
+ * Tokens saved: ~30-50% of tool result content
+ */
+
+import type { AgentMessage } from "@mariozechner/pi-agent-core";
+
+/** Configuration for MicroCompact */
+export interface MicroCompactConfig {
+  /** Time gap threshold in minutes */
+  gapThresholdMinutes: number;
+  /** Number of recent tool results to preserve */
+  keepRecent: number;
+  /** Token budget for tool results */
+  maxToolResultTokens: number;
+  /** Enable time-based triggering */
+  enabled: boolean;
+}
+
+/** Default MicroCompact configuration */
+export const DEFAULT_MICRO_COMPACT_CONFIG: MicroCompactConfig = {
+  gapThresholdMinutes: 30,
+  keepRecent: 3,
+  maxToolResultTokens: 2000,
+  enabled: true,
+};
+
+/** Tool types that are compactable */
+const COMPACTABLE_TOOLS = new Set([
+  "Read",
+  "Glob",
+  "Grep",
+  "WebFetch",
+  "WebSearch",
+  "Bash",
+  "Write",
+  "Edit",
+]);
+
+/** Marker for cleared tool result content */
+export const TIME_BASED_MC_CLEARED_MESSAGE =
+  "[Old tool result content cleared]";
+
+/** Result of MicroCompact operation */
+export interface MicroCompactResult {
+  /** Whether compaction was applied */
+  compacted: boolean;
+  /** Messages after compaction */
+  messages: AgentMessage[];
+  /** Tokens saved by compaction */
+  tokensSaved: number;
+  /** Gap in minutes that triggered compaction */
+  gapMinutes?: number;
+  /** Details of changes */
+  details: {
+    toolsCleared: number;
+    toolsKept: number;
+  };
+}
+
+/**
+ * L2 MicroCompact: Time-based tool result clearing.
+ *
+ * When the gap since the last assistant message exceeds the threshold,
+ * tool results older than the keepRecent window are content-cleared.
+ * This reduces token count without changing message structure.
+ */
+export function applyMicroCompact(
+  messages: AgentMessage[],
+  config: Partial<MicroCompactConfig> = {}
+): MicroCompactResult {
+  const cfg = { ...DEFAULT_MICRO_COMPACT_CONFIG, ...config };
+
+  if (!cfg.enabled) {
+    return {
+      compacted: false,
+      messages,
+      tokensSaved: 0,
+      details: { toolsCleared: 0, toolsKept: 0 },
+    };
+  }
+
+  // Find last assistant message
+  const lastAssistantIndex = findLastAssistantIndex(messages);
+  if (lastAssistantIndex === -1) {
+    return {
+      compacted: false,
+      messages,
+      tokensSaved: 0,
+      details: { toolsCleared: 0, toolsKept: 0 },
+    };
+  }
+
+  // Calculate time gap
+  const lastAssistantTime = new Date(
+    messages[lastAssistantIndex].timestamp
+  ).getTime();
+  const gapMs = Date.now() - lastAssistantTime;
+  const gapMinutes = gapMs / (1000 * 60);
+
+  // Check if gap exceeds threshold
+  if (gapMinutes < cfg.gapThresholdMinutes) {
+    return {
+      compacted: false,
+      messages,
+      tokensSaved: 0,
+      details: { toolsCleared: 0, toolsKept: 0 },
+    };
+  }
+
+  // Collect compactable tool IDs in encounter order
+  const compactableIds = collectCompactableToolIds(messages);
+
+  // Keep the most recent N, clear the rest
+  const keepRecent = Math.max(1, cfg.keepRecent);
+  const keepSet = new Set(compactableIds.slice(-keepRecent));
+  const clearSet = new Set(
+    compactableIds.filter((id) => !keepSet.has(id))
+  );
+
+  if (clearSet.size === 0) {
+    return {
+      compacted: false,
+      messages,
+      tokensSaved: 0,
+      details: { toolsCleared: 0, toolsKept: keepSet.size },
+    };
+  }
+
+  let tokensSaved = 0;
+  let toolsCleared = 0;
+
+  const result = messages.map((message) => {
+    if (message.type !== "user" || !Array.isArray(message.message.content)) {
+      return message;
+    }
+
+    let touched = false;
+    const newContent = message.message.content.map((block) => {
+      if (
+        block.type === "tool_result" &&
+        clearSet.has(block.tool_use_id) &&
+        block.content !== TIME_BASED_MC_CLEARED_MESSAGE
+      ) {
+        const saved = estimateToolResultTokens(block);
+        tokensSaved += saved;
+        toolsCleared++;
+        touched = true;
+        return { ...block, content: TIME_BASED_MC_CLEARED_MESSAGE };
+      }
+      return block;
+    });
+
+    if (!touched) {return message;}
+    return {
+      ...message,
+      message: { ...message.message, content: newContent },
+    };
+  });
+
+  return {
+    compacted: toolsCleared > 0,
+    messages: result,
+    tokensSaved,
+    gapMinutes: Math.round(gapMinutes),
+    details: {
+      toolsCleared,
+      toolsKept: keepSet.size,
+    },
+  };
+}
+
+/**
+ * Check if MicroCompact should trigger based on time gap.
+ */
+export function shouldMicroCompact(
+  messages: AgentMessage[],
+  config?: Partial<MicroCompactConfig>
+): { shouldTrigger: boolean; gapMinutes?: number } {
+  const cfg = { ...DEFAULT_MICRO_COMPACT_CONFIG, ...config };
+
+  const lastAssistantIndex = findLastAssistantIndex(messages);
+  if (lastAssistantIndex === -1) {
+    return { shouldTrigger: false };
+  }
+
+  const lastAssistantTime = new Date(
+    messages[lastAssistantIndex].timestamp
+  ).getTime();
+  const gapMinutes = (Date.now() - lastAssistantTime) / (1000 * 60);
+
+  return {
+    shouldTrigger: gapMinutes >= cfg.gapThresholdMinutes,
+    gapMinutes: Math.round(gapMinutes),
+  };
+}
+
+/**
+ * Collect tool_use IDs from compactable tools in encounter order.
+ */
+function collectCompactableToolIds(messages: AgentMessage[]): string[] {
+  const ids: string[] = [];
+  for (const message of messages) {
+    if (
+      message.type === "assistant" &&
+      Array.isArray(message.message.content)
+    ) {
+      for (const block of message.message.content) {
+        if (
+          block.type === "tool_use" &&
+          COMPACTABLE_TOOLS.has(block.name)
+        ) {
+          ids.push(block.id);
+        }
+      }
+    }
+  }
+  return ids;
+}
+
+/**
+ * Find the index of the last assistant message.
+ */
+function findLastAssistantIndex(messages: AgentMessage[]): number {
+  for (let i = messages.length - 1; i >= 0; i--) {
+    if (messages[i].type === "assistant") {
+      return i;
+    }
+  }
+  return -1;
+}
+
+/**
+ * Estimate token count for a tool result block.
+ */
+function estimateToolResultTokens(block: {
+  content?: string | unknown[];
+}): number {
+  if (!block.content) {return 0;}
+
+  if (typeof block.content === "string") {
+    // Rough: ~4 chars per token
+    return Math.ceil(block.content.length / 4);
+  }
+
+  if (Array.isArray(block.content)) {
+    return block.content.reduce((sum, item) => {
+      if (typeof item === "string") {
+        return sum + Math.ceil(item.length / 4);
+      }
+      // Images/documents ~2000 tokens
+      if (item && typeof item === "object" && "type" in item) {
+        const itemType = (item as { type: string }).type;
+        if (itemType === "image" || itemType === "document") {
+          return sum + 2000;
+        }
+      }
+      return sum;
+    }, 0);
+  }
+
+  return 0;
+}
