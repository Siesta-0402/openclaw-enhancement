+
+export const LANGUAGE_TO_EXTENSIONS: Record<string, string[]> = Object.entries(
+  EXTENSION_TO_LANGUAGE,
+).reduce(
+  (acc, [ext, lang]) => {
+    if (!acc[lang]) {
+      acc[lang] = [];
+    }
+    acc[lang].push(ext);
+    return acc;
+  },
+  {} as Record<string, string[]>,
+);
+
+export const LANGUAGE_CONFIGS: Record<string, LanguageConfig> = {
+  typescript: { languageId: "typescript", extensions: [".ts", ".tsx", ".js", ".jsx", ".mjs"], lspServerId: "typescript-language-server" },
+  python: { languageId: "python", extensions: [".py", ".pyw"], lspServerId: "python-lsp-server" },
+  rust: { languageId: "rust", extensions: [".rs"], lspServerId: "rust-analyzer" },
