+
+/**
+ * TaskStatusWatcher - Signal-based reactive task status monitoring
+ *
+ * Provides a reactive way to monitor task status changes.
+ * Subscribers are notified whenever the task snapshot changes.
+ */
+export class TaskStatusWatcher {
+  private statusSignal: Signal<TaskStatusSnapshot>;
+  private currentTasks: TaskRecord[] = [];
+
+  constructor(initialTasks: TaskRecord[] = []) {
+    this.statusSignal = new Signal<TaskStatusSnapshot>(
+      buildTaskStatusSnapshot(initialTasks)
+    );
+    this.currentTasks = initialTasks;
+  }
+
+  /**
+   * Get the current status snapshot.
+   */
+  getSnapshot(): TaskStatusSnapshot {
+    return this.statusSignal.get();
+  }
+
+  /**
+   * Update tasks and notify subscribers if changed.
+   */
+  updateTasks(tasks: TaskRecord[], now?: number): void {
+    this.currentTasks = tasks;
+    const newSnapshot = buildTaskStatusSnapshot(tasks, { now });
+    this.statusSignal.set(newSnapshot);
+  }
+
+  /**
+   * Subscribe to status changes.
+   * @returns Unsubscribe function
+   */
+  subscribe(callback: SignalCallback<TaskStatusSnapshot>): () => void {
+    return this.statusSignal.subscribe(callback);
+  }
+
+  /**
+   * Unsubscribe from status changes.
+   */
+  unsubscribe(callback: SignalCallback<TaskStatusSnapshot>): void {
+    this.statusSignal.unsubscribe(callback);
+  }
+
+  /**
+   * Get the active task count (reactive).
+   */
+  get activeCount(): number {
+    return this.statusSignal.get().activeCount;
+  }
+
+  /**
+   * Get whether there are any active tasks (reactive).
+   */
+  get hasActiveTasks(): boolean {
+    return this.statusSignal.get().activeCount > 0;
+  }
+
+  /**
+   * Destroy the watcher and clear all subscriptions.
+   */
+  destroy(): void {
+    this.statusSignal.destroy();
+  }
+}
+
+/**
+ * Create a task status watcher with optional initial tasks.
+ */
+export function createTaskStatusWatcher(initialTasks: TaskRecord[] = []): TaskStatusWatcher {
+  return new TaskStatusWatcher(initialTasks);
+}
